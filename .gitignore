# Build trees (including per-preset build/<preset>/ from CMakePresets.json).
# build-*/ is root-anchored: unanchored it would also swallow unrelated
# directories like .github/actions/build-docs/.
build/
/build-*/
.cache/
.claude/
compile_commands.json
Testing/

# Generated sources (fypp-expanded Fortran, configured headers) — produced
# into the build tree, never committed.
*.mod

# Transient benchmark run output; curated results live in
# doc/dev/benchmark/baseline/ and are committed explicitly.
benchmark/data/*.json

# Compiled objects / archives
*.o
*.a

__pycache__/
