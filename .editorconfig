root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# C / C++ sources and the .inc translation-unit fragments — 2-space indent.
[*.{c,cc,cpp,h,hh,hpp,inc}]
indent_size = 2

# Fortran free-form — 2-space indent.
[*.f90]
indent_size = 2

# Python (codegen, benchmark harness, scripts).
[*.py]
indent_size = 4

# CMake.
[{CMakeLists.txt,*.cmake,*.cmake.in}]
indent_size = 4

# Data / config.
[*.{json,yml,yaml,toml}]
indent_size = 2

# Markdown — keep trailing whitespace (two spaces = hard line break).
[*.md]
indent_size = 2
trim_trailing_whitespace = false
