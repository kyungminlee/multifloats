# Sphinx configuration template (shared shape across eplinalg /
# epblas-parallel / multifloats). ./doc/build.sh substitutes
# @PROJECT_VERSION@ from the repo-root VERSION file and writes conf.py
# (git-ignored) next to this template, then runs sphinx-build.

import os.path

project = "multifloats"
author = "Kyungmin Lee"
copyright = "2026, Kyungmin Lee"

# Single source of truth: the root VERSION file (see doc/build.sh).
version = "@PROJECT_VERSION@"
release = "@PROJECT_VERSION@"

extensions = [
    "myst_parser",        # Markdown (MyST) authoring
    "breathe",            # Doxygen XML -> Sphinx
    "sphinx_copybutton",  # copy button on code blocks
    "sphinx_design",      # grids / cards / tabs
]

myst_enable_extensions = [
    "colon_fence",   # ::: fenced directives
    "deflist",       # definition lists
    "dollarmath",    # $...$ / $$...$$ math
    "fieldlist",
    "substitution",
    "tasklist",
]
myst_heading_anchors = 3  # auto cross-reference anchors for h1..h3

# -- Breathe (C / C++ API extraction) ----------------------------------------
breathe_projects = {
    "multifloats": os.path.join(os.path.dirname(__file__), "_doxygen", "xml"),
}
breathe_default_project = "multifloats"
breathe_default_members = ("members",)
breathe_domain_by_extension = {"h": "cpp"}  # treat .h as C++

source_suffix = {".md": "markdown", ".rst": "restructuredtext"}
root_doc = "index"
exclude_patterns = [
    "_build",
    "_doxygen",
    ".venv",
    "Doxyfile",
    "*.in",               # conf.py.in / Doxyfile.in templates
    "requirements.txt",
    "README.md",          # build instructions, not a doc page
]

html_theme = "furo"
html_title = "multifloats"
html_static_path = ["_static"]
templates_path = ["_templates"]
