        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        real(qp) :: tmp(${SIZES(rank)}$)
        real(qp) :: tmp_res(${DIM_REDUCED_SIZES(rank)}$)
        integer :: ${IVARS(rank)}$
$:conv_loops(rank, 'array', 'tmp', 'to_qp')
        if (present(mask)) then
            tmp_res = ${func}$(tmp, dim=dim, mask=mask)
        else
            tmp_res = ${func}$(tmp, dim=dim)
        end if
$:conv_loops(rank - 1, 'tmp_res', 'res', 'from_qp')
    end function
#:endif

#:endfor
#:endfor
