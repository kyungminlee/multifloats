        integer :: ${IVARS(rank)}$
$:conv_loops(rank, 'array', 'tmp', 'to_qp')
        tmp_res = norm2(tmp, dim=dim)
$:conv_loops(rank - 1, 'tmp_res', 'res', 'from_qp')
    end function
#:endif

