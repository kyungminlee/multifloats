        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        real(qp) :: tmp(size(array))
        integer :: i1
$:conv_loops(1, 'array', 'tmp', 'to_qp')
        if (present(mask)) then
            res = from_qp(${func}$(tmp, dim=dim, mask=mask))
        else
            res = from_qp(${func}$(tmp, dim=dim))
        end if
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
