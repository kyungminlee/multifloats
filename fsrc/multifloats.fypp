#:endfor
#:endfor
    ! ================================================================
    ! dot_product (pure)
    ! ================================================================

    pure function mf_dot_product(a, b) result(res)
        type(float64x2), intent(in) :: a(:), b(:)
        type(float64x2) :: res
        ! Fused multiply-accumulate with periodic renormalization.
        ! Every MF_FMA_RENORM_INTERVAL iterations (default 8) we
        ! fast_two_sum the accumulator to keep s_lo bounded. Set the
        ! interval to 0 to renormalize only at the end.
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: k, ri
        ri = MF_FMA_RENORM_INTERVAL
        s_hi = 0.0_dp
        s_lo = 0.0_dp
        do k = 1, size(a)
            ah = a(k)%limbs(1); al = a(k)%limbs(2)
            bh = b(k)%limbs(1); bl = b(k)%limbs(2)
            p = ah * bh
            e = c_fma(ah, bh, -p)
            cross = ah * bl + al * bh
            t = s_hi + p
            bp = t - s_hi; ap = t - bp
            aerr = s_hi - ap; berr = p - bp
            s_lo = s_lo + (e + cross + aerr + berr)
            s_hi = t
            if (ri > 0 .and. mod(k, ri) == 0) then
                t = s_hi + s_lo; bp = t - s_hi
                s_hi = t; s_lo = s_lo - bp
            end if
        end do
        t = s_hi + s_lo
        bp = t - s_hi
        res%limbs(1) = t
        res%limbs(2) = s_lo - bp
    end function

    pure function cx_dot_product(a, b) result(res)
        type(complex128x2), intent(in) :: a(:), b(:)
        type(complex128x2) :: res
        type(float64x2) :: zero
        integer :: i1
        zero = mf_from_dp(0.0_dp)
        res%re = zero
        res%im = zero
        ! Standard Fortran dot_product conjugates the first argument.
        do i1 = 1, size(a)
            res = res + cx_conjg(a(i1)) * b(i1)
        end do
    end function

    ! ================================================================
    ! norm2 (pure) — rank 1-7, NO mask per standard
    ! ================================================================

#:for rank in range(1, MAX_RANK+1)
    pure function mf_norm2_${rank}$d(array) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2) :: res
        type(float64x2) :: s
        integer :: ${IVARS(rank)}$
        s = mf_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            s = s + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
        res = mf_sqrt(s)
    end function

#:if rank > 1
    pure function mf_norm2_${rank}$d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                cur = mf_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    cur = cur + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = mf_sqrt(cur)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ================================================================
    ! findloc (pure) — rank 1-7 (mf + cx)
    ! ================================================================

#:for rank in range(1, MAX_RANK+1)
    ! mf findloc rank ${rank}$
    pure function mf_findloc_${rank}$d(array, value, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = mf_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = mf_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = mf_findloc_1d(array, value, back=back)
        else
            r1 = mf_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function mf_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

    ! cx findloc rank ${rank}$
    pure function cx_findloc_${rank}$d(array, value, mask, back) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        type(complex128x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function cx_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(complex128x2), intent(in) :: array(:)
        type(complex128x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = cx_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = cx_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = cx_findloc_1d(array, value, back=back)
        else
            r1 = cx_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function cx_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        type(complex128x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ================================================================
    ! matmul (pure) — mf + cx
    ! ================================================================

    ! mf matmul: 2D × 2D → 2D
    pure function mf_matmul_mm(a, b) result(res)
        type(float64x2), intent(in) :: a(:,:), b(:,:)
        type(float64x2) :: res(size(a,1), size(b,2))
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: i1, i2, k, n, ri
        ri = MF_FMA_RENORM_INTERVAL
        n = size(a, 2)
        do i2 = 1, size(b,2)
            do i1 = 1, size(a,1)
                s_hi = 0.0_dp; s_lo = 0.0_dp
                do k = 1, n
                    ah = a(i1,k)%limbs(1); al = a(i1,k)%limbs(2)
                    bh = b(k,i2)%limbs(1); bl = b(k,i2)%limbs(2)
                    p = ah * bh
                    e = c_fma(ah, bh, -p)
                    cross = ah * bl + al * bh
                    t = s_hi + p
                    bp = t - s_hi; ap = t - bp
                    aerr = s_hi - ap; berr = p - bp
                    s_lo = s_lo + (e + cross + aerr + berr)
                    s_hi = t
                    if (ri > 0 .and. mod(k, ri) == 0) then
                        t = s_hi + s_lo; bp = t - s_hi
                        s_hi = t; s_lo = s_lo - bp
                    end if
                end do
                t = s_hi + s_lo; bp = t - s_hi
                res(i1,i2)%limbs(1) = t
                res(i1,i2)%limbs(2) = s_lo - bp
            end do
        end do
    end function

    ! mf matmul: 2D × 1D → 1D
    pure function mf_matmul_mv(a, b) result(res)
        type(float64x2), intent(in) :: a(:,:), b(:)
        type(float64x2) :: res(size(a,1))
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: i1, k, n, ri
        ri = MF_FMA_RENORM_INTERVAL
        n = size(a, 2)
        do i1 = 1, size(a,1)
            s_hi = 0.0_dp; s_lo = 0.0_dp
            do k = 1, n
                ah = a(i1,k)%limbs(1); al = a(i1,k)%limbs(2)
                bh = b(k)%limbs(1);    bl = b(k)%limbs(2)
                p = ah * bh
                e = c_fma(ah, bh, -p)
                cross = ah * bl + al * bh
                t = s_hi + p
                bp = t - s_hi; ap = t - bp
                aerr = s_hi - ap; berr = p - bp
                s_lo = s_lo + (e + cross + aerr + berr)
                s_hi = t
                if (ri > 0 .and. mod(k, ri) == 0) then
                    t = s_hi + s_lo; bp = t - s_hi
                    s_hi = t; s_lo = s_lo - bp
                end if
            end do
            t = s_hi + s_lo; bp = t - s_hi
            res(i1)%limbs(1) = t
            res(i1)%limbs(2) = s_lo - bp
        end do
    end function

    ! mf matmul: 1D × 2D → 1D
    pure function mf_matmul_vm(a, b) result(res)
        type(float64x2), intent(in) :: a(:), b(:,:)
        type(float64x2) :: res(size(b,2))
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: i2, k, n, ri
        ri = MF_FMA_RENORM_INTERVAL
        n = size(a)
        do i2 = 1, size(b,2)
            s_hi = 0.0_dp; s_lo = 0.0_dp
            do k = 1, n
                ah = a(k)%limbs(1);    al = a(k)%limbs(2)
                bh = b(k,i2)%limbs(1); bl = b(k,i2)%limbs(2)
                p = ah * bh
                e = c_fma(ah, bh, -p)
                cross = ah * bl + al * bh
                t = s_hi + p
                bp = t - s_hi; ap = t - bp
                aerr = s_hi - ap; berr = p - bp
                s_lo = s_lo + (e + cross + aerr + berr)
                s_hi = t
                if (ri > 0 .and. mod(k, ri) == 0) then
                    t = s_hi + s_lo; bp = t - s_hi
                    s_hi = t; s_lo = s_lo - bp
                end if
            end do
            t = s_hi + s_lo; bp = t - s_hi
            res(i2)%limbs(1) = t
            res(i2)%limbs(2) = s_lo - bp
        end do
    end function

    ! cx matmul: 2D × 2D → 2D
    pure function cx_matmul_mm(a, b) result(res)
        type(complex128x2), intent(in) :: a(:,:), b(:,:)
        type(complex128x2) :: res(size(a,1), size(b,2))
        type(complex128x2) :: s
        type(float64x2) :: zero
        integer :: i1, i2, k
        zero = mf_from_dp(0.0_dp)
        do i2 = 1, size(b,2)
            do i1 = 1, size(a,1)
                s%re = zero
                s%im = zero
                do k = 1, size(a,2)
                    s = s + a(i1,k) * b(k,i2)
                end do
                res(i1,i2) = s
            end do
        end do
    end function

    ! cx matmul: 2D × 1D → 1D
    pure function cx_matmul_mv(a, b) result(res)
        type(complex128x2), intent(in) :: a(:,:), b(:)
        type(complex128x2) :: res(size(a,1))
        type(complex128x2) :: s
        type(float64x2) :: zero
        integer :: i1, k
        zero = mf_from_dp(0.0_dp)
        do i1 = 1, size(a,1)
            s%re = zero
            s%im = zero
            do k = 1, size(a,2)
                s = s + a(i1,k) * b(k)
            end do
            res(i1) = s
        end do
    end function

    ! cx matmul: 1D × 2D → 1D
    pure function cx_matmul_vm(a, b) result(res)
        type(complex128x2), intent(in) :: a(:), b(:,:)
        type(complex128x2) :: res(size(b,2))
        type(complex128x2) :: s
        type(float64x2) :: zero
        integer :: i2, k
        zero = mf_from_dp(0.0_dp)
        do i2 = 1, size(b,2)
            s%re = zero
            s%im = zero
            do k = 1, size(a)
                s = s + a(k) * b(k,i2)
            end do
            res(i2) = s
        end do
    end function

    ! ================================================================
    ! Configuration
    ! ================================================================

    subroutine mf_set_fma_renorm_interval(n)
        integer, intent(in) :: n
        MF_FMA_RENORM_INTERVAL = n
    end subroutine

    ! ================================================================
    ! random_number (impure subroutine)
    ! ================================================================

    subroutine mf_random_number_0d(harvest)
        type(float64x2), intent(out) :: harvest
        real(dp) :: hi, lo, s, b
        call random_number(hi)
        call random_number(lo)
        ! Pack two independent dp randoms into a DD: hi gets ~53 bits in [0,1),
        ! lo contributes ~53 more bits below hi's ulp.
        lo = lo * 2.0_dp**(-53)
        s = hi + lo
        b = s - hi
        harvest%limbs(1) = s
        harvest%limbs(2) = lo - b
    end subroutine

#:for rank in range(1, MAX_RANK+1)
    subroutine mf_random_number_${rank}$d(harvest)
        type(float64x2), intent(out) :: harvest(${COLONS(rank)}$)
        real(dp) :: hi(${SIZES(rank, 'harvest')}$), lo(${SIZES(rank, 'harvest')}$)
        real(dp) :: s, b
        integer :: ${IVARS(rank)}$
        call random_number(hi)
        call random_number(lo)
        lo = lo * 2.0_dp**(-53)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(harvest, ${d}$)
#:endfor
            s = hi(${IDXS(rank)}$) + lo(${IDXS(rank)}$)
            b = s - hi(${IDXS(rank)}$)
            harvest(${IDXS(rank)}$)%limbs(1) = s
            harvest(${IDXS(rank)}$)%limbs(2) = lo(${IDXS(rank)}$) - b
#:for d in range(rank)
        end do
#:endfor
    end subroutine

#:endfor
    ! ================================================================
    ! Binary arithmetic (+, -, *, /) — elemental
    ! ================================================================

#:for opsym, opname in ARITH_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex128x2)' if rc else 'type(float64x2)'}$ :: res
#:if not rc
        ! Hot fast path uses scalar dp locals (no float64x2 copies, no
        ! generic mf_from_dp call). The single non-finite guard runs
        ! after the leading-limb op so a single test catches every IEEE
        ! special case.
        real(dp) :: x0, x1, y0, y1
        real(dp) :: s, e, t, aprime, bprime, aerr, berr
        real(dp) :: p00, e00, p01, p10, c, d
        real(dp) :: ux, uy, q0, q1_lo, r0, r1, q_y0, q_y1
#:if n1 == 'mf'
        x0 = a%limbs(1)
        x1 = a%limbs(2)
#:elif n1 == 'sp' or n1 == 'int'
        x0 = real(a, dp)
        x1 = 0.0_dp
#:else
        x0 = a
        x1 = 0.0_dp
#:endif
#:if n2 == 'mf'
        y0 = b%limbs(1)
        y1 = b%limbs(2)
#:elif n2 == 'sp' or n2 == 'int'
        y0 = real(b, dp)
        y1 = 0.0_dp
#:else
        y0 = b
        y1 = 0.0_dp
#:endif
#:if opname == 'sub'
        y0 = -y0
        y1 = -y1
#:endif
#:if opname == 'add' or opname == 'sub'
        s = x0 + y0
        if (.not. ieee_is_finite(s)) then
            ! Any non-finite input or overflow makes s non-finite. The
            ! EFT below would propagate NaN to limbs(2); short-circuit
            ! and let IEEE produce the correct leading limb.
            res%limbs(1) = s
            res%limbs(2) = 0.0_dp
            return
        end if
        ! When both hi limbs are zero, the two_sum EFT produces a
        ! spurious +0 from mixed-sign zero arithmetic (IEEE 754:
        ! -0 + +0 = +0 in round-to-nearest). Short-circuit so the
        ! correct IEEE sign of s is preserved.
        if (x0 == 0.0_dp .and. y0 == 0.0_dp) then
            res%limbs(1) = s
            res%limbs(2) = x1 + y1
            return
        end if
        aprime = s - y0
        bprime = s - aprime
        aerr = x0 - aprime
        berr = y0 - bprime
        e = aerr + berr
        c = x1 + y1
        aprime = c - y1
        bprime = c - aprime
        aerr = x1 - aprime
        berr = y1 - bprime
        d = aerr + berr
        t = s + c
        bprime = t - s
        c = c - bprime
        e = e + d + c
        res%limbs(1) = t + e
        bprime = res%limbs(1) - t
        res%limbs(2) = e - bprime
#:elif opname == 'mul'
        p00 = x0 * y0
        if (.not. ieee_is_finite(p00)) then
            ! Any non-finite input, 0*inf, or overflow lands here in one
            ! test (no separate ieee_is_finite on x0/y0).
            res%limbs(1) = p00
            res%limbs(2) = 0.0_dp
            return
        end if
        e00 = c_fma(x0, y0, -p00)
        p01 = x0 * y1
        p10 = x1 * y0
        e00 = e00 + (p01 + p10)
        res%limbs(1) = p00 + e00
        bprime = res%limbs(1) - p00
        res%limbs(2) = e00 - bprime
#:else
        ! Newton-refined DD division. The first guard tests the leading
        ! quotient s; if it is non-finite, every IEEE edge case (y=0,
        ! 0/0, inf/finite, NaN) collapses to the same path. The second
        ! guard catches finite/inf (s=0 but refinement hits 0*inf=NaN).
        s = x0 / y0
        if (.not. ieee_is_finite(s)) then
            res%limbs(1) = s
            res%limbs(2) = 0.0_dp
            return
        end if
        if (.not. ieee_is_finite(y0)) then
            ! y is ±inf: quotient is ±0 (already in s). The Newton
            ! refinement would compute 0*inf = NaN; short-circuit.
            res%limbs(1) = s
            res%limbs(2) = 0.0_dp
            return
        end if
        ux = 1.0_dp / y0
        p00 = x0 * ux
        e00 = c_fma(x0, ux, -p00) + x1 * ux
        q0 = p00 + e00
        bprime = q0 - p00
        q1_lo = e00 - bprime
        p00 = q0 * y0
        e00 = c_fma(q0, y0, -p00) + q0 * y1 + q1_lo * y0
        q_y0 = p00 + e00
        bprime = q_y0 - p00
        q_y1 = e00 - bprime
        ! residual = q*y - x; final step is q - residual * (1/y0).
        ! Inline the (q*y - x) DD subtract since we already have x0/x1.
        s = q_y0 + (-x0)
        aprime = s - (-x0)
        bprime = s - aprime
        aerr = q_y0 - aprime
        berr = (-x0) - bprime
        e = aerr + berr
        c = q_y1 + (-x1)
        t = s + c
        bprime = t - s
        c = c - bprime
        e = e + c
        r0 = t + e
        bprime = r0 - t
        r1 = e - bprime
        ! correction = residual * u  (u ≈ 1/y0, single dp value)
        p00 = r0 * ux
        e00 = c_fma(r0, ux, -p00) + r1 * ux
        ! res = q - correction
        s = q0 + (-p00)
        aprime = s - (-p00)
        bprime = s - aprime
        aerr = q0 - aprime
        berr = (-p00) - bprime
        e = aerr + berr
        c = q1_lo + (-e00)
        t = s + c
        bprime = t - s
        c = c - bprime
        e = e + c
        res%limbs(1) = t + e
        bprime = res%limbs(1) - t
        res%limbs(2) = e - bprime
#:endif
#:else
        ! Complex result: use native DD complex arithmetic. Lift any
        ! non-complex operand to a complex128x2 via the assignment overloads
        ! and then do the operation in (a.re, a.im) form.
        block
            type(complex128x2) :: ca, cb
            type(float64x2) :: denom
            ca = a
            cb = b
#:if opname == 'add'
            res%re = ca%re + cb%re
            res%im = ca%im + cb%im
#:elif opname == 'sub'
            res%re = ca%re - cb%re
            res%im = ca%im - cb%im
#:elif opname == 'mul'
            res%re = ca%re * cb%re - ca%im * cb%im
            res%im = ca%re * cb%im + ca%im * cb%re
#:else
            denom = cb%re * cb%re + cb%im * cb%im
            res%re = (ca%re * cb%re + ca%im * cb%im) / denom
            res%im = (ca%im * cb%re - ca%re * cb%im) / denom
#:endif
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ================================================================
    ! Power operator (**) — elemental
    ! ================================================================

#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    elemental function ${n1}$_pow_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex128x2)' if rc else 'type(float64x2)'}$ :: res
#:if n2 == 'int'
#:if rc
        ! Integer-power on a complex base via repeated multiplication.
        block
            type(complex128x2) :: base
            integer :: k, n
            base = a
            res%re = MF_ONE
            res%im%limbs = [0.0_dp, 0.0_dp]
            n = abs(b)
            do k = 1, n
                res = res * base
            end do
            if (b < 0) then
                res = complex128x2(MF_ONE, mf_from_dp(0.0_dp)) / res
            end if
        end block
#:else
        ! Integer-power on a real base via repeated multiplication.
        block
            type(float64x2) :: base
            integer :: k, n
            base = a
            res = MF_ONE
            n = abs(b)
            do k = 1, n
                res = res * base
            end do
            if (b < 0) res = MF_ONE / res
        end block
#:endif
#:elif rc
        ! General complex power: a^b = exp(b * log(a))
        block
            type(complex128x2) :: ca, cb
            ca = a
            cb = b
            res = cx_exp(cb * cx_log(ca))
        end block
#:else
        ! General real power: a^b = exp(b * log(a))
        block
            type(float64x2) :: x, y
            x = a
            y = b
            res = mf_exp(y * mf_log(x))
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
    ! ================================================================
    ! Equality comparison (==, /=) — elemental
    ! ================================================================

#:for opsym, opname in EQ_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
#:if not ISCPLX[n1] and not ISCPLX[n2]
        type(float64x2) :: x, y
        x = ${MFCONV[n1].format('a')}$
        y = ${MFCONV[n2].format('b')}$
#:if opname == 'eq'
        res = x%limbs(1) == y%limbs(1) .and. x%limbs(2) == y%limbs(2)
#:else
        res = x%limbs(1) /= y%limbs(1) .or. x%limbs(2) /= y%limbs(2)
#:endif
#:else
        ! Complex (in)equality: compare real and imaginary parts in native DD.
        block
            type(complex128x2) :: ca, cb
            ca = a
            cb = b
#:if opname == 'eq'
            res = (ca%re == cb%re) .and. (ca%im == cb%im)
#:else
            res = (ca%re /= cb%re) .or. (ca%im /= cb%im)
#:endif
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ================================================================
    ! Ordered comparison (<, >, <=, >=) — elemental
    ! ================================================================

#:for opsym, opname in ORD_OPS
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
        type(float64x2) :: x, y
        x = ${MFCONV[n1].format('a')}$
        y = ${MFCONV[n2].format('b')}$
#:if opname == 'lt'
        res = x%limbs(1) < y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) < y%limbs(2))
#:elif opname == 'gt'
        res = x%limbs(1) > y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) > y%limbs(2))
#:elif opname == 'le'
        res = x%limbs(1) < y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) <= y%limbs(2))
#:else
        res = x%limbs(1) > y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) >= y%limbs(2))
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ================================================================
    ! Defined I/O
    ! ================================================================

    subroutine write_mf_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(float64x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        real(qp) :: val_qp
        val_qp = to_qp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        else
            write(unit, '(ES23.16,1X,ES23.16)', iostat=iostat, iomsg=iomsg) &
                dtv%limbs(1), dtv%limbs(2)
        end if
#:endif
    end subroutine

    subroutine write_cx_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(complex128x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        complex(qp) :: val_cqp
        val_cqp = to_cqp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        else
            write(unit, '(4(ES23.16,1X))', iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        end if
#:endif
    end subroutine

    subroutine read_mf_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(float64x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        real(qp) :: val_qp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
        if (iostat == 0) then
            dtv%limbs(1) = real(val_qp, dp)
            dtv%limbs(2) = real(val_qp - real(dtv%limbs(1), qp), dp)
        end if
#:else
        ! Without quad, read both limbs as doubles.
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        end if
#:endif
    end subroutine

    subroutine read_cx_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(complex128x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        complex(qp) :: val_cqp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
        if (iostat == 0) then
            dtv%re%limbs(1) = real(real(val_cqp, qp), dp)
            dtv%re%limbs(2) = real(real(val_cqp, qp) - real(dtv%re%limbs(1), qp), dp)
            dtv%im%limbs(1) = real(aimag(val_cqp), dp)
            dtv%im%limbs(2) = real(aimag(val_cqp) - real(dtv%im%limbs(1), qp), dp)
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        end if
#:endif
    end subroutine

end module multifloats
