        end select
    end function
#:endif

    ! cx ${func}$ rank ${rank}$
    pure function cx_${func}$_${rank}$d(array, mask) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex128x2) :: res
        type(float64x2) :: zero, one
