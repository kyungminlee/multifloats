        one = mf_from_dp(1.0_dp)
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
