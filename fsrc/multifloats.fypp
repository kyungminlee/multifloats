        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex128x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(complex128x2) :: cur
        type(float64x2) :: zero, one
        integer :: ${IVARS(rank)}$
