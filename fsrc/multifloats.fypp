contains

    ! ================================================================
    ! Internal conversion helpers (elemental)
    ! ================================================================

    elemental function to_qp(mf) result(res)
        type(float64x2), intent(in) :: mf
        real(qp) :: res
        res = real(mf%limbs(1), qp) + real(mf%limbs(2), qp)
    end function

    elemental function from_qp(v) result(res)
        real(qp), intent(in) :: v
        type(float64x2) :: res
        real(dp) :: s, bprime
        if (.not. ieee_is_finite(v)) then
            ! Non-finite values are represented with the leading limb only;
            ! the lo limb is conventionally zero so callers don't see Inf/NaN
            ! arithmetic propagating into it.
            res%limbs = [real(v, dp), 0.0_dp]
        else
            res%limbs(1) = real(v, dp)
            res%limbs(2) = real(v - real(res%limbs(1), qp), dp)
            s = res%limbs(1) + res%limbs(2)
            bprime = s - res%limbs(1)
            res%limbs(2) = res%limbs(2) - bprime
            res%limbs(1) = s
        end if
    end function

    elemental function to_cqp(cx) result(res)
        type(complex128x2), intent(in) :: cx
        complex(qp) :: res
        res = cmplx(to_qp(cx%re), to_qp(cx%im), kind=qp)
    end function

    elemental function from_cqp(v) result(res)
        complex(qp), intent(in) :: v
        type(complex128x2) :: res
        res%re = from_qp(real(v, qp))
        res%im = from_qp(aimag(v))
    end function

    ! ================================================================
    ! Constructors
    ! ================================================================

    elemental function mf_from_mf(v) result(res)
        type(float64x2), intent(in) :: v
        type(float64x2) :: res
        res = v
    end function

    elemental function mf_from_dp(v) result(res)
        real(dp), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [v, 0.0_dp]
    end function

    elemental function mf_from_sp(v) result(res)
        real(sp), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_int(v) result(res)
        integer, intent(in) :: v
        type(float64x2) :: res
        ! Default integer kind is 32-bit and fits exactly in dp.
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_i8(v) result(res)
        integer(int8), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_i16(v) result(res)
        integer(int16), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_i64(v) result(res)
        integer(int64), intent(in) :: v
        type(float64x2) :: res
        ! int64 → dp may lose the bottom 11 bits when |v| >= 2^53.
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    function mf_from_char(v) result(res)
        character(len=*), intent(in) :: v
        type(float64x2) :: res
        real(qp) :: val_qp
        read(v, *) val_qp
        res = from_qp(val_qp)
    end function

    elemental function mf_from_cx(cx) result(res)
        type(complex128x2), intent(in) :: cx
        type(float64x2) :: res
        res = cx%re
    end function

    elemental function mf_from_cdp(x) result(res)
        complex(dp), intent(in) :: x
        type(float64x2) :: res
        res%limbs = [real(x, dp), 0.0_dp]
    end function

    elemental function mf_from_csp(x) result(res)
        complex(sp), intent(in) :: x
        type(float64x2) :: res
        res%limbs = [real(real(x, sp), dp), 0.0_dp]
    end function

    elemental function cx_from_cx(v) result(res)
        type(complex128x2), intent(in) :: v
        type(complex128x2) :: res
        res = v
    end function

    elemental function cx_from_mf_2(r, i) result(res)
        type(float64x2), intent(in) :: r, i
        type(complex128x2) :: res
        res%re = r
        res%im = i
    end function

    elemental function cx_from_dp_2(r, i) result(res)
        real(dp), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im%limbs = [i, 0.0_dp]
    end function

    elemental function cx_from_mf_1(r) result(res)
        type(float64x2), intent(in) :: r
        type(complex128x2) :: res
        res%re = r
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_dp_1(r) result(res)
        real(dp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    ! Two-argument matching-kind constructors for the remaining real /
    ! integer kinds. Each promotes both operands to dp before storing.

    elemental function cx_from_sp_2(r, i) result(res)
        real(sp), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_int_2(r, i) result(res)
        integer, intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_i8_2(r, i) result(res)
        integer(int8), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_i16_2(r, i) result(res)
        integer(int16), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_i64_2(r, i) result(res)
        integer(int64), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    ! Mixed (mf, dp) and (dp, mf) — common when one part has been
    ! computed in DD and the other is still a literal double.

    elemental function cx_from_mf_dp_2(r, i) result(res)
        type(float64x2), intent(in) :: r
        real(dp), intent(in) :: i
        type(complex128x2) :: res
        res%re = r
        res%im%limbs = [i, 0.0_dp]
    end function

    elemental function cx_from_dp_mf_2(r, i) result(res)
        real(dp), intent(in) :: r
        type(float64x2), intent(in) :: i
        type(complex128x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im = i
    end function

    ! Single-argument constructors for the remaining numeric kinds
    ! (imag set to 0).

    elemental function cx_from_sp_1(r) result(res)
        real(sp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_int_1(r) result(res)
        integer, intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_i8_1(r) result(res)
        integer(int8), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_i16_1(r) result(res)
        integer(int16), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_i64_1(r) result(res)
        integer(int64), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_cdp_1(r) result(res)
        complex(dp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [aimag(r), 0.0_dp]
    end function

    elemental function cx_from_csp_1(r) result(res)
        complex(sp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(real(r, sp), dp), 0.0_dp]
        res%im%limbs = [real(aimag(r), dp), 0.0_dp]
    end function

    ! ================================================================
    ! Assignment (elemental)
    ! ================================================================

#:for n, d in ATYPES
#:if n != 'mf'
    elemental subroutine mf_assign_${n}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if n == 'dp'
        lhs%limbs = [rhs, 0.0_dp]
#:elif n == 'sp'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'int'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'cx'
        lhs = rhs%re
#:elif n == 'cdp'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'csp'
        lhs%limbs = [real(real(rhs, sp), dp), 0.0_dp]
#:endif
    end subroutine

#:endif
#:endfor
#:for n, d in ATYPES
#:if n != 'cx'
    elemental subroutine cx_assign_${n}$(lhs, rhs)
        type(complex128x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if n == 'mf'
        lhs%re = rhs
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'dp'
        lhs%re%limbs = [rhs, 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'sp'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'int'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'cdp'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [aimag(rhs), 0.0_dp]
#:elif n == 'csp'
        lhs%re%limbs = [real(real(rhs, sp), dp), 0.0_dp]
        lhs%im%limbs = [real(aimag(rhs), dp), 0.0_dp]
#:endif
    end subroutine

#:endif
#:endfor
    ! ----------------------------------------------------------------
    ! Non-default integer kinds → mf / cx
    ! ----------------------------------------------------------------

#:for ksuf, ktype in [('i8', 'integer(int8)'), ('i16', 'integer(int16)'), ('i64', 'integer(int64)')]
    elemental subroutine mf_assign_${ksuf}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${ktype}$, intent(in) :: rhs
        lhs%limbs = [real(rhs, dp), 0.0_dp]
    end subroutine

    elemental subroutine cx_assign_${ksuf}$(lhs, rhs)
        type(complex128x2), intent(out) :: lhs
        ${ktype}$, intent(in) :: rhs
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! mf → built-in numeric types (truncation for integer kinds, mirrors
    ! the same semantics as `int_var = real_dp_var` in plain Fortran).
    ! ----------------------------------------------------------------

    elemental subroutine dp_assign_mf(lhs, rhs)
        real(dp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = rhs%limbs(1)
    end subroutine

    elemental subroutine sp_assign_mf(lhs, rhs)
        real(sp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = real(rhs%limbs(1), sp)
    end subroutine

    elemental subroutine cdp_assign_mf(lhs, rhs)
        complex(dp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = cmplx(rhs%limbs(1), 0.0_dp, dp)
    end subroutine

    elemental subroutine csp_assign_mf(lhs, rhs)
        complex(sp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = cmplx(real(rhs%limbs(1), sp), 0.0_sp, sp)
    end subroutine

#:for ksuf, ktype, klit in [('int', 'integer', 'int32'), ('i8', 'integer(int8)', 'int8'), ('i16', 'integer(int16)', 'int16'), ('i64', 'integer(int64)', 'int64')]
    elemental subroutine ${ksuf}$_assign_mf(lhs, rhs)
        ${ktype}$, intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        real(dp) :: hi
        hi = rhs%limbs(1)
        lhs = int(hi, kind(lhs))
        ! Adjust toward zero when the leading limb is exactly an integer
        ! and the lo limb pushes the true value across the boundary.
        if (hi == real(lhs, dp)) then
            if (lhs > 0 .and. rhs%limbs(2) < 0.0_dp) lhs = lhs - 1_${klit}$
            if (lhs < 0 .and. rhs%limbs(2) > 0.0_dp) lhs = lhs + 1_${klit}$
        end if
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! cx → built-in numeric types (real types take the real part;
    ! integer kinds truncate the real part toward zero).
    ! ----------------------------------------------------------------

    elemental subroutine dp_assign_cx(lhs, rhs)
        real(dp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = rhs%re%limbs(1)
    end subroutine

    elemental subroutine sp_assign_cx(lhs, rhs)
        real(sp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = real(rhs%re%limbs(1), sp)
    end subroutine

    elemental subroutine cdp_assign_cx(lhs, rhs)
        complex(dp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = cmplx(rhs%re%limbs(1), rhs%im%limbs(1), dp)
    end subroutine

    elemental subroutine csp_assign_cx(lhs, rhs)
        complex(sp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = cmplx(real(rhs%re%limbs(1), sp), real(rhs%im%limbs(1), sp), sp)
    end subroutine

#:for ksuf, ktype, klit in [('int', 'integer', 'int32'), ('i8', 'integer(int8)', 'int8'), ('i16', 'integer(int16)', 'int16'), ('i64', 'integer(int64)', 'int64')]
    elemental subroutine ${ksuf}$_assign_cx(lhs, rhs)
        ${ktype}$, intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        real(dp) :: hi
        hi = rhs%re%limbs(1)
        lhs = int(hi, kind(lhs))
        if (hi == real(lhs, dp)) then
            if (lhs > 0 .and. rhs%re%limbs(2) < 0.0_dp) lhs = lhs - 1_${klit}$
            if (lhs < 0 .and. rhs%re%limbs(2) > 0.0_dp) lhs = lhs + 1_${klit}$
        end if
    end subroutine

#:endfor
    ! ================================================================
    ! Conversions (elemental)
    ! ================================================================

    elemental function mf_dble(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        ! For a normalized DD, |lo| <= ulp(hi)/2, so the round-to-nearest
        ! double of hi+lo is exactly hi.
        res = x%limbs(1)
    end function

    elemental function mf_int(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = int(hi)
        if (hi == real(res, dp)) then
            ! hi is exactly an integer; the lo limb determines whether
            ! the true value crosses an integer boundary toward zero.
            if (res > 0 .and. x%limbs(2) < 0.0_dp) res = res - 1
            if (res < 0 .and. x%limbs(2) > 0.0_dp) res = res + 1
        end if
    end function

    elemental function mf_nint(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        ! For all values where the closest integer is unambiguous, the
        ! leading limb suffices: |lo| <= ulp(hi)/2 < 1/2.
        res = nint(x%limbs(1))
    end function

    elemental function mf_to_double(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        res = x%limbs(1)
    end function

    elemental function mf_ceiling(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = ceiling(hi)
        if (hi == real(res, dp) .and. x%limbs(2) > 0.0_dp) res = res + 1
    end function

    elemental function mf_floor(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = floor(hi)
        if (hi == real(res, dp) .and. x%limbs(2) < 0.0_dp) res = res - 1
    end function

    elemental function mf_exponent(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = exponent(x%limbs(1))
    end function

    ! ================================================================
    ! Unary operators (elemental)
    ! ================================================================

    elemental function mf_neg(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res%limbs = -x%limbs
    end function

    elemental function cx_neg(x) result(res)
        type(complex128x2), intent(in) :: x
        type(complex128x2) :: res
        res%re%limbs = -x%re%limbs
        res%im%limbs = -x%im%limbs
    end function

    ! ================================================================
    ! Full-DD exp / log kernels (ported from MultiFloats.jl)
    ! ================================================================

    ! Horner polynomial evaluation in DD. coefs(1) is the constant term.
    pure function dd_horner(y, coefs_hi, coefs_lo) result(p)
        type(float64x2), intent(in) :: y
        real(dp), intent(in) :: coefs_hi(:), coefs_lo(:)
        type(float64x2) :: p, c
        integer :: i, n
        n = size(coefs_hi)
        p%limbs = [coefs_hi(n), coefs_lo(n)]
        do i = n - 1, 1, -1
            p = p * y
            c%limbs = [coefs_hi(i), coefs_lo(i)]
            p = p + c
        end do
    end function

    ! neval: P[n]*x^n + ... + P[0] (Horner, highest degree first in array)
    pure function dd_neval(x, chi, clo) result(p)
        type(float64x2), intent(in) :: x
        real(dp), intent(in) :: chi(:), clo(:)
        type(float64x2) :: p, c
        integer :: i, n
        n = size(chi)
        p%limbs = [chi(n), clo(n)]
        do i = n - 1, 1, -1
            p = p * x
            c%limbs = [chi(i), clo(i)]
            p = p + c
        end do
    end function

    ! deval: x^(n+1) + P[n]*x^n + ... + P[0] (monic Horner)
    pure function dd_deval(x, chi, clo) result(p)
        type(float64x2), intent(in) :: x
        real(dp), intent(in) :: chi(:), clo(:)
        type(float64x2) :: p, c
        integer :: i, n
        n = size(chi)
        c%limbs = [chi(n), clo(n)]
        p = x + c
        do i = n - 1, 1, -1
            p = p * x
            c%limbs = [chi(i), clo(i)]
            p = p + c
        end do
    end function

    ! exp2 kernel: x is in [-exp2_max, +exp2_max]. Returns 2^x as DD.
    pure function dd_exp2_kernel(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, y, neg_n_dd, p
        real(dp) :: n_float
        integer :: n, half_n
        ! Range reduction: n = nearest integer to x.hi, y = (x - n) / 8.
        n_float = anint(x%limbs(1))
        neg_n_dd%limbs = [-n_float, 0.0_dp]
        y = x + neg_n_dd
        y%limbs(1) = scale(y%limbs(1), -3)  ! exact divide by 8
        y%limbs(2) = scale(y%limbs(2), -3)
        ! Polynomial in y, then cube via three squarings to undo the / 8.
        p = dd_horner(y, exp2_coefs_hi, exp2_coefs_lo)
        p = p * p
        p = p * p
        p = p * p
        ! Multiply by 2^n via two ldexps split to keep intermediates in
        ! the dp normal range when |n| is near 1024.
        n = nint(n_float)
        half_n = n / 2
        res%limbs(1) = scale(p%limbs(1), half_n)
        res%limbs(2) = scale(p%limbs(2), half_n)
        res%limbs(1) = scale(res%limbs(1), n - half_n)
        res%limbs(2) = scale(res%limbs(2), n - half_n)
    end function

    ! Public-facing exp2 with input clamping for over- / underflow.
    elemental function dd_exp2_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        if (.not. ieee_is_finite(x%limbs(1))) then
            ! exp2(NaN) = NaN; exp2(+inf) = +inf; exp2(-inf) = +0.
            if (x%limbs(1) > 0.0_dp) then
                res%limbs = [x%limbs(1), 0.0_dp]      ! +inf
            else if (x%limbs(1) < 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                res%limbs = [x%limbs(1), 0.0_dp]      ! NaN
            end if
        else if (x%limbs(1) < exp2_min) then
            res%limbs = [0.0_dp, 0.0_dp]
        else if (x%limbs(1) > exp2_max) then
            res%limbs = [huge(0.0_dp), 0.0_dp]
        else
            res = dd_exp2_kernel(x)
        end if
    end function

    ! exp(x) = exp2(x * log2(e))
    elemental function dd_exp_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, l2e
        l2e%limbs = [log2_e_hi, log2_e_lo]
        res = dd_exp2_full(x * l2e)
    end function

    ! log2 kernel for x > 0 finite. Implements both the direct branch
    ! (x near 1) and the table-lookup branch (general x).
    pure function dd_log2_kernel(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, t, t_sq, p, m, c, v, e_dd, num, den
        real(dp) :: hi
        integer :: e, idx
        hi = x%limbs(1)
        if (hi > 15.0_dp / 16.0_dp .and. hi < 17.0_dp / 16.0_dp) then
            ! Direct path: t = (x - 1) / (x + 1).
            num = x - MF_ONE
            den = x + MF_ONE
            t = num / den
            t_sq = t * t
            p = dd_horner(t_sq, log2_wide_hi, log2_wide_lo)
            res = t * p
        else
            ! Table path: extract the binary exponent and the high 5
            ! mantissa bits, then look up log2 of the bin center.
            ! Fortran's exponent() puts the implicit fraction in [0.5,1)
            ! whereas Julia / IEEE put it in [1,2); subtract one so the
            ! reduced mantissa lands in [1, 2) as the table expects.
            e = exponent(hi) - 1
            m%limbs(1) = scale(x%limbs(1), -e)  ! m in [1, 2)
            m%limbs(2) = scale(x%limbs(2), -e)
            ! Index from the top 5 bits of (m - 1) * 32, clamped to 0..31.
            idx = int((m%limbs(1) - 1.0_dp) * 32.0_dp)
            if (idx < 0)  idx = 0
            if (idx > 31) idx = 31
            c%limbs = [log2_centers(idx + 1), 0.0_dp]
            v%limbs = [log2_values_hi(idx + 1), log2_values_lo(idx + 1)]
            num = m - c
            den = m + c
            t = num / den
            t_sq = t * t
            p = dd_horner(t_sq, log2_narrow_hi, log2_narrow_lo)
            e_dd%limbs = [real(e, dp), 0.0_dp]
            res = e_dd + v + t * p
        end if
    end function

    ! log2 with special-case handling for 0, negative, inf, NaN.
    elemental function dd_log2_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        if (ieee_is_nan(x%limbs(1)) .or. x%limbs(1) < 0.0_dp) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
        else if (x%limbs(1) == 0.0_dp) then
            res%limbs = [-huge(0.0_dp), 0.0_dp]
        else if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [huge(0.0_dp), 0.0_dp]
        else
            res = dd_log2_kernel(x)
        end if
    end function

    elemental function dd_log_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, l2, ln2
        if (.not. ieee_is_finite(x%limbs(1))) then
            ! NaN propagates; +inf → +inf; -inf → NaN (caught below).
            res%limbs = [log(x%limbs(1)), 0.0_dp]
            return
        end if
        l2 = dd_log2_full(x)
        ln2%limbs = [ln_2_hi, ln_2_lo]
        res = l2 * ln2
    end function

    elemental function dd_log10_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, l2, l102
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [log10(x%limbs(1)), 0.0_dp]
            return
        end if
        l2 = dd_log2_full(x)
        l102%limbs = [log10_2_hi, log10_2_lo]
        res = l2 * l102
    end function

    ! sinpi(x) = sin(pi * x) computed via the polynomial in x², ported
    ! from MultiFloats.jl. x must already be in [0, 0.5].
    pure function dd_sinpi_kernel(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, x_sq
        x_sq = x * x
        res = dd_horner(x_sq, sinpi_coefs_hi, sinpi_coefs_lo)
        res = res * x
    end function

    pure function dd_cospi_kernel(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, x_sq
        x_sq = x * x
        res = dd_horner(x_sq, cospi_coefs_hi, cospi_coefs_lo)
    end function

    ! sinpi: reduce x to [-0.5, 0.5] using the period of sinpi (period 2),
    ! then dispatch to sinpi_kernel / cospi_kernel based on the quadrant.
    elemental function dd_sinpi_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, rx, neg_half_n
        real(dp) :: n_float
        integer :: n_mod
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        ! abs(x); the final sign flip is applied at the end.
        if (x%limbs(1) < 0.0_dp) then
            ax%limbs = -x%limbs
        else
            ax = x
        end if
        ! Reduce to [0, 0.5]: pick the nearest half-integer.
        n_float = anint(2.0_dp * ax%limbs(1))
        neg_half_n%limbs = [-0.5_dp * n_float, 0.0_dp]
        rx = ax + neg_half_n
        n_mod = iand(int(n_float, int64), 3_int64)
        select case (n_mod)
        case (0)
            res = dd_sinpi_kernel(rx)
        case (1)
            res = dd_cospi_kernel(rx)
        case (2)
            res = dd_sinpi_kernel(rx)
            res%limbs = -res%limbs
        case default
            res = dd_cospi_kernel(rx)
            res%limbs = -res%limbs
        end select
        if (x%limbs(1) < 0.0_dp) res%limbs = -res%limbs
    end function

    elemental function dd_cospi_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, rx, neg_half_n
        real(dp) :: n_float
        integer :: n_mod
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        if (x%limbs(1) < 0.0_dp) then
            ax%limbs = -x%limbs
        else
            ax = x
        end if
        n_float = anint(2.0_dp * ax%limbs(1))
        neg_half_n%limbs = [-0.5_dp * n_float, 0.0_dp]
        rx = ax + neg_half_n
        n_mod = iand(int(n_float, int64), 3_int64)
        select case (n_mod)
        case (0)
            res = dd_cospi_kernel(rx)
        case (1)
            res = dd_sinpi_kernel(rx)
            res%limbs = -res%limbs
        case (2)
            res = dd_cospi_kernel(rx)
            res%limbs = -res%limbs
        case default
            res = dd_sinpi_kernel(rx)
        end select
    end function

    ! 3-part Cody-Waite range reduction: compute r = x - n*(π/2) using
    ! the 3-part π/2 constant (~161 bits). n is the nearest integer to
    ! x/(π/2), computed via dp. Each subtraction step uses DD - dp
    ! (exact via two_sum when |n*pi_half_cw*| < 2^53).
    ! Returns (r, n_mod4) where r is the DD reduced argument and
    ! n_mod4 is n mod 4 for quadrant dispatch.
    elemental subroutine dd_reduce_pi_half(x, r, n_mod4)
        type(float64x2), intent(in) :: x
        type(float64x2), intent(out) :: r
        integer, intent(out) :: n_mod4
        real(dp) :: n_float, p, s, bp, ap, aerr, berr, rh, rl
        ! n = nearest integer to x / (π/2)
        n_float = anint(x%limbs(1) * 0.6366197723675814_dp)  ! 2/π
        ! r = x - n*(π/2) using 3-part Cody-Waite with DD arithmetic.
        ! Each n*pi_half_cwK is computed exactly as a DD via FMA, then
        ! subtracted from r using full DD subtraction. This preserves
        ! ~106 bits throughout (vs dp accumulation which loses ~36 bits).
        block
            type(float64x2) :: npi
            r = x
            ! Step 1: r -= n * pi_half_cw1 (exact DD product via FMA)
            npi%limbs(1) = n_float * pi_half_cw1
            npi%limbs(2) = ieee_fma(n_float, pi_half_cw1, -npi%limbs(1))
            r = r - npi
            ! Step 2: r -= n * pi_half_cw2
            npi%limbs(1) = n_float * pi_half_cw2
            npi%limbs(2) = ieee_fma(n_float, pi_half_cw2, -npi%limbs(1))
            r = r - npi
            ! Step 3: r -= n * pi_half_cw3 (single dp, error is ~1e-50)
            npi%limbs(1) = n_float * pi_half_cw3
            npi%limbs(2) = 0.0_dp
            r = r - npi
        end block
        n_mod4 = iand(int(abs(n_float), int64), 3_int64)
        if (n_float < 0.0_dp) n_mod4 = iand(4_int64 - int(n_mod4, int64), 3_int64)
    end subroutine

    ! sin/cos kernel: evaluate the Taylor polynomial directly in x (not
    ! in x/π), using the Horner scheme on the DD coefficients. These
    ! compute sin(x)/x and cos(x) for |x| <= π/4.
    pure function dd_sin_kernel(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, x_sq
        x_sq = x * x
        res = dd_horner(x_sq, sin_taylor_hi, sin_taylor_lo)
        res = res * x
    end function

    pure function dd_cos_kernel(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, x_sq
        x_sq = x * x
        res = dd_horner(x_sq, cos_taylor_hi, cos_taylor_lo)
    end function

    ! Evaluate sin(r) for |r| ≤ π/4. If |r| > π/8, shift by π/4 and use
    ! the angle-addition identity to halve the polynomial argument range.
    elemental function dd_sin_eval(r) result(res)
        type(float64x2), intent(in) :: r
        type(float64x2) :: res, rp, sk, ck, inv_sqrt2
        real(dp), parameter :: pi8 = 0.392699081698724_dp
        if (abs(r%limbs(1)) <= pi8) then
            res = dd_sin_kernel(r)
        else
            inv_sqrt2%limbs = [0.7071067811865476_dp, -4.833646656726457e-17_dp]
            block
                type(float64x2) :: pi4_dd
                pi4_dd%limbs = [0.7853981633974483_dp, 3.061616997868383e-17_dp]
                rp = merge(r - pi4_dd, r + pi4_dd, r%limbs(1) > 0.0_dp)
            end block
            sk = dd_sin_kernel(rp); ck = dd_cos_kernel(rp)
            res = merge((sk + ck) * inv_sqrt2, (sk - ck) * inv_sqrt2, &
                        r%limbs(1) > 0.0_dp)
        end if
    end function

    ! Evaluate cos(r) for |r| ≤ π/4, same π/8 split.
    elemental function dd_cos_eval(r) result(res)
        type(float64x2), intent(in) :: r
        type(float64x2) :: res, rp, sk, ck, inv_sqrt2
        real(dp), parameter :: pi8 = 0.392699081698724_dp
        if (abs(r%limbs(1)) <= pi8) then
            res = dd_cos_kernel(r)
        else
            inv_sqrt2%limbs = [0.7071067811865476_dp, -4.833646656726457e-17_dp]
            block
                type(float64x2) :: pi4_dd
                pi4_dd%limbs = [0.7853981633974483_dp, 3.061616997868383e-17_dp]
                rp = merge(r - pi4_dd, r + pi4_dd, r%limbs(1) > 0.0_dp)
            end block
            sk = dd_sin_kernel(rp); ck = dd_cos_kernel(rp)
            res = merge((ck - sk) * inv_sqrt2, (ck + sk) * inv_sqrt2, &
                        r%limbs(1) > 0.0_dp)
        end if
    end function

    elemental function dd_sin_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, r
        integer :: q
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        call dd_reduce_pi_half(x, r, q)
        select case (q)
        case (0); res =  dd_sin_eval(r)
        case (1); res =  dd_cos_eval(r)
        case (2); res = -dd_sin_eval(r)
        case (3); res = -dd_cos_eval(r)
        end select
    end function

    elemental function dd_cos_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, r
        integer :: q
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        call dd_reduce_pi_half(x, r, q)
        select case (q)
        case (0); res =  dd_cos_eval(r)
        case (1); res = -dd_sin_eval(r)
        case (2); res = -dd_cos_eval(r)
        case (3); res =  dd_sin_eval(r)
        end select
    end function

    elemental function dd_tan_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, r
        integer :: q
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        call dd_reduce_pi_half(x, r, q)
        select case (q)
        case (0); res =  dd_sin_eval(r) / dd_cos_eval(r)
        case (1); res = -dd_cos_eval(r) / dd_sin_eval(r)
        case (2); res =  dd_sin_eval(r) / dd_cos_eval(r)
        case (3); res = -dd_cos_eval(r) / dd_sin_eval(r)
        end select
    end function

    ! sinh / cosh / tanh derived from the new full-DD exp.
    !   sinh(x) = (exp(x) - exp(-x)) / 2
    !   cosh(x) = (exp(x) + exp(-x)) / 2
    !   tanh(x) = (exp(2x) - 1) / (exp(2x) + 1) — overflow-safe version
    elemental function dd_sinh_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, e, einv, neg_x, half
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [sinh(x%limbs(1)), 0.0_dp]
            return
        end if
        ! For small |x|, (e^x - e^-x)/2 has catastrophic cancellation.
        ! Use the Taylor series sinh(x) = x + x³/6 + x⁵/120 + ...
        ! For |x| < 0.1 nine terms give full DD precision (0.1^17/17! ≈ 3e-32).
        if (abs(x%limbs(1)) < 0.1_dp) then
            block
                type(float64x2) :: x2, p, c1, c3, c5, c7, c9, c11, c13, c15, c17
                c1%limbs  = [1.0_dp, 0.0_dp]
                c3%limbs  = [0.16666666666666666_dp,     9.25185853854297e-18_dp]
                c5%limbs  = [0.008333333333333333_dp,    1.1564823173178714e-19_dp]
                c7%limbs  = [0.0001984126984126984_dp,   1.7209558293420705e-22_dp]
                c9%limbs  = [2.7557319223985893e-06_dp, -1.858393274046472e-22_dp]
                c11%limbs = [2.505210838544172e-08_dp,  -1.448814070935912e-24_dp]
                c13%limbs = [1.6059043836821613e-10_dp,  1.2585294588752098e-26_dp]
                c15%limbs = [7.647163731819816e-13_dp,   7.03872877733453e-30_dp]
                c17%limbs = [2.8114572543455206e-15_dp,  1.6508842730861433e-31_dp]
                x2 = x * x
                p = c17
                p = p * x2 + c15
                p = p * x2 + c13
                p = p * x2 + c11
                p = p * x2 + c9
                p = p * x2 + c7
                p = p * x2 + c5
                p = p * x2 + c3
                p = p * x2 + c1
                res = p * x
            end block
            return
        end if
        e = dd_exp_full(x)
        neg_x%limbs = -x%limbs
        einv = dd_exp_full(neg_x)
        half%limbs = [0.5_dp, 0.0_dp]
        res = (e - einv) * half
    end function

    elemental function dd_cosh_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, e, einv, neg_x, half
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [cosh(x%limbs(1)), 0.0_dp]
            return
        end if
        e = dd_exp_full(x)
        neg_x%limbs = -x%limbs
        einv = dd_exp_full(neg_x)
        half%limbs = [0.5_dp, 0.0_dp]
        res = (e + einv) * half
    end function

    ! asin / acos / atan / atan2 — one Newton step on the now-full-DD
    ! sin / cos / tan, seeded by the libm leading-limb call. Quadratic
    ! convergence makes a single iteration enough to reach DD precision.

    elemental function dd_asin_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, y0, sy, cy, num
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [asin(x%limbs(1)), 0.0_dp]
            return
        end if
        if (abs(x%limbs(1)) > 1.0_dp) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        y0%limbs = [asin(x%limbs(1)), 0.0_dp]
        ! Newton: y' = y + (x - sin(y)) / cos(y)
        sy = dd_sin_full(y0)
        cy = dd_cos_full(y0)
        if (abs(cy%limbs(1)) < 1.0e-15_dp) then
            ! Near ±1: cos(asin(x)) ≈ 0, division is ill-conditioned;
            ! fall back to the seed (libm precision).
            res = y0
            return
        end if
        num = x - sy
        res = y0 + num / cy
    end function

    elemental function dd_acos_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, y0, sy, cy, num
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [acos(x%limbs(1)), 0.0_dp]
            return
        end if
        if (abs(x%limbs(1)) > 1.0_dp) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        y0%limbs = [acos(x%limbs(1)), 0.0_dp]
        ! Newton: y' = y - (x - cos(y)) / sin(y)  [d/dy cos = -sin]
        sy = dd_sin_full(y0)
        cy = dd_cos_full(y0)
        if (abs(sy%limbs(1)) < 1.0e-15_dp) then
            res = y0
            return
        end if
        num = x - cy
        res = y0 - num / sy
    end function

    elemental function dd_atan_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, y0, sy, cy, t, c2, arg, pi_half_dd, one_dd
        logical :: use_recip
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [atan(x%limbs(1)), 0.0_dp]
            return
        end if
        ! For |x| > 1 the Newton residual (x - tan(y0)) cancels to
        ! ~ulp(x), capping precision at ~log2(x) bits lost. Apply the
        ! identity atan(x) = sign(x)·π/2 - atan(1/x) to keep the Newton
        ! argument in [-1, 1], where the residual stays well-scaled.
        use_recip = abs(x%limbs(1)) > 1.0_dp
        if (use_recip) then
            one_dd%limbs = [1.0_dp, 0.0_dp]
            arg = one_dd / x
        else
            arg = x
        end if
        y0%limbs = [atan(arg%limbs(1)), 0.0_dp]
        ! Newton: y' = y + cos²(y) * (arg - tan(y))
        sy = dd_sin_full(y0)
        cy = dd_cos_full(y0)
        if (abs(cy%limbs(1)) < 1.0e-15_dp) then
            res = y0
        else
            t = sy / cy
            c2 = cy * cy
            res = y0 + c2 * (arg - t)
        end if
        if (use_recip) then
            pi_half_dd%limbs = [1.5707963267948966_dp, 6.123233995736766e-17_dp]
            if (x%limbs(1) > 0.0_dp) then
                res = pi_half_dd - res
            else
                ! atan(x) = -π/2 - atan(1/x), but 1/x < 0 here so
                ! computed `res` is negative; add to reach -π/2 + (-|res|).
                res%limbs(1) = -res%limbs(1)
                res%limbs(2) = -res%limbs(2)
                res = res - pi_half_dd
            end if
        end if
    end function

    elemental function dd_atan2_full(y, x) result(res)
        type(float64x2), intent(in) :: y, x
        type(float64x2) :: res, ratio, pi_dd, pi_half_dd
        ! Use the libm atan2 leading-limb result as the seed and do one
        ! Newton step on atan(y/x) when both inputs are non-zero finite.
        if (.not. ieee_is_finite(x%limbs(1)) .or. .not. ieee_is_finite(y%limbs(1))) then
            res%limbs = [atan2(y%limbs(1), x%limbs(1)), 0.0_dp]
            return
        end if
        if (x%limbs(1) == 0.0_dp .and. y%limbs(1) == 0.0_dp) then
            res%limbs = [atan2(y%limbs(1), x%limbs(1)), 0.0_dp]
            return
        end if
        ! High-precision π and π/2 constants for the quadrant correction.
        pi_dd%limbs      = [3.141592653589793_dp,    1.2246467991473532e-16_dp]
        pi_half_dd%limbs = [1.5707963267948966_dp,   6.123233995736766e-17_dp]
        if (abs(x%limbs(1)) >= abs(y%limbs(1))) then
            ! Result is in the band closest to ±π/2; use atan(y/x).
            ratio = y / x
            res = dd_atan_full(ratio)
            if (x%limbs(1) < 0.0_dp) then
                if (y%limbs(1) >= 0.0_dp) then
                    res = res + pi_dd
                else
                    res = res - pi_dd
                end if
            end if
        else
            ! Use atan2(y, x) = ±π/2 - atan(x/y) to keep |x/y| <= 1.
            ratio = x / y
            res = dd_atan_full(ratio)
            if (y%limbs(1) > 0.0_dp) then
                res%limbs = -res%limbs
                res = res + pi_half_dd
            else
                res%limbs = -res%limbs
                res = res - pi_half_dd
            end if
        end if
    end function

    ! asinh / acosh / atanh derived directly from log and sqrt.

    elemental function dd_asinh_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, x2, root, arg, two_ax, ln2
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [asinh(x%limbs(1)), 0.0_dp]
            return
        end if
        ! For small |x|, use the Taylor series asinh(x) = x − x³/6 +
        ! 3x⁵/40 − 15x⁷/336 + ... 15 terms cover |x| < 0.01 with 30+
        ! digits of margin. The log-of-(x + sqrt(1+x²)) formula leaks
        ! ~one DD ulp into the lo limb at this scale because the
        ! intermediate sqrt(1+x²) and the +x cancel against each other.
        if (abs(x%limbs(1)) < 0.01_dp) then
            block
                type(float64x2) :: ax_, x2_, p
                type(float64x2) :: ac(15)
                ac(1)%limbs  = [1.0_dp, 0.0_dp]
                ac(2)%limbs  = [-0.16666666666666666_dp,   -9.25185853854297e-18_dp]
                ac(3)%limbs  = [0.075_dp,                   2.7755575615628915e-18_dp]
                ac(4)%limbs  = [-0.044642857142857144_dp,   9.912705577010326e-19_dp]
                ac(5)%limbs  = [0.030381944444444444_dp,    3.854941057726238e-19_dp]
                ac(6)%limbs  = [-0.022372159090909092_dp,   9.462128050782583e-19_dp]
                ac(7)%limbs  = [0.017352764423076924_dp,   -8.006416042969879e-19_dp]
                ac(8)%limbs  = [-0.01396484375_dp,          6.938893903907229e-19_dp]
                ac(9)%limbs  = [0.011551800896139705_dp,    8.163404592832033e-19_dp]
                ac(10)%limbs = [-0.009761609529194078_dp,  -5.478074134663601e-19_dp]
                ac(11)%limbs = [0.008390335809616815_dp,    4.130293990420969e-19_dp]
                ac(12)%limbs = [-0.0073125258735988454_dp,  3.394024192128536e-19_dp]
                ac(13)%limbs = [0.006447210311889649_dp,   -3.1225022567582527e-19_dp]
                ac(14)%limbs = [-0.005740037670841924_dp,   1.2849803525754126e-19_dp]
                ac(15)%limbs = [0.005153309682319905_dp,   -3.888173308223878e-19_dp]
                ax_ = x
                x2_ = ax_ * ax_
                p = ac(15)
                p = p * x2_ + ac(14)
                p = p * x2_ + ac(13)
                p = p * x2_ + ac(12)
                p = p * x2_ + ac(11)
                p = p * x2_ + ac(10)
                p = p * x2_ + ac(9)
                p = p * x2_ + ac(8)
                p = p * x2_ + ac(7)
                p = p * x2_ + ac(6)
                p = p * x2_ + ac(5)
                p = p * x2_ + ac(4)
                p = p * x2_ + ac(3)
                p = p * x2_ + ac(2)
                p = p * x2_ + ac(1)
                res = p * ax_
            end block
            return
        end if
        if (x%limbs(1) < 0.0_dp) then
            ax%limbs = -x%limbs
        else
            ax = x
        end if
        ! For huge |x|, x² overflows. asinh(x) → log(2|x|) = log(|x|) + ln(2).
        if (ax%limbs(1) > 1.0e150_dp) then
            ln2%limbs = [ln_2_hi, ln_2_lo]
            res = dd_log_full(ax) + ln2
            if (x%limbs(1) < 0.0_dp) res%limbs = -res%limbs
            return
        end if
        x2 = ax * ax
        root = mf_sqrt(x2 + MF_ONE)
        arg = ax + root
        res = dd_log_full(arg)
        if (x%limbs(1) < 0.0_dp) res%limbs = -res%limbs
    end function

    elemental function dd_acosh_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, x2, root, arg, ln2
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [acosh(x%limbs(1)), 0.0_dp]
            return
        end if
        if (x%limbs(1) < 1.0_dp) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        ! For huge x, x² overflows. acosh(x) → log(2x) = log(x) + ln(2).
        if (x%limbs(1) > 1.0e150_dp) then
            ln2%limbs = [ln_2_hi, ln_2_lo]
            res = dd_log_full(x) + ln2
            return
        end if
        x2 = x * x
        root = mf_sqrt(x2 - MF_ONE)
        arg = x + root
        res = dd_log_full(arg)
    end function

    ! erf/erfc: piecewise rational approximation (ported from libquadmath erfq.c)
    elemental function dd_erf_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, z, y, efx_dd, ec
        logical :: neg
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [erf(x%limbs(1)), 0.0_dp]
            return
        end if
        neg = x%limbs(1) < 0.0_dp
        if (neg) then
            ax%limbs = -x%limbs
        else
            ax = x
        end if
        if (ax%limbs(1) >= 1.0_dp) then
            if (ax%limbs(1) >= 16.0_dp) then
                if (neg) then
                    res%limbs = [-1.0_dp, 0.0_dp]
                else
                    res%limbs = [1.0_dp, 0.0_dp]
                end if
                return
            end if
            ec = dd_erfc_full(ax)
            res = MF_ONE - ec
            if (neg) res%limbs = -res%limbs
            return
        end if
        if (ax%limbs(1) < 0.875_dp) then
            if (ax%limbs(1) < 1.0e-18_dp) then
                efx_dd%limbs = [erf_efx_hi, erf_efx_lo]
                res = x + efx_dd * x
                return
            end if
            z = ax * ax
            y = ax + ax * dd_neval(z, erf_TN1_hi, erf_TN1_lo) / &
                          dd_deval(z, erf_TD1_hi, erf_TD1_lo)
        else
            z = ax - MF_ONE
            efx_dd%limbs = [erf_const_hi, erf_const_lo]
            y = efx_dd + dd_neval(z, erf_TN2_hi, erf_TN2_lo) / &
                         dd_deval(z, erf_TD2_hi, erf_TD2_lo)
        end if
        if (neg) then
            res%limbs = -y%limbs
        else
            res = y
        end if
    end function

    elemental function dd_erfc_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, z, y, p, ca, cb, s, x2, e1, e2, diff_sq
        logical :: neg
        integer :: idx
        integer(8) :: ibits
        real(dp) :: sd
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [erfc(x%limbs(1)), 0.0_dp]
            return
        end if
        neg = x%limbs(1) < 0.0_dp
        if (neg) then
            ax%limbs = -x%limbs
        else
            ax = x
        end if
        if (ax%limbs(1) < 0.25_dp) then
            res = MF_ONE - dd_erf_full(x)
            return
        end if
        if (ax%limbs(1) > 107.0_dp) then
            if (neg) then
                res%limbs = [2.0_dp, 0.0_dp]
            else
                res%limbs = [0.0_dp, 0.0_dp]
            end if
            return
        end if
        if (ax%limbs(1) < 1.25_dp) then
            idx = int(8.0_dp * ax%limbs(1))
            z%limbs = [erfc_x0(idx - 1), 0.0_dp]
            z = ax - z
            ca%limbs = [erfc_Ca_hi(idx - 1), 0.0_dp]
            cb%limbs = [erfc_Cb_hi(idx - 1), erfc_Cb_lo(idx - 1)]
            select case (idx)
            case (2)
                y = dd_neval(z, erfc_RN13_hi, erfc_RN13_lo) / &
                    dd_deval(z, erfc_RD13_hi, erfc_RD13_lo)
            case (3)
                y = dd_neval(z, erfc_RN14_hi, erfc_RN14_lo) / &
                    dd_deval(z, erfc_RD14_hi, erfc_RD14_lo)
            case (4)
                y = dd_neval(z, erfc_RN15_hi, erfc_RN15_lo) / &
                    dd_deval(z, erfc_RD15_hi, erfc_RD15_lo)
            case (5)
                y = dd_neval(z, erfc_RN16_hi, erfc_RN16_lo) / &
                    dd_deval(z, erfc_RD16_hi, erfc_RD16_lo)
            case (6)
                y = dd_neval(z, erfc_RN17_hi, erfc_RN17_lo) / &
                    dd_deval(z, erfc_RD17_hi, erfc_RD17_lo)
            case (7)
                y = dd_neval(z, erfc_RN18_hi, erfc_RN18_lo) / &
                    dd_deval(z, erfc_RD18_hi, erfc_RD18_lo)
            case (8)
                y = dd_neval(z, erfc_RN19_hi, erfc_RN19_lo) / &
                    dd_deval(z, erfc_RD19_hi, erfc_RD19_lo)
            case default
                y = dd_neval(z, erfc_RN20_hi, erfc_RN20_lo) / &
                    dd_deval(z, erfc_RD20_hi, erfc_RD20_lo)
            end select
            res = y * z + cb + ca
        else
            ! Asymptotic: erfc(x) = (1/x)*exp(-x^2 - 0.5625 + R(1/x^2))
            if (neg .and. ax%limbs(1) >= 9.0_dp) then
                res%limbs = [2.0_dp, 0.0_dp]
                if (neg) return
            end if
            x2 = ax * ax
            z = MF_ONE / x2
            idx = int(8.0_dp / ax%limbs(1))
            if (idx > 7) idx = 7
            select case (idx)
            case (0)
                p = dd_neval(z, erfc_AN1_hi, erfc_AN1_lo) / &
                    dd_deval(z, erfc_AD1_hi, erfc_AD1_lo)
            case (1)
                p = dd_neval(z, erfc_AN2_hi, erfc_AN2_lo) / &
                    dd_deval(z, erfc_AD2_hi, erfc_AD2_lo)
            case (2)
                p = dd_neval(z, erfc_AN3_hi, erfc_AN3_lo) / &
                    dd_deval(z, erfc_AD3_hi, erfc_AD3_lo)
            case (3)
                p = dd_neval(z, erfc_AN4_hi, erfc_AN4_lo) / &
                    dd_deval(z, erfc_AD4_hi, erfc_AD4_lo)
            case (4)
                p = dd_neval(z, erfc_AN5_hi, erfc_AN5_lo) / &
                    dd_deval(z, erfc_AD5_hi, erfc_AD5_lo)
            case (5)
                p = dd_neval(z, erfc_AN6_hi, erfc_AN6_lo) / &
                    dd_deval(z, erfc_AD6_hi, erfc_AD6_lo)
            case (6)
                p = dd_neval(z, erfc_AN7_hi, erfc_AN7_lo) / &
                    dd_deval(z, erfc_AD7_hi, erfc_AD7_lo)
            case default
                p = dd_neval(z, erfc_AN8_hi, erfc_AN8_lo) / &
                    dd_deval(z, erfc_AD8_hi, erfc_AD8_lo)
            end select
            ! Truncate hi limb to ~27 bits for accurate exp(-x^2)
            ibits = transfer(ax%limbs(1), ibits)
            ibits = iand(ibits, int(Z'FFFFFFFFF8000000', 8))
            sd = transfer(ibits, sd)
            s%limbs = [sd, 0.0_dp]
            e1%limbs = [-0.5625_dp, 0.0_dp]
            e1 = dd_exp_full(-(s * s) + e1)
            diff_sq = (s - ax) * (s + ax)
            e2 = dd_exp_full(diff_sq + p)
            res = (e1 * e2) / ax
        end if
        if (neg) then
            z%limbs = [2.0_dp, 0.0_dp]
            res = z - res
        end if
    end function

    elemental function dd_atanh_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, num, den, ratio, half
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [atanh(x%limbs(1)), 0.0_dp]
            return
        end if
        if (abs(x%limbs(1)) > 1.0_dp) then
            res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            return
        end if
        ! For small |x|, use the Taylor series atanh(x) = x + x³/3 +
        ! x⁵/5 + ... 15 terms cover |x| < 0.5 to about 1e-9 truncation,
        ! and for the |x| < 0.01 branch we have 30+ digits of margin
        ! before the truncation matters. The formula path leaks ~one
        ! DD ulp into the lo limb for tiny x because of the cancellation
        ! in the (1+x)/(1-x) ratio computation.
        if (abs(x%limbs(1)) < 0.01_dp) then
            block
                type(float64x2) :: x2, p
                type(float64x2) :: ac(15)
                ac(1)%limbs  = [1.0_dp, 0.0_dp]
                ac(2)%limbs  = [0.3333333333333333_dp,    1.850371707708594e-17_dp]
                ac(3)%limbs  = [0.2_dp,                  -1.1102230246251566e-17_dp]
                ac(4)%limbs  = [0.14285714285714285_dp,   7.93016446160826e-18_dp]
                ac(5)%limbs  = [0.1111111111111111_dp,    6.1679056923619804e-18_dp]
                ac(6)%limbs  = [0.09090909090909091_dp,  -2.523234146875356e-18_dp]
                ac(7)%limbs  = [0.07692307692307693_dp,  -4.270088556250602e-18_dp]
                ac(8)%limbs  = [0.06666666666666667_dp,   9.251858538542971e-19_dp]
                ac(9)%limbs  = [0.058823529411764705_dp,  8.163404592832033e-19_dp]
                ac(10)%limbs = [0.05263157894736842_dp,   2.921639538487254e-18_dp]
                ac(11)%limbs = [0.047619047619047616_dp,  2.64338815386942e-18_dp]
                ac(12)%limbs = [0.043478260869565216_dp,  1.206764157201257e-18_dp]
                ac(13)%limbs = [0.04_dp,                 -8.326672684688674e-19_dp]
                ac(14)%limbs = [0.037037037037037035_dp,  2.05596856412066e-18_dp]
                ac(15)%limbs = [0.034482758620689655_dp,  4.785444071660157e-19_dp]
                x2 = x * x
                p = ac(15)
                p = p * x2 + ac(14)
                p = p * x2 + ac(13)
                p = p * x2 + ac(12)
                p = p * x2 + ac(11)
                p = p * x2 + ac(10)
                p = p * x2 + ac(9)
                p = p * x2 + ac(8)
                p = p * x2 + ac(7)
                p = p * x2 + ac(6)
                p = p * x2 + ac(5)
                p = p * x2 + ac(4)
                p = p * x2 + ac(3)
                p = p * x2 + ac(2)
                p = p * x2 + ac(1)
                res = p * x
            end block
            return
        end if
        num = MF_ONE + x
        den = MF_ONE - x
        ratio = num / den
        half%limbs = [0.5_dp, 0.0_dp]
        res = half * dd_log_full(ratio)
    end function

    elemental function dd_tanh_full(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, neg_two_ax, em2, two
        if (.not. ieee_is_finite(x%limbs(1))) then
            res%limbs = [tanh(x%limbs(1)), 0.0_dp]
            return
        end if
        ! For |x| > 37, exp(-2|x|) < 2^-106 (below DD epsilon relative
        ! to 1.0), so tanh(x) = ±1 to full DD precision.
        if (x%limbs(1) > 37.0_dp) then
            res%limbs = [1.0_dp, 0.0_dp]
            return
        end if
        if (x%limbs(1) < -37.0_dp) then
            res%limbs = [-1.0_dp, 0.0_dp]
            return
        end if
        ! Small |x|: sinh / cosh avoids the 1-small cancellation.
        if (abs(x%limbs(1)) < 0.5_dp) then
            res = dd_sinh_full(x) / dd_cosh_full(x)
            return
        end if
        ! General case: tanh(|x|) = 1 - 2·exp(-2|x|) / (1 + exp(-2|x|)).
        ! Using exp(-2|x|) (which is small for |x| > 0.5) avoids the
        ! cancellation in the old "1 - 2/(e^(2|x|)+1)" form — there,
        ! 2/(e^(2|x|)+1) ≈ 2·exp(-2|x|) which is close to 0, so
        ! subtracting it from 1 lost ~2|x|/ln(10) digits.
        if (x%limbs(1) < 0.0_dp) then
            ax%limbs = [-x%limbs(1), -x%limbs(2)]
        else
            ax = x
        end if
        neg_two_ax%limbs = [-2.0_dp * ax%limbs(1), -2.0_dp * ax%limbs(2)]
        em2 = dd_exp_full(neg_two_ax)   ! exp(-2|x|), small for |x| > 0.5
        two%limbs = [2.0_dp, 0.0_dp]
        ! tanh(|x|) = 1 - 2·em2 / (1 + em2)
        ! = (1 + em2 - 2·em2) / (1 + em2)
        ! = (1 - em2) / (1 + em2)
        res = (MF_ONE - em2) / (MF_ONE + em2)
        if (x%limbs(1) < 0.0_dp) res%limbs = -res%limbs
    end function

    ! ================================================================
    ! Unary math: mf → mf (elemental)
    ! ================================================================

#:for func in UNARY_MF_MF
    elemental function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
#:if func == 'abs'
        ! IEEE abs: also flips signed-zero -0 to +0. Use sign() rather
        ! than `<` so the -0 case is not silently treated as positive.
        if (sign(1.0_dp, x%limbs(1)) < 0.0_dp .or. &
            (x%limbs(1) == 0.0_dp .and. x%limbs(2) < 0.0_dp)) then
            res%limbs = -x%limbs
        else
            res = x
        end if
#:elif func == 'sqrt'
        ! Karp/Markstein DD sqrt — port of Julia mfsqrt for N == 2.
        ! Inlined into scalar dp so the kernel never goes through a
        ! float64x2 operator dispatch in the hot path.
        block
            real(dp) :: x0, x1, u, half_u, leading
            real(dp) :: r0, r1, p00, e00, bprime, s, c, t, e
            real(dp) :: aprime, aerr, berr
            x0 = x%limbs(1)
            x1 = x%limbs(2)
            leading = sqrt(x0)
            if (.not. (x0 > 0.0_dp .and. ieee_is_finite(leading))) then
                ! 0, -0, negative, NaN, or +Inf — leading-limb sqrt handles
                ! every IEEE special case naturally.
                res%limbs(1) = leading
                res%limbs(2) = 0.0_dp
            else
                u = 1.0_dp / leading
                half_u = 0.5_dp * u
                ! root = x * u  (DD * dp), inlined.
                p00 = x0 * u
                e00 = ieee_fma(x0, u, -p00) + x1 * u
                r0 = p00 + e00
                bprime = r0 - p00
                r1 = e00 - bprime
                ! residual = root * root - x  (DD multiply, then DD subtract).
                p00 = r0 * r0
                e00 = ieee_fma(r0, r0, -p00) + 2.0_dp * (r0 * r1)
                ! root*root as DD: limbs (s_hi, s_lo)
                s = p00 + e00
                bprime = s - p00
                c = e00 - bprime    ! lo limb of root*root
                ! Subtract x: (s, c) - (x0, x1)
                t = s + (-x0)
                aprime = t - (-x0)
                bprime = t - aprime
                aerr = s - aprime
                berr = (-x0) - bprime
                e = aerr + berr
                e = e + (c - x1)
                p00 = t + e         ! residual%limbs(1)
                bprime = p00 - t
                e00 = e - bprime    ! residual%limbs(2)
                ! correction = residual * half_u  (DD * dp).
                s = p00 * half_u
                c = ieee_fma(p00, half_u, -s) + e00 * half_u
                p00 = s + c
                bprime = p00 - s
                e00 = c - bprime
                ! res = root - correction.
                s = r0 + (-p00)
                aprime = s - (-p00)
                bprime = s - aprime
                aerr = r0 - aprime
                berr = (-p00) - bprime
                e = aerr + berr
                c = r1 + (-e00)
                t = s + c
                bprime = t - s
                c = c - bprime
                e = e + c
                res%limbs(1) = t + e
                bprime = res%limbs(1) - t
                res%limbs(2) = e - bprime
            end if
        end block
#:elif func == 'aint'
        res = dd_trunc(x)
#:elif func == 'anint'
        res = dd_round(x)
#:elif func == 'fraction'
        block
            integer :: e
            if (x%limbs(1) == 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                e = exponent(x%limbs(1))
                res%limbs(1) = scale(x%limbs(1), -e)
                res%limbs(2) = scale(x%limbs(2), -e)
            end if
        end block
#:elif func == 'tiny' or func == 'huge' or func == 'epsilon'
        ! Inquiry constants: derive from the underlying double, not via
        ! quad precision (which under/overflows when stored back as dp).
#:if func == 'tiny'
        res%limbs = [tiny(0.0_dp), 0.0_dp]
#:elif func == 'huge'
        res%limbs = [huge(0.0_dp), 0.0_dp]
#:else
        ! epsilon for double-double is roughly 2^-105 (one ulp at the lo
        ! limb of 1.0).
        res%limbs = [scale(epsilon(0.0_dp), -53), 0.0_dp]
#:endif
#:elif func == 'spacing'
        ! DD spacing: distance to the next representable double-double.
        ! For a normalized DD whose hi limb is x[0], the next DD differs
        ! in the lo limb by ulp(x[0]) * 2^-53, which is spacing(x[0]) / 2^53.
        res%limbs = [scale(spacing(x%limbs(1)), -53), 0.0_dp]
#:elif func == 'rrspacing'
        ! rrspacing(x) = |x| / spacing(x). Compute against the DD spacing
        ! so the result is consistent with mf_spacing above.
        res%limbs = [abs(x%limbs(1)) / scale(spacing(x%limbs(1)), -53), 0.0_dp]
#:elif func == 'exp'
        res = dd_exp_full(x)
#:elif func == 'log'
        res = dd_log_full(x)
#:elif func == 'log10'
        res = dd_log10_full(x)
#:elif func == 'sin'
        res = dd_sin_full(x)
#:elif func == 'cos'
        res = dd_cos_full(x)
#:elif func == 'sinpi'
        res = dd_sinpi_full(x)
#:elif func == 'cospi'
        res = dd_cospi_full(x)
#:elif func == 'tan'
        res = dd_tan_full(x)
#:elif func == 'sinh'
        res = dd_sinh_full(x)
#:elif func == 'cosh'
        res = dd_cosh_full(x)
#:elif func == 'tanh'
        res = dd_tanh_full(x)
#:elif func == 'asin'
        res = dd_asin_full(x)
#:elif func == 'acos'
        res = dd_acos_full(x)
#:elif func == 'atan'
        res = dd_atan_full(x)
#:elif func == 'asinh'
        res = dd_asinh_full(x)
#:elif func == 'acosh'
        res = dd_acosh_full(x)
#:elif func == 'atanh'
        res = dd_atanh_full(x)
#:elif func == 'erf'
        res = dd_erf_full(x)
#:elif func == 'erfc'
        res = dd_erfc_full(x)
#:elif func in ('erfc_scaled', 'gamma', 'log_gamma', 'bessel_j0', 'bessel_j1', 'bessel_y0', 'bessel_y1')
        ! Derivative-corrected DD evaluation:
        !     func(hi + lo) ≈ func(hi) + func'(hi) * lo
        ! combined via fast_two_sum into a normalized DD result. Roughly
        ! doubles the precision of the leading-limb std intrinsic without
        ! ever touching quad precision.
        block
            real(dp) :: fhi, deriv, corr, s, bp
            ! erfc_scaled, gamma, log_gamma, bessel_*: no closed-form
            ! correction available without further special functions, so
            ! fall back to a leading-limb evaluation. Precision drops to
            ! single-double for these but no quad precision is involved.
            fhi = ${func}$(x%limbs(1))
            deriv = 0.0_dp
            corr = deriv * x%limbs(2)
            s = fhi + corr
            bp = s - fhi
            res%limbs(1) = s
            res%limbs(2) = corr - bp
        end block
#:else
        ! Should be unreachable: every entry of UNARY_MF_MF is handled above.
        res%limbs = [0.0_dp, 0.0_dp]
#:endif
    end function

#:endfor
    ! ================================================================
    ! Unary math: cx → cx (elemental)
    ! ================================================================

#:for func in UNARY_CX_CX
    elemental function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        type(complex128x2) :: res
#:if func == 'conjg'
        res%re = x%re
        res%im%limbs = -x%im%limbs
#:elif func == 'sqrt'
        ! Complex sqrt — Kahan-style algorithm.
        ! Compute one branch via the well-conditioned `(|z|+|a|)/2`
        ! sub-expression (always non-cancelled) and derive the other
        ! from `u·v = b/2`. Scale the input by an even power of 2
        ! (exact) so the intermediates cannot overflow.
        block
            type(float64x2) :: a, b, r, w, two_w
            integer :: ea, eb, e2, eh
            a = x%re
            b = x%im
            if (a%limbs(1) == 0.0_dp .and. b%limbs(1) == 0.0_dp) then
                res%re = MF_ZERO
                res%im = MF_ZERO
            else
                ea = exponent(a%limbs(1))
                eb = exponent(b%limbs(1))
                if (ea > eb) then
                    e2 = ea
                else
                    e2 = eb
                end if
                ! Make e2 even so we can scale the root by 2^(e2/2).
                if (mod(e2, 2) /= 0) e2 = e2 + 1
                eh = e2 / 2
                a%limbs(1) = scale(a%limbs(1), -e2)
                a%limbs(2) = scale(a%limbs(2), -e2)
                b%limbs(1) = scale(b%limbs(1), -e2)
                b%limbs(2) = scale(b%limbs(2), -e2)
                r = mf_hypot_mf(a, b)
                ! w = sqrt((|z| + |a|) / 2) — never has cancellation.
                if (a%limbs(1) >= 0.0_dp) then
                    w = mf_sqrt(mf_mul_dp((r + a), 0.5_dp))
                else
                    w = mf_sqrt(mf_mul_dp((r - a), 0.5_dp))
                end if
                two_w%limbs = [2.0_dp * w%limbs(1), 2.0_dp * w%limbs(2)]
                if (a%limbs(1) >= 0.0_dp) then
                    ! u = w, v = b / (2w)
                    res%re%limbs(1) = scale(w%limbs(1), eh)
                    res%re%limbs(2) = scale(w%limbs(2), eh)
                    if (w%limbs(1) > 0.0_dp) then
                        block
                            type(float64x2) :: v
                            v = b / two_w
                            res%im%limbs(1) = scale(v%limbs(1), eh)
                            res%im%limbs(2) = scale(v%limbs(2), eh)
                        end block
                    else
                        res%im = MF_ZERO
                    end if
                else
                    ! u = |b| / (2w), v = sign(b) * w
                    if (w%limbs(1) > 0.0_dp) then
                        block
                            type(float64x2) :: ab, u
                            if (b%limbs(1) < 0.0_dp) then
                                ab%limbs = -b%limbs
                            else
                                ab = b
                            end if
                            u = ab / two_w
                            res%re%limbs(1) = scale(u%limbs(1), eh)
                            res%re%limbs(2) = scale(u%limbs(2), eh)
                        end block
                    else
                        res%re = MF_ZERO
                    end if
                    if (b%limbs(1) < 0.0_dp) then
                        res%im%limbs(1) = -scale(w%limbs(1), eh)
                        res%im%limbs(2) = -scale(w%limbs(2), eh)
                    else
                        res%im%limbs(1) = scale(w%limbs(1), eh)
                        res%im%limbs(2) = scale(w%limbs(2), eh)
                    end if
                end if
            end if
        end block
#:elif func == 'exp'
        ! exp(a+bi) = exp(a) * (cos(b) + i sin(b))
        block
            type(float64x2) :: ea
            ea = mf_exp(x%re)
            res%re = ea * mf_cos(x%im)
            res%im = ea * mf_sin(x%im)
        end block
#:elif func == 'log'
        ! log(a+bi) = log(|z|) + i*atan2(b, a)
        ! Compute log(|z|) without forming hypot(a, b) explicitly so the
        ! formula does not overflow when |z| > huge.
        block
            type(float64x2) :: ax, ay, big, small, ratio, half
            ax = abs(x%re)
            ay = abs(x%im)
            if (ax > ay) then
                big = ax
                small = ay
            else
                big = ay
                small = ax
            end if
            if (big%limbs(1) == 0.0_dp) then
                res%re%limbs = [-huge(0.0_dp), 0.0_dp]
            else
                ratio = small / big
                half%limbs = [0.5_dp, 0.0_dp]
                res%re = mf_log(big) + half * mf_log(MF_ONE + ratio * ratio)
            end if
        end block
        res%im = mf_atan2_mf(x%im, x%re)
#:elif func == 'sin'
        ! sin(a+bi) = sin(a)*cosh(b) + i*cos(a)*sinh(b)
        res%re = mf_sin(x%re) * mf_cosh(x%im)
        res%im = mf_cos(x%re) * mf_sinh(x%im)
#:elif func == 'cos'
        ! cos(a+bi) = cos(a)*cosh(b) - i*sin(a)*sinh(b)
        block
            type(float64x2) :: tmp
            res%re = mf_cos(x%re) * mf_cosh(x%im)
            tmp = mf_sin(x%re) * mf_sinh(x%im)
            res%im%limbs = -tmp%limbs
        end block
#:elif func == 'tan'
        ! tan(z) = sin(z) / cos(z)
        res = cx_sin(x) / cx_cos(x)
#:elif func == 'sinh'
        ! sinh(a+bi) = sinh(a)*cos(b) + i*cosh(a)*sin(b)
        res%re = mf_sinh(x%re) * mf_cos(x%im)
        res%im = mf_cosh(x%re) * mf_sin(x%im)
#:elif func == 'cosh'
        ! cosh(a+bi) = cosh(a)*cos(b) + i*sinh(a)*sin(b)
        res%re = mf_cosh(x%re) * mf_cos(x%im)
        res%im = mf_sinh(x%re) * mf_sin(x%im)
#:elif func == 'tanh'
        res = cx_sinh(x) / cx_cosh(x)
#:elif func == 'asin'
        ! asin(z) = -i * log(iz + sqrt((1-z)(1+z))).
        ! The factored form (1-z)(1+z) avoids the cancellation that
        ! plain (1 - z²) suffers when |z| is near 1.
        block
            type(complex128x2) :: iz, omz, opz, one_minus_z2, root, arg
            iz%re%limbs = -x%im%limbs
            iz%im = x%re
            omz%re = MF_ONE - x%re
            omz%im%limbs = -x%im%limbs
            opz%re = MF_ONE + x%re
            opz%im = x%im
            one_minus_z2 = omz * opz
            root = cx_sqrt(one_minus_z2)
            arg = iz + root
            arg = cx_log(arg)
            ! multiply by -i: (-i)*(p + qi) = q - p*i
            res%re = arg%im
            res%im%limbs = -arg%re%limbs
        end block
#:elif func == 'acos'
        ! acos(z) = pi/2 - asin(z), with a high-precision DD pi/2.
        block
            type(complex128x2) :: a
            type(float64x2) :: pi_half_dd
            a = cx_asin(x)
            pi_half_dd%limbs = [1.5707963267948966_dp, 6.123233995736766e-17_dp]
            res%re = pi_half_dd - a%re
            res%im%limbs = -a%im%limbs
        end block
#:elif func == 'atan'
        ! atan(z) = (i/2) * log((i+z)/(i-z))
        block
            type(complex128x2) :: num, den, ratio, l
            type(float64x2) :: half_im
            num%re = x%re
            num%im = MF_ONE + x%im
            den%re%limbs = -x%re%limbs
            den%im = MF_ONE - x%im
            ratio = num / den
            l = cx_log(ratio)
            ! multiply by i/2: (i/2)*(p+qi) = -q/2 + (p/2)*i
            half_im = mf_mul_dp(l%im, 0.5_dp)
            res%re%limbs = -half_im%limbs
            res%im = mf_mul_dp(l%re, 0.5_dp)
        end block
#:elif func == 'asinh'
        ! asinh(z) = log(z + sqrt(1 + z²)).
        ! Factor (1 + z²) = (1 + iz)(1 - iz) to avoid the cancellation
        ! that plain z² + 1 suffers when z is near ±i.
        block
            type(complex128x2) :: opi, omi, one_plus_z2, root, arg
            ! 1 + iz = (1 - im) + re·i
            opi%re = MF_ONE - x%im
            opi%im = x%re
            ! 1 - iz = (1 + im) - re·i
            omi%re = MF_ONE + x%im
            omi%im%limbs = -x%re%limbs
            one_plus_z2 = opi * omi
            root = cx_sqrt(one_plus_z2)
            arg = x + root
            res = cx_log(arg)
        end block
#:elif func == 'acosh'
        ! acosh(z) = log(z + sqrt(z-1) * sqrt(z+1))
        block
            type(complex128x2) :: zp1, zm1, r1, r2, arg
            zp1 = x; zp1%re = x%re + MF_ONE
            zm1 = x; zm1%re = x%re - MF_ONE
            r1 = cx_sqrt(zm1)
            r2 = cx_sqrt(zp1)
            arg = x + r1 * r2
            res = cx_log(arg)
        end block
#:elif func == 'atanh'
        ! atanh(z) = (1/2) * log((1+z)/(1-z))
        block
            type(complex128x2) :: num, den, ratio, l
            num%re = MF_ONE + x%re
            num%im = x%im
            den%re = MF_ONE - x%re
            den%im%limbs = -x%im%limbs
            ratio = num / den
            l = cx_log(ratio)
            res%re = mf_mul_dp(l%re, 0.5_dp)
            res%im = mf_mul_dp(l%im, 0.5_dp)
        end block
#:endif
    end function

#:endfor
    ! ================================================================
    ! Unary math: cx → mf (elemental)
    ! ================================================================

#:for func in UNARY_CX_MF
    elemental function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
#:if func == 'abs'
        ! |a + bi| = hypot(a, b)
        res = mf_hypot_mf(x%re, x%im)
#:else
        ! aimag(a + bi) = b
        res = x%im
#:endif
    end function

#:endfor
    ! ================================================================
    ! Complex-specific: cmplx, real, mf_real (elemental)
    ! ================================================================

    elemental function mf_cmplx_2(re, im) result(res)
        type(float64x2), intent(in) :: re, im
        type(complex128x2) :: res
        res%re = re
        res%im = im
    end function

    elemental function mf_cmplx_1(re) result(res)
        type(float64x2), intent(in) :: re
        type(complex128x2) :: res
        res%re = re
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_real(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    elemental function mf_real_mf(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = x
    end function

    elemental function cx_real_mf(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    ! ================================================================
    ! Internal DD rounding helpers (used by mod/modulo and aint/anint)
    ! ================================================================

    elemental function dd_trunc(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        real(dp) :: x_hi, x_lo, t_hi, frac_hi, s, bp, n
        real(dp) :: t1, t2
        x_hi = x%limbs(1)
        x_lo = x%limbs(2)
        if (abs(x_hi) >= 4503599627370496.0_dp) then  ! 2^52
            ! Large values: original algorithm (hi already integer,
            ! need two-limb result + correction).
            t1 = aint(x_hi)
            t2 = aint(x_lo)
            s = t1 + t2; bp = s - t1
            res%limbs(1) = s
            res%limbs(2) = t2 - bp
            if (x_hi >= 0.0_dp) then
                if (res > x) res = res - MF_ONE
            else
                if (res < x) res = res + MF_ONE
            end if
            return
        end if
        ! Fast path: truncate hi, compute DD fractional part, adjust.
        t_hi = aint(x_hi)
        frac_hi = x_hi - t_hi       ! exact
        s = frac_hi + x_lo          ! total fractional part
        ! Adjust if lo limb pushed past an integer boundary.
        n = 0.0_dp
        if (x_hi >= 0.0_dp) then
            if (s >= 1.0_dp) n = 1.0_dp
            if (s < 0.0_dp) n = -1.0_dp
        else
            if (s <= -1.0_dp) n = -1.0_dp
            if (s > 0.0_dp) n = 1.0_dp
        end if
        res%limbs(1) = t_hi + n
        res%limbs(2) = 0.0_dp
    end function

    elemental function dd_floor(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = dd_trunc(x)
        if (x%limbs(1) < 0.0_dp .and. res /= x) then
            res = res - MF_ONE
        end if
    end function

    elemental function dd_ceil(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = dd_trunc(x)
        if (x%limbs(1) > 0.0_dp .and. res /= x) then
            res = res + MF_ONE
        end if
    end function

    elemental function dd_round(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        ! Round half away from zero, matching Fortran nint / anint.
        ! Fast scalar path for |hi| < 2^52: truncate hi, compute the
        ! DD fractional part via two_sum, and test against ±0.5. All
        ! scalar dp operations — no DD operator calls.
        real(dp) :: x_hi, x_lo, t_hi, frac_hi, s, bp, frac_lo, n
        x_hi = x%limbs(1)
        x_lo = x%limbs(2)
        if (abs(x_hi) >= 4503599627370496.0_dp) then  ! 2^52
            ! Large or special values: existing correct path.
            if (x_hi >= 0.0_dp) then
                res = dd_floor(x + MF_HALF)
            else
                res = dd_ceil(x - MF_HALF)
            end if
            return
        end if
        ! Truncate hi to integer; frac_hi = x_hi - t_hi is exact.
        t_hi = aint(x_hi)
        frac_hi = x_hi - t_hi
        ! DD sum of (frac_hi, x_lo) via two_sum → (s, frac_lo).
        s = frac_hi + x_lo
        bp = s - frac_hi
        frac_lo = x_lo - bp
        ! Decide rounding: +1, -1, or 0.
        n = 0.0_dp
        if (s > 0.5_dp .or. (s == 0.5_dp .and. frac_lo >= 0.0_dp)) then
            n = 1.0_dp
        else if (s < -0.5_dp .or. (s == -0.5_dp .and. frac_lo <= 0.0_dp)) then
            n = -1.0_dp
        end if
        res%limbs(1) = t_hi + n
        res%limbs(2) = 0.0_dp
    end function

    ! ================================================================
    ! Binary real functions (elemental)
    ! ================================================================

#:for func in BINARY_REAL + BINARY_MINMAX
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
    elemental function ${n1}$_${func}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        type(float64x2) :: res
        type(float64x2) :: x, y
        x = ${MFCONV[n1].format('a')}$
        y = ${MFCONV[n2].format('b')}$
#:if func == 'min'
        if (x < y) then
            res = x
        else
            res = y
        end if
#:elif func == 'max'
        if (x > y) then
            res = x
        else
            res = y
        end if
#:elif func == 'sign'
        ! Fortran sign(a, b): magnitude of |a|, sign of b.
        block
            logical :: x_neg, y_neg
            x_neg = (x%limbs(1) < 0.0_dp .or. (x%limbs(1) == 0.0_dp .and. x%limbs(2) < 0.0_dp))
            y_neg = (y%limbs(1) < 0.0_dp .or. (y%limbs(1) == 0.0_dp .and. y%limbs(2) < 0.0_dp))
            if (x_neg .neqv. y_neg) then
                res%limbs = -x%limbs
            else
                res = x
            end if
        end block
#:elif func == 'mod'
        ! Fast iterative reduction for exponent gaps ≤ 53 (quotients
        ! up to ~2^53). For larger gaps, fall back to the divide-based
        ! path which computes trunc(x/y) without iterative cancellation.
        block
            logical :: x_neg
            type(float64x2) :: ax, ay, r
            real(dp) :: q
            integer :: ex, ey, diff
            x_neg = (x%limbs(1) < 0.0_dp)
            if (x_neg) then
                ax%limbs(1) = -x%limbs(1); ax%limbs(2) = -x%limbs(2)
            else
                ax = x
            end if
            if (y%limbs(1) < 0.0_dp) then
                ay%limbs(1) = -y%limbs(1); ay%limbs(2) = -y%limbs(2)
            else
                ay = y
            end if
            if (ax < ay) then
                res = x
            else
                ex = exponent(ax%limbs(1))
                ey = exponent(ay%limbs(1))
                diff = ex - ey
                if (diff > 53) then
                    ! Large gap: full DD divide path (correct for any range)
                    res = x - dd_trunc(x / y) * y
                else
                    ! Small gap: floor-multiple reduction (no DD divide).
                    ! Use aint (returns real) rather than floor (returns
                    ! default integer, which overflows for q > 2^31 and
                    ! saturates negative — forcing the slow one-at-a-time
                    ! subtract path to loop ~r/ay times). r and ay are
                    ! positive here so aint == floor.
                    r = ax
                    do while (r >= ay)
                        q = aint(r%limbs(1) / ay%limbs(1))
                        if (q <= 1.0_dp) then
                            r = r - ay
                        else
                            r = r - mf_mul_dp(ay, q)
                        end if
                        if (r%limbs(1) < 0.0_dp) r = r + ay
                        if (r%limbs(1) == 0.0_dp .and. r%limbs(2) == 0.0_dp) exit
                    end do
                    if (x_neg) then
                        res%limbs(1) = -r%limbs(1)
                        res%limbs(2) = -r%limbs(2)
                    else
                        res = r
                    end if
                end if
            end if
        end block
#:elif func == 'modulo'
        ! modulo via mod + sign adjustment
        res = ${n1}$_mod_${n2}$(a, b)
        if (res%limbs(1) /= 0.0_dp) then
            if ((res%limbs(1) > 0.0_dp .and. y%limbs(1) < 0.0_dp) .or. &
                (res%limbs(1) < 0.0_dp .and. y%limbs(1) > 0.0_dp)) then
                res = res + y
            end if
        end if
#:elif func == 'dim'
        if (.not. (ieee_is_finite(x%limbs(1)) .and. ieee_is_finite(y%limbs(1)))) then
            ! Defer to the dp intrinsic so NaN/Inf propagation matches.
            res%limbs = [dim(x%limbs(1), y%limbs(1)), 0.0_dp]
        else if (x > y) then
            res = x - y
        else
            res = MF_ZERO
        end if
#:elif func == 'hypot'
        ! sqrt(x^2 + y^2) with scaling to avoid overflow / underflow.
        block
            type(float64x2) :: ax, ay, big, small, ratio, scaled, root
            real(dp) :: scale_up
            integer :: scale_exp
            if (.not. (ieee_is_finite(x%limbs(1)) .and. ieee_is_finite(y%limbs(1)))) then
                ! Defer to the dp intrinsic so hypot(inf, NaN) = inf etc.
                res%limbs = [hypot(x%limbs(1), y%limbs(1)), 0.0_dp]
                return
            end if
            if (x%limbs(1) < 0.0_dp .or. (x%limbs(1) == 0.0_dp .and. x%limbs(2) < 0.0_dp)) then
                ax%limbs = -x%limbs
            else
                ax = x
            end if
            if (y%limbs(1) < 0.0_dp .or. (y%limbs(1) == 0.0_dp .and. y%limbs(2) < 0.0_dp)) then
                ay%limbs = -y%limbs
            else
                ay = y
            end if
            if (ax > ay) then
                big = ax
                small = ay
            else
                big = ay
                small = ax
            end if
            if (big%limbs(1) == 0.0_dp) then
                res = MF_ZERO
            else
                ! Scale by powers of 2 (exact) so big stays away from
                ! both overflow and underflow before the final multiply.
                scale_exp = exponent(big%limbs(1))
                big%limbs(1)   = scale(big%limbs(1),   -scale_exp)
                big%limbs(2)   = scale(big%limbs(2),   -scale_exp)
                small%limbs(1) = scale(small%limbs(1), -scale_exp)
                small%limbs(2) = scale(small%limbs(2), -scale_exp)
                ratio = small / big
                root = big * mf_sqrt(MF_ONE + ratio * ratio)
                res%limbs(1) = scale(root%limbs(1), scale_exp)
                res%limbs(2) = scale(root%limbs(2), scale_exp)
                if (.not. ieee_is_finite(res%limbs(1))) then
                    ! True result exceeds dp range; force the lo limb
                    ! to 0 so callers see a clean inf instead of garbage.
                    res%limbs(2) = 0.0_dp
                end if
            end if
        end block
#:elif func == 'atan2'
        ! Full-DD atan2 — see dd_atan2_full above. Here the binary
        ! generator passes (a, b) with a = "y" and b = "x" inverted, so
        ! we still call dd_atan2_full(x, y) where x corresponds to the
        ! first argument (y in standard atan2 terms).
        res = dd_atan2_full(x, y)
#:elif func == 'nearest'
        ! Approximate one DD ulp toward y on the leading limb only.
        block
            real(dp) :: hi, dir
            hi = x%limbs(1)
            if (y%limbs(1) > 0.0_dp) then
                dir = huge(0.0_dp)
            else
                dir = -huge(0.0_dp)
            end if
            res%limbs(1) = nearest(hi, dir)
            res%limbs(2) = 0.0_dp
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! min/max with N arguments (N = 3..8). LAPACK has call sites with
    ! up to 5 arguments; the upper bound is generous so future call
    ! sites do not regress.
#:def mf_minmax_body(func, n)
    elemental function mf_${func}$${n}$(${', '.join(['a%d' % i for i in range(1, n+1)])}$) result(res)
        type(float64x2), intent(in) :: ${', '.join(['a%d' % i for i in range(1, n+1)])}$
        type(float64x2) :: res
#:set cmp = '<' if func == 'min' else '>'
        res = a1
#:for i in range(2, n+1)
        if (a${i}$ ${cmp}$ res) res = a${i}$
#:endfor
    end function
#:enddef
#:for func in BINARY_MINMAX
#:for n in MINMAX_NARG
$:mf_minmax_body(func, n)

#:endfor
#:endfor
    ! ================================================================
    ! Bessel functions with integer order (elemental + transformational)
    ! ================================================================

#:for func in BESSEL_N
    elemental function mf_${func}$_elem(n, x) result(res)
        integer, intent(in) :: n
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        ! Leading-limb only — no closed-form derivative for general bessel
        ! orders without dragging in more special-function machinery.
        res%limbs = [${func}$(n, x%limbs(1)), 0.0_dp]
    end function

    pure function mf_${func}$_range(n1, n2, x) result(res)
        integer, intent(in) :: n1, n2
        type(float64x2), intent(in) :: x
        type(float64x2) :: res(max(n2 - n1 + 1, 0))
        real(dp) :: tmp(max(n2 - n1 + 1, 0))
        integer :: i
        tmp = ${func}$(n1, n2, x%limbs(1))
        do i = 1, size(tmp)
            res(i)%limbs = [tmp(i), 0.0_dp]
        end do
    end function

#:endfor
    ! ================================================================
    ! Functions: (mf, integer) → mf (elemental)
    ! ================================================================

#:for func in MF_INT_TO_MF
    elemental function mf_${func}$(x, i) result(res)
        type(float64x2), intent(in) :: x
        integer, intent(in) :: i
        type(float64x2) :: res
#:if func == 'scale'
        ! scale(x, i) = x * 2^i — exact on dp limbs.
        res%limbs(1) = scale(x%limbs(1), i)
        res%limbs(2) = scale(x%limbs(2), i)
#:else
        ! set_exponent(x, i) = fraction(x) * 2^i.
        block
            integer :: e
            if (x%limbs(1) == 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                e = exponent(x%limbs(1))
                res%limbs(1) = scale(x%limbs(1), i - e)
                res%limbs(2) = scale(x%limbs(2), i - e)
            end if
        end block
#:endif
    end function

#:endfor
    ! ================================================================
    ! Numeric inquiry functions (elemental)
    ! ================================================================

#:for func in INQUIRY_MF_INT
    elemental function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
#:if func == 'digits'
        res = 106
#:elif func == 'maxexponent'
        res = maxexponent(0.0_dp)
#:elif func == 'minexponent'
        res = minexponent(0.0_dp)
#:else
        res = radix(0.0_dp)
#:endif
    end function

#:endfor
#:for func in INQUIRY_BOTH_INT
    elemental function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
#:if func == 'precision'
        res = 31
#:else
        res = range(0.0_dp)
#:endif
    end function

    elemental function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        integer :: res
#:if func == 'precision'
        res = 31
#:else
        res = range(0.0_dp)
#:endif
    end function

#:endfor
    elemental function mf_storage_size(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = 2 * storage_size(0.0_dp)
    end function

    elemental function cx_storage_size(x) result(res)
        type(complex128x2), intent(in) :: x
        integer :: res
        res = 4 * storage_size(0.0_dp)
    end function

    ! ================================================================
    ! Array reductions: value (maxval, minval) — rank 1-7
    ! ================================================================

#:for func in ARRAY_REDUCE_VAL
#:set CMP_OP = '>' if func == 'maxval' else '<'
#:for rank in range(1, MAX_RANK+1)
    pure function mf_${func}$_${rank}$d(array, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res
        logical :: have
        integer :: ${IVARS(rank)}$
        have = .false.
        ! Provide a deterministic default for empty / fully-masked input.
        res = mf_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (.not. have) then
                res = array(${IDXS(rank)}$)
                have = .true.
            else if (array(${IDXS(rank)}$) ${CMP_OP}$ res) then
                res = array(${IDXS(rank)}$)
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_${func}$_1d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        if (present(mask)) then
            res = mf_${func}$_1d(array, mask=mask)
        else
            res = mf_${func}$_1d(array)
        end if
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        logical :: have
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                have = .false.
                cur = mf_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (.not. have) then
                        cur = array(${IDXS(rank)}$)
                        have = .true.
                    else if (array(${IDXS(rank)}$) ${CMP_OP}$ cur) then
                        cur = array(${IDXS(rank)}$)
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ================================================================
    ! Array reductions: location (maxloc, minloc) — rank 1-7
    ! ================================================================

#:for func in ARRAY_REDUCE_LOC
#:set CMP_OP = '>' if func == 'maxloc' else '<'
#:set CMP_STRICT = '>' if func == 'maxloc' else '<'
#:for rank in range(1, MAX_RANK+1)
    pure function mf_${func}$_${rank}$d(array, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        type(float64x2) :: best
        logical :: have, scan_back
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        have = .false.
        best = mf_from_dp(0.0_dp)
        res = 0
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (.not. have) then
                best = array(${IDXS(rank)}$)
                res = [${IDXS(rank)}$]
                have = .true.
            else if (array(${IDXS(rank)}$) ${CMP_STRICT}$ best) then
                best = array(${IDXS(rank)}$)
                res = [${IDXS(rank)}$]
            else if (scan_back .and. array(${IDXS(rank)}$) == best) then
                res = [${IDXS(rank)}$]
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_${func}$_1d_dim(array, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = mf_${func}$_1d(array, mask=mask, back=back)
        else if (present(mask)) then
            r1 = mf_${func}$_1d(array, mask=mask)
        else if (present(back)) then
            r1 = mf_${func}$_1d(array, back=back)
        else
            r1 = mf_${func}$_1d(array)
        end if
        res = r1(1)
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: best
        logical :: have, scan_back
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                have = .false.
                best = mf_from_dp(0.0_dp)
                idx = 0
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (.not. have) then
                        best = array(${IDXS(rank)}$)
                        idx = i${d}$
                        have = .true.
                    else if (array(${IDXS(rank)}$) ${CMP_STRICT}$ best) then
                        best = array(${IDXS(rank)}$)
                        idx = i${d}$
                    else if (scan_back .and. array(${IDXS(rank)}$) == best) then
                        idx = i${d}$
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ================================================================
    ! Array reductions: sum, product — rank 1-7 (mf + cx)
    ! ================================================================

#:for func in ARRAY_REDUCE_SUM
#:set INIT_VAL = '0.0_dp' if func == 'sum' else '1.0_dp'
#:set OP_SYM = '+' if func == 'sum' else '*'
#:for rank in range(1, MAX_RANK+1)
    ! mf ${func}$ rank ${rank}$
    pure function mf_${func}$_${rank}$d(array, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res
        integer :: ${IVARS(rank)}$
        res = mf_from_dp(${INIT_VAL}$)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            res = res ${OP_SYM}$ array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_${func}$_1d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        if (present(mask)) then
            res = mf_${func}$_1d(array, mask=mask)
        else
            res = mf_${func}$_1d(array)
        end if
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                cur = mf_from_dp(${INIT_VAL}$)
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    cur = cur ${OP_SYM}$ array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

    ! cx ${func}$ rank ${rank}$
    pure function cx_${func}$_${rank}$d(array, mask) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex128x2) :: res
        type(float64x2) :: zero, one
        integer :: ${IVARS(rank)}$
        zero = mf_from_dp(0.0_dp)
        one = mf_from_dp(1.0_dp)
#:if func == 'sum'
        res%re = zero
        res%im = zero
#:else
        res%re = one
        res%im = zero
#:endif
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            res = res ${OP_SYM}$ array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function cx_${func}$_1d_dim(array, dim, mask) result(res)
        type(complex128x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(complex128x2) :: res
        if (present(mask)) then
            res = cx_${func}$_1d(array, mask=mask)
        else
            res = cx_${func}$_1d(array)
        end if
    end function
#:else
    pure function cx_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex128x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(complex128x2) :: cur
        type(float64x2) :: zero, one
        integer :: ${IVARS(rank)}$
        zero = mf_from_dp(0.0_dp)
        one = mf_from_dp(1.0_dp)
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
#:if func == 'sum'
                cur%re = zero
                cur%im = zero
#:else
                cur%re = one
                cur%im = zero
#:endif
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    cur = cur ${OP_SYM}$ array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ================================================================
    ! dot_product (pure)
    ! ================================================================

    pure function mf_dot_product(a, b) result(res)
        type(float64x2), intent(in) :: a(:), b(:)
        type(float64x2) :: res
        ! Fused multiply-accumulate with periodic renormalization.
        ! Every MF_FMA_RENORM_INTERVAL iterations (default 8) we
        ! fast_two_sum the accumulator to keep s_lo bounded. Set the
        ! interval to 0 to renormalize only at the end.
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: k, ri
        ri = MF_FMA_RENORM_INTERVAL
        s_hi = 0.0_dp
        s_lo = 0.0_dp
        do k = 1, size(a)
            ah = a(k)%limbs(1); al = a(k)%limbs(2)
            bh = b(k)%limbs(1); bl = b(k)%limbs(2)
            p = ah * bh
            e = ieee_fma(ah, bh, -p)
            cross = ah * bl + al * bh
            t = s_hi + p
            bp = t - s_hi; ap = t - bp
            aerr = s_hi - ap; berr = p - bp
            s_lo = s_lo + (e + cross + aerr + berr)
            s_hi = t
            if (ri > 0 .and. mod(k, ri) == 0) then
                t = s_hi + s_lo; bp = t - s_hi
                s_hi = t; s_lo = s_lo - bp
            end if
        end do
        t = s_hi + s_lo
        bp = t - s_hi
        res%limbs(1) = t
        res%limbs(2) = s_lo - bp
    end function

    pure function cx_dot_product(a, b) result(res)
        type(complex128x2), intent(in) :: a(:), b(:)
        type(complex128x2) :: res
        type(float64x2) :: zero
        integer :: i1
        zero = mf_from_dp(0.0_dp)
        res%re = zero
        res%im = zero
        ! Standard Fortran dot_product conjugates the first argument.
        do i1 = 1, size(a)
            res = res + cx_conjg(a(i1)) * b(i1)
        end do
    end function

    ! ================================================================
    ! norm2 (pure) — rank 1-7, NO mask per standard
    ! ================================================================

#:for rank in range(1, MAX_RANK+1)
    pure function mf_norm2_${rank}$d(array) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2) :: res
        type(float64x2) :: s
        integer :: ${IVARS(rank)}$
        s = mf_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            s = s + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
        res = mf_sqrt(s)
    end function

#:if rank > 1
    pure function mf_norm2_${rank}$d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                cur = mf_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    cur = cur + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = mf_sqrt(cur)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ================================================================
    ! findloc (pure) — rank 1-7 (mf + cx)
    ! ================================================================

#:for rank in range(1, MAX_RANK+1)
    ! mf findloc rank ${rank}$
    pure function mf_findloc_${rank}$d(array, value, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = mf_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = mf_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = mf_findloc_1d(array, value, back=back)
        else
            r1 = mf_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function mf_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

