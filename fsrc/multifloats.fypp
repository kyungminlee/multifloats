#! multifloats.fypp — Float64x2 multifloats module (generated with fypp)
#!
#! The public generic interface is inherited from the mock scaffold, but the
#! core Float64x2 arithmetic uses explicit 2-limb double-double kernels
#! adapted from external/MultiFloats.jl. Broader transformational and
#! transcendental coverage still routes through REAL(16)/COMPLEX(16) helpers.
#!
#! The interface for float64x2 mirrors REAL(KIND=16) as closely as possible:
#! all mixed-type arithmetic, comparisons, and assignments with real(dp),
#! real(sp), integer, complex(dp), and complex(sp) are supported.
#!
#! =====================================================================
#! Performance note: Fortran ABI overhead (2025-04)
#! =====================================================================
#!
#! The DD kernels (add, mul, div, sqrt, ...) use `elemental` functions
#! on a `sequence` derived type. This design is intentional — it gives
#! automatic whole-array operations and EQUIVALENCE compatibility (needed
#! by some LAPACK routines) — but it carries an inherent ABI cost:
#!
#!   - gfortran passes/returns derived types via hidden pointers (not in
#!     FP registers), adding ~3-7× call overhead vs the C ABI.
#!   - With LTO (OBJECT library + -flto), gfortran inlines the kernels
#!     and eliminates most of this overhead, but its SROA pass does not
#!     fully promote the hidden result pointer to registers, leaving a
#!     ~1.5× residual gap vs C++ on the cheapest ops (add, mul).
#!
#! Benchmarking confirmed that switching to `bind(c)` + `value` args on
#! a `bind(c)` type closes the gap entirely (fc/cw ≈ 1.0× for add, mul,
#! div, sqrt), proving the gap is purely ABI, not codegen. However,
#! `bind(c)` is incompatible with `elemental` and `sequence`, so we keep
#! the current design and accept the ~1.5× overhead on basic arithmetic
#! (which is already 2-10× faster than libquadmath quad precision).
#!
#! To get the fastest possible DD arithmetic from Fortran without LTO,
#! call the C-ABI wrappers in include/multifloats.h directly via
#! iso_c_binding interfaces (see test/bench_abi.f90 for an example).
#! =====================================================================

#! =====================================================================
#! Type system metadata
#! =====================================================================
#:set RTYPES = [('dd', 'type(float64x2)'), ('dp', 'real(dp)'), ('sp', 'real(sp)'), ('int', 'integer')]
#:set CTYPES = [('cdd', 'type(complex64x2)'), ('cdp', 'complex(dp)'), ('csp', 'complex(sp)')]
#:set ATYPES = RTYPES + CTYPES

#:set CONV = {'dd': 'to_qp({})', 'cdd': 'to_cqp({})', 'dp': 'real({}, qp)', 'sp': 'real({}, qp)', 'int': 'real({}, qp)', 'cdp': 'cmplx({}, kind=qp)', 'csp': 'cmplx({}, kind=qp)'}
#:set ISCPLX = {'dd': False, 'cdd': True, 'dp': False, 'sp': False, 'int': False, 'cdp': True, 'csp': True}
#:set DDCONV = {'dd': '{}', 'dp': 'dd_from_dp({})', 'sp': 'dd_from_sp({})', 'int': 'dd_from_int({})'}

#! Operator tables
#:set ARITH_OPS = [('+', 'add'), ('-', 'sub'), ('*', 'mul'), ('/', 'div')]
#:set EQ_OPS = [('==', 'eq'), ('/=', 'ne')]
#:set ORD_OPS = [('<', 'lt'), ('>', 'gt'), ('<=', 'le'), ('>=', 'ge')]

#! Unary math function tables
#:set UNARY_DD_DD = ['abs', 'sqrt', 'sin', 'cos', 'tan', 'sinpi', 'cospi', 'tanpi', 'exp', 'expm1', 'log', 'log2', 'log10', 'log1p', 'atan', 'asin', 'acos', 'atanpi', 'asinpi', 'acospi', 'aint', 'anint', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh', 'erf', 'erfc', 'erfc_scaled', 'gamma', 'log_gamma', 'bessel_j0', 'bessel_j1', 'bessel_y0', 'bessel_y1', 'fraction', 'rrspacing', 'spacing', 'epsilon', 'huge', 'tiny']
#:set UNARY_CDD_CDD = ['sqrt', 'sin', 'sinpi', 'cos', 'cospi', 'tan', 'exp', 'expm1', 'log', 'log2', 'log10', 'log1p', 'atan', 'asin', 'acos', 'conjg', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh']
#:set UNARY_CDD_DD = ['abs', 'aimag']
#:set ALL_UNARY = sorted(set(UNARY_DD_DD + UNARY_CDD_CDD + UNARY_CDD_DD))

#! Binary real function tables
#:set BINARY_REAL = ['sign', 'mod', 'atan2', 'atan2pi', 'dim', 'modulo', 'hypot', 'nearest']
#:set BINARY_MINMAX = ['min', 'max']

#! Array reduction function tables
#:set ARRAY_REDUCE_VAL = ['maxval', 'minval']
#:set ARRAY_REDUCE_LOC = ['maxloc', 'minloc']
#:set ARRAY_REDUCE_SUM = ['sum', 'product']

#! Bessel functions with integer order
#:set BESSEL_N = ['bessel_jn', 'bessel_yn']

#! Functions: (dd, integer) → dd
#:set DD_INT_TO_DD = ['scale', 'set_exponent']

#! Inquiry functions
#:set INQUIRY_DD_INT = ['digits', 'maxexponent', 'minexponent', 'radix']
#:set INQUIRY_BOTH_INT = ['precision', 'range']

#! =====================================================================
#! Rank-generic helpers
#! =====================================================================
#:set MAX_RANK = 7
#:set COLONS = lambda r: ', '.join([':'] * r)
#:set SIZES = lambda r, v='array': (', &\n' + ' '*12).join(['size(%s,%d)' % (v, i) for i in range(1, r+1)]) if r > 4 else ', '.join(['size(%s,%d)' % (v, i) for i in range(1, r+1)])
#:set IDXS = lambda r: ', '.join(['i%d' % i for i in range(1, r+1)])
#:set IVARS = lambda r: ', '.join(['i%d' % i for i in range(1, r+1)])
#:set OUT_IDXS = lambda r, d: ', '.join(['i%d' % i for i in range(1, r+1) if i != d])
#:set SURVIVOR_DIMS = lambda r, d: [i for i in range(1, r+1) if i != d]
#:set DIM_REDUCED_SIZES = lambda r: (', &\n' + ' '*12).join(['merge(size(array,%d),size(array,%d),dim<=%d)' % (j+1,j,j) for j in range(1, r)])

#! Convert a Julia / C99 hex floating-point literal to a Fortran double
#! literal body via Python's float.fromhex + repr (round-trip exact).
#:set hex_dp = lambda h: repr(float.fromhex(h))
#:set hex_array = lambda lst: (', &\n        ').join([hex_dp(h) + '_dp' for h in lst])
#:set hex_array_padded = lambda lst, n: hex_array(lst + ['0x0p+0'] * (n - len(lst)))

#! Inline function: generate nested conversion loops
#:set conv_loops = lambda r, src, dst, func: '\n'.join(['        do i%d = 1, size(%s, %d)' % (d, src, d) for d in range(r, 0, -1)] + ['            %s(%s) = %s(%s(%s))' % (dst, IDXS(r), func, src, IDXS(r))] + ['        end do'] * r)

module multifloats
    use, intrinsic :: ieee_arithmetic, only: ieee_is_finite, ieee_is_nan, &
                                              ieee_value, ieee_quiet_nan,  &
                                              ieee_positive_inf, ieee_negative_inf
    use, intrinsic :: iso_fortran_env, only: int8, int16, int32, int64
    use, intrinsic :: iso_c_binding, only: c_double, c_int, c_int64_t, &
                                             c_ptr, c_loc
    implicit none
    private

    ! Wrap C's fma() as a pure elemental function. ieee_fma from
    ! ieee_arithmetic is impure in gfortran <= 12, so we bypass it.
    interface
        pure function c_fma(x, y, z) bind(c, name="fma")
            import :: c_double
            real(c_double), value, intent(in) :: x, y, z
            real(c_double) :: c_fma
        end function
    end interface

    ! C-ABI matmul kernels (defined in multifloats_math.cc). The Fortran
    ! float64x2 type has SEQUENCE layout [hi, lo] which is bit-compatible
    ! with the C float64x2_t struct, so we pass arrays by c_loc. The final
    ! renorm_interval arg mirrors DD_FMA_RENORM_INTERVAL (0 = off).
    interface
        pure subroutine c_dd_matmul_mm(a, b, c, m, k, n, ri) &
                bind(c, name="matmuldd_mm")
            import :: c_ptr, c_int64_t
            type(c_ptr), value, intent(in) :: a, b, c
            integer(c_int64_t), value, intent(in) :: m, k, n, ri
        end subroutine
        pure subroutine c_dd_matmul_mv(a, x, y, m, k, ri) &
                bind(c, name="matmuldd_mv")
            import :: c_ptr, c_int64_t
            type(c_ptr), value, intent(in) :: a, x, y
            integer(c_int64_t), value, intent(in) :: m, k, ri
        end subroutine
        pure subroutine c_dd_matmul_vm(x, b, y, k, n, ri) &
                bind(c, name="matmuldd_vm")
            import :: c_ptr, c_int64_t
            type(c_ptr), value, intent(in) :: x, b, y
            integer(c_int64_t), value, intent(in) :: k, n, ri
        end subroutine
    end interface

#:if defined('MULTIFLOATS_NO_QUAD')
#:set HAS_QUAD = False
#:else
#:set HAS_QUAD = True
#:endif
    integer, parameter :: dp = 8   ! Double precision
    integer, parameter :: sp = 4   ! Single precision
#:if HAS_QUAD
    integer, parameter :: qp = 16  ! Quad precision (not available on all compilers)
#:endif

    ! SEQUENCE is required so derived-type variables of these types may
    ! appear in EQUIVALENCE statements (used by some LAPACK routines
    ! such as DLALN2/wlaln2 to overlay 2x2 work arrays with linearized
    ! vectors).
    type, public :: float64x2
        sequence
        real(dp) :: limbs(2)
    end type float64x2

    type, public :: complex64x2
        sequence
        type(float64x2) :: re, im
    end type complex64x2

    ! ================================================================
    ! PUBLIC INTERFACE
    ! ================================================================

    ! ----------------------------------------------------------------
    ! Constructors
    ! ----------------------------------------------------------------

    interface float64x2
        module procedure dd_from_dd
        module procedure dd_from_dp
        module procedure dd_from_sp
        module procedure dd_from_int
        module procedure dd_from_i8
        module procedure dd_from_i16
        module procedure dd_from_i64
        module procedure dd_from_char
        module procedure dd_from_cdd
        module procedure dd_from_cdp
        module procedure dd_from_csp
    end interface float64x2

    interface complex64x2
        module procedure cdd_from_cdd
        ! Two-argument (re, im) constructors — matching kinds.
        module procedure cdd_from_dd_2
        module procedure cdd_from_dp_2
        module procedure cdd_from_sp_2
        module procedure cdd_from_int_2
        module procedure cdd_from_i8_2
        module procedure cdd_from_i16_2
        module procedure cdd_from_i64_2
        ! Two-argument (re, im) constructors — common mixed kinds.
        module procedure cdd_from_dd_dp_2
        module procedure cdd_from_dp_dd_2
        ! Single-argument constructors (imag = 0).
        module procedure cdd_from_dd_1
        module procedure cdd_from_dp_1
        module procedure cdd_from_sp_1
        module procedure cdd_from_int_1
        module procedure cdd_from_i8_1
        module procedure cdd_from_i16_1
        module procedure cdd_from_i64_1
        module procedure cdd_from_cdp_1
        module procedure cdd_from_csp_1
    end interface complex64x2

    ! ----------------------------------------------------------------
    ! Arithmetic operators (+, -, *, /)
    ! ----------------------------------------------------------------

#:for opsym, opname in ARITH_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('dd', 'cdd') or n2 in ('dd', 'cdd')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
#:if opsym == '-'
        module procedure dd_neg
        module procedure cdd_neg
#:endif
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ----------------------------------------------------------------
    ! Power operator (**)
    ! ----------------------------------------------------------------

    interface operator(**)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('dd', 'cdd') or n2 in ('dd', 'cdd')
        module procedure ${n1}$_pow_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(**)

    ! ----------------------------------------------------------------
    ! Equality comparison (==, /=) — all type pairs
    ! ----------------------------------------------------------------

#:for opsym, opname in EQ_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('dd', 'cdd') or n2 in ('dd', 'cdd')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ----------------------------------------------------------------
    ! Ordered comparison (<, >, <=, >=) — real types only
    ! ----------------------------------------------------------------

#:for opsym, opname in ORD_OPS
    interface operator(${opsym}$)
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'dd' or n2 == 'dd'
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ----------------------------------------------------------------
    ! Unary math generics
    ! ----------------------------------------------------------------

#:for func in ALL_UNARY
    interface ${func}$
#:if func in UNARY_DD_DD
        module procedure dd_${func}$
#:endif
#:if func in UNARY_CDD_CDD or func in UNARY_CDD_DD
        module procedure cdd_${func}$
#:endif
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Binary real functions (sign, mod, atan2, dim, modulo, hypot, nearest)
    ! ----------------------------------------------------------------

#:for func in BINARY_REAL
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'dd' or n2 == 'dd'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: ${func}$

#:endfor
#:set MINMAX_NARG = [3, 4, 5, 6, 7, 8]
#:for func in BINARY_MINMAX
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'dd' or n2 == 'dd'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
#:for n in MINMAX_NARG
        module procedure dd_${func}$${n}$
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: value (maxval, minval)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_VAL
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure dd_${func}$_${rank}$d
        module procedure dd_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: location (maxloc, minloc)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_LOC
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure dd_${func}$_${rank}$d
        module procedure dd_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: sum, product (dd + cdd)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_SUM
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure dd_${func}$_${rank}$d
        module procedure dd_${func}$_${rank}$d_dim
        module procedure cdd_${func}$_${rank}$d
        module procedure cdd_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! dot_product, norm2, findloc, matmul
    ! ----------------------------------------------------------------

    interface dot_product
        module procedure dd_dot_product
        module procedure cdd_dot_product
    end interface
    public :: dot_product

    interface norm2
#:for rank in range(1, MAX_RANK+1)
        module procedure dd_norm2_${rank}$d
#:if rank > 1
        module procedure dd_norm2_${rank}$d_dim
#:endif
#:endfor
    end interface
    public :: norm2

    interface findloc
#:for rank in range(1, MAX_RANK+1)
        module procedure dd_findloc_${rank}$d
        module procedure dd_findloc_${rank}$d_dim
        module procedure cdd_findloc_${rank}$d
        module procedure cdd_findloc_${rank}$d_dim
#:endfor
    end interface
    public :: findloc

    interface matmul
        module procedure dd_matmul_mm
        module procedure dd_matmul_mv
        module procedure dd_matmul_vm
        module procedure cdd_matmul_mm
        module procedure cdd_matmul_mv
        module procedure cdd_matmul_vm
    end interface
    public :: matmul

    ! ----------------------------------------------------------------
    ! Bessel functions with integer order
    ! ----------------------------------------------------------------

#:for func in BESSEL_N
    interface ${func}$
        module procedure dd_${func}$_elem
        module procedure dd_${func}$_range
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Conversions and numeric functions
    ! ----------------------------------------------------------------

    interface ceiling
        module procedure dd_ceiling
    end interface
    public :: ceiling

    interface floor
        module procedure dd_floor
    end interface
    public :: floor

    interface exponent
        module procedure dd_exponent
    end interface
    public :: exponent

#:for func in DD_INT_TO_DD
    interface ${func}$
        module procedure dd_${func}$
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Numeric inquiry functions
    ! ----------------------------------------------------------------

#:for func in INQUIRY_DD_INT
    interface ${func}$
        module procedure dd_${func}$
    end interface
    public :: ${func}$

#:endfor
#:for func in INQUIRY_BOTH_INT
    interface ${func}$
        module procedure dd_${func}$
        module procedure cdd_${func}$
    end interface
    public :: ${func}$

#:endfor
    interface storage_size
        module procedure dd_storage_size
        module procedure cdd_storage_size
    end interface
    public :: storage_size

    ! ----------------------------------------------------------------
    ! Complex-specific: cmplx, real, dd_real
    ! ----------------------------------------------------------------

    interface cmplx
        module procedure dd_cmplx_2
        module procedure dd_cmplx_1
    end interface
    public :: cmplx

    interface real
        module procedure cdd_real
        module procedure dd_real_dd
    end interface
    public :: real

    interface dd_real
        module procedure dd_real_dd
        module procedure cdd_real_dd
    end interface
    public :: dd_real

    ! ----------------------------------------------------------------
    ! Conversions: dble, int, nint, dd_to_double
    ! ----------------------------------------------------------------

    interface dble
        module procedure dd_dble
    end interface
    public :: dble

    interface int
        module procedure dd_int
    end interface
    public :: int

    interface nint
        module procedure dd_nint
    end interface
    public :: nint

    public :: dd_to_double

    ! ----------------------------------------------------------------
    ! Fused sincos / sinhcosh
    ! ----------------------------------------------------------------

    interface sincos
        module procedure dd_sincos
    end interface
    public :: sincos

    interface sinhcosh
        module procedure dd_sinhcosh
    end interface
    public :: sinhcosh

    ! ----------------------------------------------------------------
    ! random_number (impure subroutine)
    ! ----------------------------------------------------------------

    interface random_number
        module procedure dd_random_number_0d
#:for rank in range(1, MAX_RANK+1)
        module procedure dd_random_number_${rank}$d
#:endfor
    end interface
    public :: random_number
    public :: dd_set_fma_renorm_interval

    ! ----------------------------------------------------------------
    ! Assignment (=)
    ! ----------------------------------------------------------------

    interface assignment(=)
        ! lhs = dd / cdd (forward direction: build a multifloat type)
#:for n, _ in ATYPES
#:if n != 'dd'
        module procedure dd_assign_${n}$
#:endif
#:endfor
#:for n, _ in ATYPES
#:if n != 'cdd'
        module procedure cdd_assign_${n}$
#:endif
#:endfor
        ! Non-default integer kinds → dd / cdd
        module procedure dd_assign_i8
        module procedure dd_assign_i16
        module procedure dd_assign_i64
        module procedure cdd_assign_i8
        module procedure cdd_assign_i16
        module procedure cdd_assign_i64
        ! dd → built-in numeric types
        module procedure dp_assign_dd
        module procedure sp_assign_dd
        module procedure int_assign_dd
        module procedure i8_assign_dd
        module procedure i16_assign_dd
        module procedure i64_assign_dd
        module procedure cdp_assign_dd
        module procedure csp_assign_dd
        ! cdd → built-in numeric types
        module procedure dp_assign_cdd
        module procedure sp_assign_cdd
        module procedure int_assign_cdd
        module procedure i8_assign_cdd
        module procedure i16_assign_cdd
        module procedure i64_assign_cdd
        module procedure cdp_assign_cdd
        module procedure csp_assign_cdd
    end interface
    public :: assignment(=)

    ! ----------------------------------------------------------------
    ! Defined I/O
    ! ----------------------------------------------------------------

    interface write(formatted)
        module procedure write_dd_formatted
        module procedure write_cdd_formatted
    end interface
    public :: write(formatted)

    interface read(formatted)
        module procedure read_dd_formatted
        module procedure read_cdd_formatted
    end interface
    public :: read(formatted)

    ! ----------------------------------------------------------------
    ! Named constants
    ! ----------------------------------------------------------------

    ! Named constants — using component initialization for portability
    ! (flang does not support sequence-type structure constructors in
    ! constant expressions).
#:def DD_CONST(name, val)
    type(float64x2), parameter, public :: ${name}$ = &
        float64x2(limbs=[${val}$, 0.0_dp])
#:enddef
    $:DD_CONST('DD_ZERO',   '0.0_dp')
    $:DD_CONST('DD_ONE',    '1.0_dp')
    $:DD_CONST('DD_TWO',    '2.0_dp')
    $:DD_CONST('DD_HALF',   '0.5_dp')
    $:DD_CONST('DD_EIGHT',  '8.0_dp')
    $:DD_CONST('DD_SAFMIN', '2.2250738585072014e-308_dp')
    $:DD_CONST('DD_SAFMAX', '1.7976931348623157e+308_dp')
    $:DD_CONST('DD_TSML',   '1.0e-100_dp')
    $:DD_CONST('DD_TBIG',   '1.0e+100_dp')
    $:DD_CONST('DD_SSML',   '1.0e-50_dp')
    $:DD_CONST('DD_SBIG',   '1.0e+50_dp')
    $:DD_CONST('DD_RTMIN',  '1.0e-150_dp')
    $:DD_CONST('DD_RTMAX',  '1.0e+150_dp')

    ! Renormalization interval for fused multiply-accumulate reductions
    ! (dot_product, matmul). The accumulator s_lo drifts by ~1 ulp per
    ! iteration; renormalizing every DD_FMA_RENORM_INTERVAL steps keeps
    ! worst-case error within ~1e-31 (full DD). Set to 0 to disable
    ! periodic renormalization (single renorm at the end only).
    !
    ! Empirical sweep (random-input 4×k · k×4 matmul, max_rel vs qp ref):
    !    k      ri=0      ri=4      ri=8      ri=16     ri=32     ri=64
    !   16    1.2e-31   3.3e-32   3.3e-32   1.2e-31   1.2e-31   1.2e-31
    !   64    2.9e-31   2.9e-31   2.9e-31   2.9e-31   2.9e-31   2.9e-31
    !   1k    3.2e-29   1.7e-29   4.9e-30   1.2e-29   7.6e-30   3.3e-30
    !   16k   4.8e-29   2.9e-29   1.5e-29   3.6e-29   5.3e-29   1.5e-28
    !   65k   1.5e-28   1.6e-29   3.2e-30   6.9e-30   1.2e-29   1.5e-29
    ! ri=8 is a good default: ~50× better than ri=0 at k=65k, with only
    ! ~3-4% overhead (vs ri=4 which runs 40-70% slower at large k).
    ! Tune via `dd_set_fma_renorm_interval`:
    !   - k < 100  : ri=0 is fine (no measurable precision gain from ri>0).
    !   - 100 < k < 10000 : any ri in [8, 32] works; default 8 is safe.
    !   - k > 10000 : ri=8 is near-optimal; avoid ri>32 which lets s_lo
    !     grow enough to alias off significant bits.
    integer, public, protected :: DD_FMA_RENORM_INTERVAL = 8

    ! ================================================================
    ! MODULE DATA, CONSTANTS & C-ABI INTERFACES
    ! ================================================================

    ! ----------------------------------------------------------------
    ! C-ABI interfaces for DD math kernels (defined in src/multifloats_math.cc).
    ! The Fortran wrappers below each delegate to one of these, keeping the
    ! algorithmic implementation single-sourced in C++.
    ! ----------------------------------------------------------------
    type, bind(c) :: float64x2_t
        real(c_double) :: hi, lo
    end type float64x2_t

    type, bind(c) :: complex64x2_t
        type(float64x2_t) :: re, im
    end type complex64x2_t

#! Complex DD transcendentals delegated to C c*dd kernels. Function names
#! are uniform so no map is needed — the Fortran-side name is always
#! `cdd_<func>`, the C symbol is always `c<func>dd`.
#:set C_DELEGATE_CX_UNARY_FUNCS = ['sqrt', 'exp', 'expm1', 'log', 'log2',      &
    'log10', 'log1p', 'sin', 'sinpi', 'cos', 'cospi', 'tan', 'asin', 'acos',  &
    'atan', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh']

#! Complex DD arithmetic delegated to C. Name mapping same as unary
#! transcendentals: fypp `add` → C `cadddd`, etc.
#:set C_DELEGATE_CX_BINARY_FUNCS = ['add', 'sub', 'mul', 'div']

#! (fortran_full_name, c_symbol) pairs for DD math kernels implemented in
#! src/multifloats_math.cc. The Fortran side exposes these as elemental
#! wrappers generated by C_DELEGATE_UNARY / C_DELEGATE_BINARY below, so the
#! algorithm lives in C++ only.
#:set C_DELEGATE_UNARY_MAP = [ &
    ('dd_sqrt_full',      'sqrtdd'),   &
    ('dd_trunc_full',     'truncdd'),  &
    ('dd_round_full',     'rounddd'),  &
    ('dd_exp2_full',      'exp2dd'),   &
    ('dd_exp_full',       'expdd'),    &
    ('dd_expm1_full',     'expm1dd'),  &
    ('dd_log2_full',      'log2dd'),   &
    ('dd_log_full',       'logdd'),    &
    ('dd_log10_full',     'log10dd'),  &
    ('dd_log1p_full',     'log1pdd'),  &
    ('dd_sin_full',       'sindd'),    &
    ('dd_cos_full',       'cosdd'),    &
    ('dd_tan_full',       'tandd'),    &
    ('dd_asin_full',      'asindd'),   &
    ('dd_acos_full',      'acosdd'),   &
    ('dd_atan_full',      'atandd'),   &
    ('dd_sinpi_full',     'sinpidd'),  &
    ('dd_cospi_full',     'cospidd'),  &
    ('dd_tanpi_full',     'tanpidd'),  &
    ('dd_asinpi_full',    'asinpidd'), &
    ('dd_acospi_full',    'acospidd'), &
    ('dd_atanpi_full',    'atanpidd'), &
    ('dd_sinh_full',      'sinhdd'),   &
    ('dd_cosh_full',      'coshdd'),   &
    ('dd_tanh_full',      'tanhdd'),   &
    ('dd_asinh_full',     'asinhdd'),  &
    ('dd_acosh_full',     'acoshdd'),  &
    ('dd_atanh_full',     'atanhdd'),  &
    ('dd_erf_full',         'erfdd'),    &
    ('dd_erfc_full',        'erfcdd'),   &
    ('dd_erfc_scaled_full', 'erfcxdd'),  &
    ('dd_gamma_full',     'tgammadd'), &
    ('dd_log_gamma_full', 'lgammadd'), &
    ('dd_bessel_j0_full', 'j0dd'),     &
    ('dd_bessel_j1_full', 'j1dd'),     &
    ('dd_bessel_y0_full', 'y0dd'),     &
    ('dd_bessel_y1_full', 'y1dd') ]
#:set C_DELEGATE_BINARY_MAP = [ &
    ('dd_atan2_full',   'atan2dd'),   &
    ('dd_atan2pi_full', 'atan2pidd'), &
    ('dd_hypot_full',   'hypotdd'),   &
    ('dd_fmod_full',    'fmoddd'),    &
    ('dd_pow_full',     'powdd') ]

    interface
#:for _ffull, csym in C_DELEGATE_UNARY_MAP
        pure type(float64x2_t) function c_${csym}$(a) bind(c, name='${csym}$')
            import :: float64x2_t; type(float64x2_t), value, intent(in) :: a
        end function
#:endfor
#:for _ffull, csym in C_DELEGATE_BINARY_MAP
        pure type(float64x2_t) function c_${csym}$(a, b) bind(c, name='${csym}$')
            import :: float64x2_t; type(float64x2_t), value, intent(in) :: a, b
        end function
#:endfor
#:for func in C_DELEGATE_CX_UNARY_FUNCS
        pure type(complex64x2_t) function c_dd_cdd_${func}$(a) bind(c, name='c${func}$dd')
            import :: complex64x2_t; type(complex64x2_t), value, intent(in) :: a
        end function
#:endfor
#:for func in C_DELEGATE_CX_BINARY_FUNCS
        pure type(complex64x2_t) function c_dd_cdd2_${func}$(a, b) bind(c, name='c${func}$dd')
            import :: complex64x2_t; type(complex64x2_t), value, intent(in) :: a, b
        end function
#:endfor
        ! Integer-exponent power: exponent comes in as a plain C int, so
        ! the delegate map shape (dd, dd)->dd doesn't fit — declare by hand.
        pure type(float64x2_t) function c_dd_powi(a, n) bind(c, name='powidd')
            import :: float64x2_t, c_int
            type(float64x2_t), value, intent(in) :: a
            integer(c_int), value, intent(in) :: n
        end function
        ! Integer-order Bessel (recurrence in C++; seeded by j0dd/j1dd/y0dd/y1dd).
        pure type(float64x2_t) function c_dd_jn(n, a) bind(c, name='jndd')
            import :: float64x2_t, c_int
            integer(c_int), value, intent(in) :: n
            type(float64x2_t), value, intent(in) :: a
        end function
        pure type(float64x2_t) function c_dd_yn(n, a) bind(c, name='yndd')
            import :: float64x2_t, c_int
            integer(c_int), value, intent(in) :: n
            type(float64x2_t), value, intent(in) :: a
        end function
        pure subroutine c_dd_jn_range(n1, n2, a, out) bind(c, name='jndd_range')
            import :: float64x2_t, c_int
            integer(c_int), value, intent(in) :: n1, n2
            type(float64x2_t), value, intent(in) :: a
            type(float64x2_t), intent(out) :: out(*)
        end subroutine
        pure subroutine c_dd_yn_range(n1, n2, a, out) bind(c, name='yndd_range')
            import :: float64x2_t, c_int
            integer(c_int), value, intent(in) :: n1, n2
            type(float64x2_t), value, intent(in) :: a
            type(float64x2_t), intent(out) :: out(*)
        end subroutine
        ! Fused sin/cos and sinh/cosh: one range-reduction feeds both outputs.
        pure subroutine c_dd_sincos(a, s, c) bind(c, name='sincosdd')
            import :: float64x2_t
            type(float64x2_t), value, intent(in) :: a
            type(float64x2_t), intent(out) :: s, c
        end subroutine
        pure subroutine c_dd_sinhcosh(a, s, c) bind(c, name='sinhcoshdd')
            import :: float64x2_t
            type(float64x2_t), value, intent(in) :: a
            type(float64x2_t), intent(out) :: s, c
        end subroutine
    end interface

#! Elemental wrapper: Fortran `ffull(x)` → C `csym(float64x2_t)`.
#:def C_DELEGATE_UNARY(ffull, csym)
    elemental function ${ffull}$(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        type(float64x2_t) :: r
        r = c_${csym}$(float64x2_t(x%limbs(1), x%limbs(2)))
        res%limbs = [r%hi, r%lo]
    end function
#:enddef

#! Elemental wrapper: Fortran `ffull(a, b)` → C `csym(float64x2_t, float64x2_t)`.
#:def C_DELEGATE_BINARY(ffull, csym)
    elemental function ${ffull}$(a, b) result(res)
        type(float64x2), intent(in) :: a, b
        type(float64x2) :: res
        type(float64x2_t) :: r
        r = c_${csym}$(float64x2_t(a%limbs(1), a%limbs(2)), float64x2_t(b%limbs(1), b%limbs(2)))
        res%limbs = [r%hi, r%lo]
    end function
#:enddef

contains

    ! ================================================================
    ! PROCEDURE IMPLEMENTATIONS
    ! ================================================================

    ! ----------------------------------------------------------------
    ! Internal conversion helpers (elemental)
    ! ----------------------------------------------------------------

#:if HAS_QUAD
    elemental function to_qp(dd) result(res)
        type(float64x2), intent(in) :: dd
        real(qp) :: res
        res = real(dd%limbs(1), qp) + real(dd%limbs(2), qp)
    end function

    elemental function from_qp(v) result(res)
        real(qp), intent(in) :: v
        type(float64x2) :: res
        real(dp) :: s, bprime
        if (.not. ieee_is_finite(v)) then
            res%limbs = [real(v, dp), 0.0_dp]
        else
            res%limbs(1) = real(v, dp)
            res%limbs(2) = real(v - real(res%limbs(1), qp), dp)
            s = res%limbs(1) + res%limbs(2)
            bprime = s - res%limbs(1)
            res%limbs(2) = res%limbs(2) - bprime
            res%limbs(1) = s
        end if
    end function

    elemental function to_cqp(cdd) result(res)
        type(complex64x2), intent(in) :: cdd
        complex(qp) :: res
        res = cmplx(to_qp(cdd%re), to_qp(cdd%im), kind=qp)
    end function

    elemental function from_cqp(v) result(res)
        complex(qp), intent(in) :: v
        type(complex64x2) :: res
        res%re = from_qp(real(v, qp))
        res%im = from_qp(aimag(v))
    end function
#:endif

    ! ----------------------------------------------------------------
    ! Constructors
    ! ----------------------------------------------------------------

    elemental function dd_from_dd(v) result(res)
        type(float64x2), intent(in) :: v
        type(float64x2) :: res
        res = v
    end function

    elemental function dd_from_dp(v) result(res)
        real(dp), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [v, 0.0_dp]
    end function

    elemental function dd_from_sp(v) result(res)
        real(sp), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function dd_from_int(v) result(res)
        integer, intent(in) :: v
        type(float64x2) :: res
        ! Default integer kind is 32-bit and fits exactly in dp.
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function dd_from_i8(v) result(res)
        integer(int8), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function dd_from_i16(v) result(res)
        integer(int16), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function dd_from_i64(v) result(res)
        integer(int64), intent(in) :: v
        type(float64x2) :: res
        ! int64 → dp may lose the bottom 11 bits when |v| >= 2^53.
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    function dd_from_char(v) result(res)
        character(len=*), intent(in) :: v
        type(float64x2) :: res
#:if HAS_QUAD
        real(qp) :: val_qp
        read(v, *) val_qp
        res = from_qp(val_qp)
#:else
        ! Without quad precision, parse to double (loses low limb).
        read(v, *) res%limbs(1)
        res%limbs(2) = 0.0_dp
#:endif
    end function

    elemental function dd_from_cdd(cdd) result(res)
        type(complex64x2), intent(in) :: cdd
        type(float64x2) :: res
        res = cdd%re
    end function

    elemental function dd_from_cdp(x) result(res)
        complex(dp), intent(in) :: x
        type(float64x2) :: res
        res%limbs = [real(x, dp), 0.0_dp]
    end function

    elemental function dd_from_csp(x) result(res)
        complex(sp), intent(in) :: x
        type(float64x2) :: res
        res%limbs = [real(real(x, sp), dp), 0.0_dp]
    end function

    elemental function cdd_from_cdd(v) result(res)
        type(complex64x2), intent(in) :: v
        type(complex64x2) :: res
        res = v
    end function

    elemental function cdd_from_dd_2(r, i) result(res)
        type(float64x2), intent(in) :: r, i
        type(complex64x2) :: res
        res%re = r
        res%im = i
    end function

    elemental function cdd_from_dp_2(r, i) result(res)
        real(dp), intent(in) :: r, i
        type(complex64x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im%limbs = [i, 0.0_dp]
    end function

    elemental function cdd_from_dd_1(r) result(res)
        type(float64x2), intent(in) :: r
        type(complex64x2) :: res
        res%re = r
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_from_dp_1(r) result(res)
        real(dp), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    ! Two-argument matching-kind constructors for the remaining real /
    ! integer kinds. Each promotes both operands to dp before storing.

    elemental function cdd_from_sp_2(r, i) result(res)
        real(sp), intent(in) :: r, i
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cdd_from_int_2(r, i) result(res)
        integer, intent(in) :: r, i
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cdd_from_i8_2(r, i) result(res)
        integer(int8), intent(in) :: r, i
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cdd_from_i16_2(r, i) result(res)
        integer(int16), intent(in) :: r, i
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cdd_from_i64_2(r, i) result(res)
        integer(int64), intent(in) :: r, i
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    ! Mixed (dd, dp) and (dp, dd) — common when one part has been
    ! computed in DD and the other is still a literal double.

    elemental function cdd_from_dd_dp_2(r, i) result(res)
        type(float64x2), intent(in) :: r
        real(dp), intent(in) :: i
        type(complex64x2) :: res
        res%re = r
        res%im%limbs = [i, 0.0_dp]
    end function

    elemental function cdd_from_dp_dd_2(r, i) result(res)
        real(dp), intent(in) :: r
        type(float64x2), intent(in) :: i
        type(complex64x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im = i
    end function

    ! Single-argument constructors for the remaining numeric kinds
    ! (imag set to 0).

    elemental function cdd_from_sp_1(r) result(res)
        real(sp), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_from_int_1(r) result(res)
        integer, intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_from_i8_1(r) result(res)
        integer(int8), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_from_i16_1(r) result(res)
        integer(int16), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_from_i64_1(r) result(res)
        integer(int64), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_from_cdp_1(r) result(res)
        complex(dp), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [aimag(r), 0.0_dp]
    end function

    elemental function cdd_from_csp_1(r) result(res)
        complex(sp), intent(in) :: r
        type(complex64x2) :: res
        res%re%limbs = [real(real(r, sp), dp), 0.0_dp]
        res%im%limbs = [real(aimag(r), dp), 0.0_dp]
    end function

    ! ----------------------------------------------------------------
    ! Assignment (elemental)
    ! ----------------------------------------------------------------

#:for n, d in ATYPES
#:if n != 'dd'
    elemental subroutine dd_assign_${n}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if n == 'dp'
        lhs%limbs = [rhs, 0.0_dp]
#:elif n == 'sp'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'int'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'cdd'
        lhs = rhs%re
#:elif n == 'cdp'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'csp'
        lhs%limbs = [real(real(rhs, sp), dp), 0.0_dp]
#:endif
    end subroutine

#:endif
#:endfor
#:for n, d in ATYPES
#:if n != 'cdd'
    elemental subroutine cdd_assign_${n}$(lhs, rhs)
        type(complex64x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if n == 'dd'
        lhs%re = rhs
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'dp'
        lhs%re%limbs = [rhs, 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'sp'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'int'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'cdp'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [aimag(rhs), 0.0_dp]
#:elif n == 'csp'
        lhs%re%limbs = [real(real(rhs, sp), dp), 0.0_dp]
        lhs%im%limbs = [real(aimag(rhs), dp), 0.0_dp]
#:endif
    end subroutine

#:endif
#:endfor
    ! ----------------------------------------------------------------
    ! Non-default integer kinds → dd / cdd
    ! ----------------------------------------------------------------

#:for ksuf, ktype in [('i8', 'integer(int8)'), ('i16', 'integer(int16)'), ('i64', 'integer(int64)')]
    elemental subroutine dd_assign_${ksuf}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${ktype}$, intent(in) :: rhs
        lhs%limbs = [real(rhs, dp), 0.0_dp]
    end subroutine

    elemental subroutine cdd_assign_${ksuf}$(lhs, rhs)
        type(complex64x2), intent(out) :: lhs
        ${ktype}$, intent(in) :: rhs
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! dd → built-in numeric types (truncation for integer kinds, mirrors
    ! the same semantics as `int_var = real_dp_var` in plain Fortran).
    ! ----------------------------------------------------------------

    elemental subroutine dp_assign_dd(lhs, rhs)
        real(dp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = rhs%limbs(1)
    end subroutine

    elemental subroutine sp_assign_dd(lhs, rhs)
        real(sp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = real(rhs%limbs(1), sp)
    end subroutine

    elemental subroutine cdp_assign_dd(lhs, rhs)
        complex(dp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = cmplx(rhs%limbs(1), 0.0_dp, dp)
    end subroutine

    elemental subroutine csp_assign_dd(lhs, rhs)
        complex(sp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = cmplx(real(rhs%limbs(1), sp), 0.0_sp, sp)
    end subroutine

#:for ksuf, ktype, klit in [('int', 'integer', 'int32'), ('i8', 'integer(int8)', 'int8'), ('i16', 'integer(int16)', 'int16'), ('i64', 'integer(int64)', 'int64')]
    elemental subroutine ${ksuf}$_assign_dd(lhs, rhs)
        ${ktype}$, intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        real(dp) :: hi
        hi = rhs%limbs(1)
        lhs = int(hi, kind(lhs))
        ! Adjust toward zero when the leading limb is exactly an integer
        ! and the lo limb pushes the true value across the boundary.
        if (hi == real(lhs, dp)) then
            if (lhs > 0 .and. rhs%limbs(2) < 0.0_dp) lhs = lhs - 1_${klit}$
            if (lhs < 0 .and. rhs%limbs(2) > 0.0_dp) lhs = lhs + 1_${klit}$
        end if
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! cdd → built-in numeric types (real types take the real part;
    ! integer kinds truncate the real part toward zero).
    ! ----------------------------------------------------------------

    elemental subroutine dp_assign_cdd(lhs, rhs)
        real(dp), intent(out) :: lhs
        type(complex64x2), intent(in) :: rhs
        lhs = rhs%re%limbs(1)
    end subroutine

    elemental subroutine sp_assign_cdd(lhs, rhs)
        real(sp), intent(out) :: lhs
        type(complex64x2), intent(in) :: rhs
        lhs = real(rhs%re%limbs(1), sp)
    end subroutine

    elemental subroutine cdp_assign_cdd(lhs, rhs)
        complex(dp), intent(out) :: lhs
        type(complex64x2), intent(in) :: rhs
        lhs = cmplx(rhs%re%limbs(1), rhs%im%limbs(1), dp)
    end subroutine

    elemental subroutine csp_assign_cdd(lhs, rhs)
        complex(sp), intent(out) :: lhs
        type(complex64x2), intent(in) :: rhs
        lhs = cmplx(real(rhs%re%limbs(1), sp), real(rhs%im%limbs(1), sp), sp)
    end subroutine

#:for ksuf, ktype, klit in [('int', 'integer', 'int32'), ('i8', 'integer(int8)', 'int8'), ('i16', 'integer(int16)', 'int16'), ('i64', 'integer(int64)', 'int64')]
    elemental subroutine ${ksuf}$_assign_cdd(lhs, rhs)
        ${ktype}$, intent(out) :: lhs
        type(complex64x2), intent(in) :: rhs
        real(dp) :: hi
        hi = rhs%re%limbs(1)
        lhs = int(hi, kind(lhs))
        if (hi == real(lhs, dp)) then
            if (lhs > 0 .and. rhs%re%limbs(2) < 0.0_dp) lhs = lhs - 1_${klit}$
            if (lhs < 0 .and. rhs%re%limbs(2) > 0.0_dp) lhs = lhs + 1_${klit}$
        end if
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! Conversions (elemental)
    ! ----------------------------------------------------------------

    elemental function dd_dble(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        ! For a normalized DD, |lo| <= ulp(hi)/2, so the round-to-nearest
        ! double of hi+lo is exactly hi.
        res = x%limbs(1)
    end function

    elemental function dd_int(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = int(hi)
        if (hi == real(res, dp)) then
            ! hi is exactly an integer; the lo limb determines whether
            ! the true value crosses an integer boundary toward zero.
            if (res > 0 .and. x%limbs(2) < 0.0_dp) res = res - 1
            if (res < 0 .and. x%limbs(2) > 0.0_dp) res = res + 1
        end if
    end function

    elemental function dd_nint(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi, lo, diff
        ! Two half-integer hazards that hi alone misses:
        !   (1) hi is itself a half-integer (nint rounds away from zero);
        !       if lo has the opposite sign, the TRUE DD value falls on
        !       the near side of the integer boundary and we over-rounded.
        !   (2) hi is an exact integer and |lo| > 1/2 (possible once
        !       ulp(hi) >= 1, i.e. |hi| >= 2^53); lo pushes the true
        !       value past the next integer boundary.
        ! Mirrors the detail::lround_adjust template in multifloats.h.
        hi = x%limbs(1)
        lo = x%limbs(2)
        res = nint(hi)
        diff = hi - real(res, dp)
        if (diff == 0.0_dp) then
            if (lo > 0.5_dp) then
                res = res + 1
            else if (lo < -0.5_dp) then
                res = res - 1
            else if (lo == 0.5_dp .and. hi >= 0.0_dp) then
                res = res + 1
            else if (lo == -0.5_dp .and. hi <= 0.0_dp) then
                res = res - 1
            end if
        else if (diff == -0.5_dp .and. lo < 0.0_dp) then
            res = res - 1
        else if (diff == 0.5_dp .and. lo > 0.0_dp) then
            res = res + 1
        end if
    end function

    elemental function dd_to_double(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        res = x%limbs(1)
    end function

    elemental function dd_ceiling(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = ceiling(hi)
        if (hi == real(res, dp) .and. x%limbs(2) > 0.0_dp) res = res + 1
    end function

    elemental function dd_floor(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = floor(hi)
        if (hi == real(res, dp) .and. x%limbs(2) < 0.0_dp) res = res - 1
    end function

    elemental function dd_exponent(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = exponent(x%limbs(1))
    end function

    ! ----------------------------------------------------------------
    ! Unary operators (elemental)
    ! ----------------------------------------------------------------

    ! ----------------------------------------------------------------
    ! Error-free transforms, mirrored from include/multifloats.h
    ! (detail::two_sum / fast_two_sum / two_prod). Inlined in every
    ! arithmetic kernel below, so algorithms stay bit-identical to the
    ! C++ operators in float64x2.
    ! ----------------------------------------------------------------

    pure subroutine two_sum(a, b, s, e)
        real(dp), intent(in)  :: a, b
        real(dp), intent(out) :: s, e
        real(dp) :: ap, bp
        s = a + b
        ap = s - b
        bp = s - ap
        e = (a - ap) + (b - bp)
    end subroutine

    pure subroutine fast_two_sum(a, b, s, e)
        real(dp), intent(in)  :: a, b
        real(dp), intent(out) :: s, e
        real(dp) :: bp
        s = a + b
        bp = s - a
        e = b - bp
    end subroutine

    pure subroutine two_prod(a, b, p, e)
        real(dp), intent(in)  :: a, b
        real(dp), intent(out) :: p, e
        p = a * b
        e = c_fma(a, b, -p)
    end subroutine

    ! DD signbit — matches C++ multifloats::signbit: looks at the first
    ! nonzero limb, falling back to the hi limb when both limbs are
    ! (possibly signed) zero. Needed so non-canonical DDs like (+0, -eps)
    ! resolve their sign correctly in abs / copysign.
    elemental function dd_signbit(x) result(res)
        type(float64x2), intent(in) :: x
        logical :: res
        real(dp) :: pivot
        if (x%limbs(1) /= 0.0_dp) then
            pivot = x%limbs(1)
        else if (x%limbs(2) /= 0.0_dp) then
            pivot = x%limbs(2)
        else
            pivot = x%limbs(1)
        end if
        res = sign(1.0_dp, pivot) < 0.0_dp
    end function

    elemental function dd_neg(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res%limbs = -x%limbs
    end function

    elemental function cdd_neg(x) result(res)
        type(complex64x2), intent(in) :: x
        type(complex64x2) :: res
        res%re%limbs = -x%re%limbs
        res%im%limbs = -x%im%limbs
    end function

    ! ----------------------------------------------------------------
    ! Thin wrappers around the DD math kernels in src/multifloats_math.cc.
    ! The algorithmic implementation is single-sourced in C++; Fortran
    ! delegates via the C-ABI declarations at the top of this module.
    ! ----------------------------------------------------------------
#:for ffull, csym in C_DELEGATE_UNARY_MAP
$:C_DELEGATE_UNARY(ffull, csym)
#:endfor
#:for ffull, csym in C_DELEGATE_BINARY_MAP
$:C_DELEGATE_BINARY(ffull, csym)
#:endfor

    ! ----------------------------------------------------------------
    ! Unary math: dd → dd (elemental)
    ! ----------------------------------------------------------------

#:for func in UNARY_DD_DD
    elemental function dd_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
#:if func == 'abs'
        ! Match C++ multifloats::fabs: resolve the sign via the first
        ! nonzero limb; if every limb is a (possibly signed) zero,
        ! return canonical +0 so abs(-0.0) = +0.0 as IEEE expects.
        if (x%limbs(1) == 0.0_dp .and. x%limbs(2) == 0.0_dp) then
            res = DD_ZERO
        else if (dd_signbit(x)) then
            res%limbs = -x%limbs
        else
            res = x
        end if
#:elif func == 'sqrt'
        res = dd_sqrt_full(x)
#:elif func == 'aint'
        res = dd_trunc_full(x)
#:elif func == 'anint'
        res = dd_round_full(x)
#:elif func == 'fraction'
        block
            integer :: e
            if (x%limbs(1) == 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                e = exponent(x%limbs(1))
                res%limbs(1) = scale(x%limbs(1), -e)
                res%limbs(2) = scale(x%limbs(2), -e)
            end if
        end block
#:elif func == 'tiny' or func == 'huge' or func == 'epsilon'
        ! Inquiry constants: derive from the underlying double, not via
        ! quad precision (which under/overflows when stored back as dp).
#:if func == 'tiny'
        res%limbs = [tiny(0.0_dp), 0.0_dp]
#:elif func == 'huge'
        res%limbs = [huge(0.0_dp), 0.0_dp]
#:else
        ! epsilon for double-double is roughly 2^-105 (one ulp at the lo
        ! limb of 1.0).
        res%limbs = [scale(epsilon(0.0_dp), -53), 0.0_dp]
#:endif
#:elif func == 'spacing'
        ! DD spacing: distance to the next representable double-double.
        ! For a normalized DD whose hi limb is x[0], the next DD differs
        ! in the lo limb by ulp(x[0]) * 2^-53, which is spacing(x[0]) / 2^53.
        res%limbs = [scale(spacing(x%limbs(1)), -53), 0.0_dp]
#:elif func == 'rrspacing'
        ! rrspacing(x) = |x| / spacing(x). Compute against the DD spacing
        ! so the result is consistent with dd_spacing above.
        res%limbs = [abs(x%limbs(1)) / scale(spacing(x%limbs(1)), -53), 0.0_dp]
#:elif func == 'exp'
        res = dd_exp_full(x)
#:elif func == 'expm1'
        res = dd_expm1_full(x)
#:elif func == 'log'
        res = dd_log_full(x)
#:elif func == 'log2'
        res = dd_log2_full(x)
#:elif func == 'log10'
        res = dd_log10_full(x)
#:elif func == 'log1p'
        res = dd_log1p_full(x)
#:elif func == 'sin'
        res = dd_sin_full(x)
#:elif func == 'cos'
        res = dd_cos_full(x)
#:elif func == 'sinpi'
        res = dd_sinpi_full(x)
#:elif func == 'cospi'
        res = dd_cospi_full(x)
#:elif func == 'tanpi'
        res = dd_tanpi_full(x)
#:elif func == 'tan'
        res = dd_tan_full(x)
#:elif func == 'sinh'
        res = dd_sinh_full(x)
#:elif func == 'cosh'
        res = dd_cosh_full(x)
#:elif func == 'tanh'
        res = dd_tanh_full(x)
#:elif func == 'asin'
        res = dd_asin_full(x)
#:elif func == 'acos'
        res = dd_acos_full(x)
#:elif func == 'atan'
        res = dd_atan_full(x)
#:elif func == 'asinpi'
        res = dd_asinpi_full(x)
#:elif func == 'acospi'
        res = dd_acospi_full(x)
#:elif func == 'atanpi'
        res = dd_atanpi_full(x)
#:elif func == 'asinh'
        res = dd_asinh_full(x)
#:elif func == 'acosh'
        res = dd_acosh_full(x)
#:elif func == 'atanh'
        res = dd_atanh_full(x)
#:elif func == 'erf'
        res = dd_erf_full(x)
#:elif func == 'erfc'
        res = dd_erfc_full(x)
#:elif func == 'erfc_scaled'
        res = dd_erfc_scaled_full(x)
#:elif func == 'gamma'
        res = dd_gamma_full(x)
#:elif func == 'log_gamma'
        res = dd_log_gamma_full(x)
#:elif func == 'bessel_j0'
        res = dd_bessel_j0_full(x)
#:elif func == 'bessel_j1'
        res = dd_bessel_j1_full(x)
#:elif func == 'bessel_y0'
        res = dd_bessel_y0_full(x)
#:elif func == 'bessel_y1'
        res = dd_bessel_y1_full(x)
#:else
        ! Should be unreachable: every entry of UNARY_DD_DD is handled above.
        res%limbs = [0.0_dp, 0.0_dp]
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Unary math: cdd → cdd (elemental)
    ! ----------------------------------------------------------------

#:for func in UNARY_CDD_CDD
    elemental function cdd_${func}$(x) result(res)
        type(complex64x2), intent(in) :: x
        type(complex64x2) :: res
#:if func == 'conjg'
        res%re = x%re
        res%im%limbs = -x%im%limbs
#:else
        ! Delegate to C c${func}$dd — algorithm single-sourced in
        ! src/multifloats_math.cc (same Kahan sqrt, factored (1-z)(1+z)
        ! branches, overflow-safe log, etc. that used to live here).
        block
            type(complex64x2_t) :: a, r
            a%re = float64x2_t(x%re%limbs(1), x%re%limbs(2))
            a%im = float64x2_t(x%im%limbs(1), x%im%limbs(2))
            r = c_dd_cdd_${func}$(a)
            res%re%limbs = [r%re%hi, r%re%lo]
            res%im%limbs = [r%im%hi, r%im%lo]
        end block
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Unary math: cdd → dd (elemental)
    ! ----------------------------------------------------------------

#:for func in UNARY_CDD_DD
    elemental function cdd_${func}$(x) result(res)
        type(complex64x2), intent(in) :: x
        type(float64x2) :: res
#:if func == 'abs'
        ! |a + bi| = hypot(a, b)
        res = dd_hypot_dd(x%re, x%im)
#:else
        ! aimag(a + bi) = b
        res = x%im
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Complex-specific: cmplx, real, dd_real (elemental)
    ! ----------------------------------------------------------------

    elemental function dd_cmplx_2(re, im) result(res)
        type(float64x2), intent(in) :: re, im
        type(complex64x2) :: res
        res%re = re
        res%im = im
    end function

    elemental function dd_cmplx_1(re) result(res)
        type(float64x2), intent(in) :: re
        type(complex64x2) :: res
        res%re = re
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cdd_real(x) result(res)
        type(complex64x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    elemental function dd_real_dd(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = x
    end function

    elemental function cdd_real_dd(x) result(res)
        type(complex64x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    ! ----------------------------------------------------------------
    ! Binary real functions (elemental)
    ! ----------------------------------------------------------------

#:for func in BINARY_REAL + BINARY_MINMAX
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'dd' or n2 == 'dd'
    elemental function ${n1}$_${func}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        type(float64x2) :: res
        type(float64x2) :: x, y
        x = ${DDCONV[n1].format('a')}$
        y = ${DDCONV[n2].format('b')}$
#:if func == 'min'
        ! multifloats::fmin : (a < b) ? a : b
        if (x < y) then
            res = x
        else
            res = y
        end if
#:elif func == 'max'
        ! multifloats::fmax : (a < b) ? b : a
        if (x < y) then
            res = y
        else
            res = x
        end if
#:elif func == 'sign'
        ! Fortran sign(a, b) == C++ copysign(a, b):
        !   (signbit(a) == signbit(b)) ? a : -a
        ! signbit uses first-nonzero-limb logic (see dd_signbit).
        if (dd_signbit(x) .eqv. dd_signbit(y)) then
            res = x
        else
            res%limbs = -x%limbs
        end if
#:elif func == 'mod'
        res = dd_fmod_full(x, y)
#:elif func == 'modulo'
        ! Floored modulo mirroring multifloats::modulo: fmod for the
        ! truncated remainder, then add y when signbit(r) != signbit(y).
        ! dd_signbit is first-nonzero-limb, so non-canonical DDs like
        ! (0, -eps) get the correct sign adjust — something the prior
        ! hi-only check missed.
        res = dd_fmod_full(x, y)
        if (res%limbs(1) /= 0.0_dp .or. res%limbs(2) /= 0.0_dp) then
            if (dd_signbit(res) .neqv. dd_signbit(y)) res = res + y
        end if
#:elif func == 'dim'
        ! multifloats::fdim : (x > y) ? x - y : 0
        if (x > y) then
            res = x - y
        else
            res = DD_ZERO
        end if
#:elif func == 'hypot'
        res = dd_hypot_full(x, y)
#:elif func == 'atan2'
        ! Full-DD atan2 — see dd_atan2_full above. Here the binary
        ! generator passes (a, b) with a = "y" and b = "x" inverted, so
        ! we still call dd_atan2_full(x, y) where x corresponds to the
        ! first argument (y in standard atan2 terms).
        res = dd_atan2_full(x, y)
#:elif func == 'atan2pi'
        ! atan2pi(y, x) = atan2(y, x) / π. Same (a, b) convention.
        res = dd_atan2pi_full(x, y)
#:elif func == 'nearest'
        ! Approximate one DD ulp toward y on the leading limb only.
        block
            real(dp) :: hi, dir
            hi = x%limbs(1)
            if (y%limbs(1) > 0.0_dp) then
                dir = huge(0.0_dp)
            else
                dir = -huge(0.0_dp)
            end if
            res%limbs(1) = nearest(hi, dir)
            res%limbs(2) = 0.0_dp
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! min/max with N arguments (N = 3..8). LAPACK has call sites with
    ! up to 5 arguments; the upper bound is generous so future call
    ! sites do not regress.
#:def dd_minmax_body(func, n)
    elemental function dd_${func}$${n}$(${', '.join(['a%d' % i for i in range(1, n+1)])}$) result(res)
        type(float64x2), intent(in) :: ${', '.join(['a%d' % i for i in range(1, n+1)])}$
        type(float64x2) :: res
#:set cmp = '<' if func == 'min' else '>'
        res = a1
#:for i in range(2, n+1)
        if (a${i}$ ${cmp}$ res) res = a${i}$
#:endfor
    end function
#:enddef
#:for func in BINARY_MINMAX
#:for n in MINMAX_NARG
$:dd_minmax_body(func, n)

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Bessel functions with integer order (elemental + transformational)
    ! ----------------------------------------------------------------

    ! Full DD bessel_jn / bessel_yn delegate to C. Algorithm lives in
    ! src/multifloats_math.cc (forward recurrence when n <= |x|, Miller's
    ! backward recurrence for Jn when n > x).
    elemental function dd_bessel_jn_elem(n, x) result(res)
        integer, intent(in) :: n
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        type(float64x2_t) :: r
        r = c_dd_jn(int(n, c_int), float64x2_t(x%limbs(1), x%limbs(2)))
        res%limbs = [r%hi, r%lo]
    end function

    elemental function dd_bessel_yn_elem(n, x) result(res)
        integer, intent(in) :: n
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        type(float64x2_t) :: r
        r = c_dd_yn(int(n, c_int), float64x2_t(x%limbs(1), x%limbs(2)))
        res%limbs = [r%hi, r%lo]
    end function

    pure function dd_bessel_jn_range(n1, n2, x) result(res)
        integer, intent(in) :: n1, n2
        type(float64x2), intent(in) :: x
        type(float64x2) :: res(max(n2 - n1 + 1, 0))
        type(float64x2_t), allocatable :: buf(:)
        integer :: i, nsize
        nsize = size(res)
        if (nsize == 0) return
        ! Delegate the per-output Miller backward recurrence to C, matching
        ! the yn_range shape — Jn forward recurrence is unstable for n > x,
        ! so the C side loops over jndd (Miller's algorithm) per output.
        allocate(buf(nsize))
        call c_dd_jn_range(int(n1, c_int), int(n2, c_int), &
                           float64x2_t(x%limbs(1), x%limbs(2)), buf)
        do i = 1, nsize
            res(i)%limbs = [buf(i)%hi, buf(i)%lo]
        end do
    end function

    pure function dd_bessel_yn_range(n1, n2, x) result(res)
        integer, intent(in) :: n1, n2
        type(float64x2), intent(in) :: x
        type(float64x2) :: res(max(n2 - n1 + 1, 0))
        type(float64x2_t), allocatable :: buf(:)
        integer :: i, nsize
        nsize = size(res)
        if (nsize == 0) return
        ! Delegate the single-sweep forward recurrence to C.
        allocate(buf(nsize))
        call c_dd_yn_range(int(n1, c_int), int(n2, c_int), &
                           float64x2_t(x%limbs(1), x%limbs(2)), buf)
        do i = 1, nsize
            res(i)%limbs = [buf(i)%hi, buf(i)%lo]
        end do
    end function

    ! ----------------------------------------------------------------
    ! Functions: (dd, integer) → dd (elemental)
    ! ----------------------------------------------------------------

#:for func in DD_INT_TO_DD
    elemental function dd_${func}$(x, i) result(res)
        type(float64x2), intent(in) :: x
        integer, intent(in) :: i
        type(float64x2) :: res
#:if func == 'scale'
        ! scale(x, i) = x * 2^i — exact on dp limbs.
        res%limbs(1) = scale(x%limbs(1), i)
        res%limbs(2) = scale(x%limbs(2), i)
#:else
        ! set_exponent(x, i) = fraction(x) * 2^i.
        block
            integer :: e
            if (x%limbs(1) == 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                e = exponent(x%limbs(1))
                res%limbs(1) = scale(x%limbs(1), i - e)
                res%limbs(2) = scale(x%limbs(2), i - e)
            end if
        end block
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Numeric inquiry functions (elemental)
    ! ----------------------------------------------------------------

#:for func in INQUIRY_DD_INT
    elemental function dd_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
#:if func == 'digits'
        res = 106
#:elif func == 'maxexponent'
        res = maxexponent(0.0_dp)
#:elif func == 'minexponent'
        res = minexponent(0.0_dp)
#:else
        res = radix(0.0_dp)
#:endif
    end function

#:endfor
#:for func in INQUIRY_BOTH_INT
    elemental function dd_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
#:if func == 'precision'
        res = 31
#:else
        res = range(0.0_dp)
#:endif
    end function

    elemental function cdd_${func}$(x) result(res)
        type(complex64x2), intent(in) :: x
        integer :: res
#:if func == 'precision'
        res = 31
#:else
        res = range(0.0_dp)
#:endif
    end function

#:endfor
    elemental function dd_storage_size(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = 2 * storage_size(0.0_dp)
    end function

    elemental function cdd_storage_size(x) result(res)
        type(complex64x2), intent(in) :: x
        integer :: res
        res = 4 * storage_size(0.0_dp)
    end function

    ! ----------------------------------------------------------------
    ! Array reductions: value (maxval, minval) — rank 1-7
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_VAL
#:set CMP_OP = '>' if func == 'maxval' else '<'
#:for rank in range(1, MAX_RANK+1)
    pure function dd_${func}$_${rank}$d(array, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res
        logical :: have
        integer :: ${IVARS(rank)}$
        have = .false.
        ! Provide a deterministic default for empty / fully-masked input.
        res = dd_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (.not. have) then
                res = array(${IDXS(rank)}$)
                have = .true.
            else if (array(${IDXS(rank)}$) ${CMP_OP}$ res) then
                res = array(${IDXS(rank)}$)
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function dd_${func}$_1d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        if (present(mask)) then
            res = dd_${func}$_1d(array, mask=mask)
        else
            res = dd_${func}$_1d(array)
        end if
    end function
#:else
    pure function dd_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        logical :: have
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                have = .false.
                cur = dd_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (.not. have) then
                        cur = array(${IDXS(rank)}$)
                        have = .true.
                    else if (array(${IDXS(rank)}$) ${CMP_OP}$ cur) then
                        cur = array(${IDXS(rank)}$)
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: location (maxloc, minloc) — rank 1-7
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_LOC
#:set CMP_OP = '>' if func == 'maxloc' else '<'
#:set CMP_STRICT = '>' if func == 'maxloc' else '<'
#:for rank in range(1, MAX_RANK+1)
    pure function dd_${func}$_${rank}$d(array, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        type(float64x2) :: best
        logical :: have, scan_back
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        have = .false.
        best = dd_from_dp(0.0_dp)
        res = 0
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (.not. have) then
                best = array(${IDXS(rank)}$)
                res = [${IDXS(rank)}$]
                have = .true.
            else if (array(${IDXS(rank)}$) ${CMP_STRICT}$ best) then
                best = array(${IDXS(rank)}$)
                res = [${IDXS(rank)}$]
            else if (scan_back .and. array(${IDXS(rank)}$) == best) then
                res = [${IDXS(rank)}$]
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function dd_${func}$_1d_dim(array, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = dd_${func}$_1d(array, mask=mask, back=back)
        else if (present(mask)) then
            r1 = dd_${func}$_1d(array, mask=mask)
        else if (present(back)) then
            r1 = dd_${func}$_1d(array, back=back)
        else
            r1 = dd_${func}$_1d(array)
        end if
        res = r1(1)
    end function
#:else
    pure function dd_${func}$_${rank}$d_dim(array, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: best
        logical :: have, scan_back
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                have = .false.
                best = dd_from_dp(0.0_dp)
                idx = 0
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (.not. have) then
                        best = array(${IDXS(rank)}$)
                        idx = i${d}$
                        have = .true.
                    else if (array(${IDXS(rank)}$) ${CMP_STRICT}$ best) then
                        best = array(${IDXS(rank)}$)
                        idx = i${d}$
                    else if (scan_back .and. array(${IDXS(rank)}$) == best) then
                        idx = i${d}$
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: sum, product — rank 1-7 (dd + cdd)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_SUM
#:set INIT_VAL = '0.0_dp' if func == 'sum' else '1.0_dp'
#:set OP_SYM = '+' if func == 'sum' else '*'
#:for rank in range(1, MAX_RANK+1)
    ! dd ${func}$ rank ${rank}$
    pure function dd_${func}$_${rank}$d(array, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res
        integer :: ${IVARS(rank)}$
#:if func == 'sum'
        real(dp) :: s_hi, s_lo, x_hi, x_lo, t, bp, ap, aerr, berr
        s_hi = 0.0_dp; s_lo = 0.0_dp
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            x_hi = array(${IDXS(rank)}$)%limbs(1)
            x_lo = array(${IDXS(rank)}$)%limbs(2)
            t = s_hi + x_hi
            bp = t - s_hi; ap = t - bp
            aerr = s_hi - ap; berr = x_hi - bp
            s_lo = s_lo + (x_lo + aerr + berr)
            s_hi = t
#:for d in range(rank)
        end do
#:endfor
        t = s_hi + s_lo; bp = t - s_hi
        res%limbs(1) = t
        res%limbs(2) = s_lo - bp
#:else
        res = dd_from_dp(${INIT_VAL}$)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            res = res ${OP_SYM}$ array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
#:endif
    end function

#:if rank == 1
    pure function dd_${func}$_1d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        if (present(mask)) then
            res = dd_${func}$_1d(array, mask=mask)
        else
            res = dd_${func}$_1d(array)
        end if
    end function
#:else
    pure function dd_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
#:if func == 'sum'
        real(dp) :: s_hi, s_lo, x_hi, x_lo, t, bp, ap, aerr, berr
#:else
        type(float64x2) :: cur
#:endif
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
#:if func == 'sum'
                ! Neumaier-compensated scalar accumulator, matching
                ! dd_sum_${rank}$d above.
                s_hi = 0.0_dp; s_lo = 0.0_dp
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    x_hi = array(${IDXS(rank)}$)%limbs(1)
                    x_lo = array(${IDXS(rank)}$)%limbs(2)
                    t = s_hi + x_hi
                    bp = t - s_hi; ap = t - bp
                    aerr = s_hi - ap; berr = x_hi - bp
                    s_lo = s_lo + (x_lo + aerr + berr)
                    s_hi = t
                end do
                t = s_hi + s_lo
                bp = t - s_hi; ap = t - bp
                aerr = s_hi - ap; berr = s_lo - bp
                res(${OUT_IDXS(rank, d)}$)%limbs(1) = t
                res(${OUT_IDXS(rank, d)}$)%limbs(2) = aerr + berr
#:else
                ! Product: each DD*DD is already ~1 DD ulp; Neumaier-style
                ! compensation does not apply to multiplication.
                cur = dd_from_dp(${INIT_VAL}$)
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    cur = cur ${OP_SYM}$ array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:endif
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

    ! cdd ${func}$ rank ${rank}$
    pure function cdd_${func}$_${rank}$d(array, mask) result(res)
        type(complex64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex64x2) :: res
#:if func == 'sum'
        real(dp) :: re_hi, re_lo, im_hi, im_lo
        real(dp) :: xh, xl, t, bp, ap, aerr, berr
#:else
        type(float64x2) :: zero, one
#:endif
        integer :: ${IVARS(rank)}$
#:if func == 'sum'
        ! Neumaier-compensated accumulators on both real and imaginary limbs.
        re_hi = 0.0_dp; re_lo = 0.0_dp
        im_hi = 0.0_dp; im_lo = 0.0_dp
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            xh = array(${IDXS(rank)}$)%re%limbs(1)
            xl = array(${IDXS(rank)}$)%re%limbs(2)
            t = re_hi + xh
            bp = t - re_hi; ap = t - bp
            aerr = re_hi - ap; berr = xh - bp
            re_lo = re_lo + (xl + aerr + berr)
            re_hi = t
            xh = array(${IDXS(rank)}$)%im%limbs(1)
            xl = array(${IDXS(rank)}$)%im%limbs(2)
            t = im_hi + xh
            bp = t - im_hi; ap = t - bp
            aerr = im_hi - ap; berr = xh - bp
            im_lo = im_lo + (xl + aerr + berr)
            im_hi = t
#:for d in range(rank)
        end do
#:endfor
        t = re_hi + re_lo
        bp = t - re_hi; ap = t - bp
        aerr = re_hi - ap; berr = re_lo - bp
        res%re%limbs(1) = t
        res%re%limbs(2) = aerr + berr
        t = im_hi + im_lo
        bp = t - im_hi; ap = t - bp
        aerr = im_hi - ap; berr = im_lo - bp
        res%im%limbs(1) = t
        res%im%limbs(2) = aerr + berr
#:else
        zero = dd_from_dp(0.0_dp)
        one = dd_from_dp(1.0_dp)
        res%re = one
        res%im = zero
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            res = res ${OP_SYM}$ array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
#:endif
    end function

#:if rank == 1
    pure function cdd_${func}$_1d_dim(array, dim, mask) result(res)
        type(complex64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(complex64x2) :: res
        if (present(mask)) then
            res = cdd_${func}$_1d(array, mask=mask)
        else
            res = cdd_${func}$_1d(array)
        end if
    end function
#:else
    pure function cdd_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(complex64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
#:if func == 'sum'
        real(dp) :: re_hi, re_lo, im_hi, im_lo
        real(dp) :: xh, xl, t, bp, ap, aerr, berr
#:else
        type(complex64x2) :: cur
        type(float64x2) :: zero, one
#:endif
        integer :: ${IVARS(rank)}$
#:if func == 'product'
        zero = dd_from_dp(0.0_dp)
        one = dd_from_dp(1.0_dp)
#:endif
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
#:if func == 'sum'
                ! Neumaier-compensated real + imag accumulators.
                re_hi = 0.0_dp; re_lo = 0.0_dp
                im_hi = 0.0_dp; im_lo = 0.0_dp
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    xh = array(${IDXS(rank)}$)%re%limbs(1)
                    xl = array(${IDXS(rank)}$)%re%limbs(2)
                    t = re_hi + xh
                    bp = t - re_hi; ap = t - bp
                    aerr = re_hi - ap; berr = xh - bp
                    re_lo = re_lo + (xl + aerr + berr)
                    re_hi = t
                    xh = array(${IDXS(rank)}$)%im%limbs(1)
                    xl = array(${IDXS(rank)}$)%im%limbs(2)
                    t = im_hi + xh
                    bp = t - im_hi; ap = t - bp
                    aerr = im_hi - ap; berr = xh - bp
                    im_lo = im_lo + (xl + aerr + berr)
                    im_hi = t
                end do
                t = re_hi + re_lo
                bp = t - re_hi; ap = t - bp
                aerr = re_hi - ap; berr = re_lo - bp
                res(${OUT_IDXS(rank, d)}$)%re%limbs(1) = t
                res(${OUT_IDXS(rank, d)}$)%re%limbs(2) = aerr + berr
                t = im_hi + im_lo
                bp = t - im_hi; ap = t - bp
                aerr = im_hi - ap; berr = im_lo - bp
                res(${OUT_IDXS(rank, d)}$)%im%limbs(1) = t
                res(${OUT_IDXS(rank, d)}$)%im%limbs(2) = aerr + berr
#:else
                cur%re = one
                cur%im = zero
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    cur = cur ${OP_SYM}$ array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:endif
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! dot_product (pure)
    ! ----------------------------------------------------------------

    pure function dd_dot_product(a, b) result(res)
        type(float64x2), intent(in) :: a(:), b(:)
        type(float64x2) :: res
        ! Fused multiply-accumulate with periodic renormalization.
        ! Every DD_FMA_RENORM_INTERVAL iterations (default 8) we
        ! fast_two_sum the accumulator to keep s_lo bounded. Set the
        ! interval to 0 to renormalize only at the end.
        ! Hoist the `ri > 0` test out of the inner loop: the `ri <= 0`
        ! path is a single tight FMA pass; the periodic-renorm path is
        ! a nested block loop with the fast_two_sum between blocks. This
        ! eliminates the `mod(k, ri)` check from the hot per-element body.
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: k, kk, ke, n, ri
        ri = DD_FMA_RENORM_INTERVAL
        n = size(a)
        s_hi = 0.0_dp
        s_lo = 0.0_dp
        if (ri <= 0) then
            do k = 1, n
                ah = a(k)%limbs(1); al = a(k)%limbs(2)
                bh = b(k)%limbs(1); bl = b(k)%limbs(2)
                p = ah * bh
                e = c_fma(ah, bh, -p)
                cross = ah * bl + al * bh
                t = s_hi + p
                bp = t - s_hi; ap = t - bp
                aerr = s_hi - ap; berr = p - bp
                s_lo = s_lo + (e + cross + aerr + berr)
                s_hi = t
            end do
        else
            do kk = 1, n, ri
                ke = min(kk + ri - 1, n)
                do k = kk, ke
                    ah = a(k)%limbs(1); al = a(k)%limbs(2)
                    bh = b(k)%limbs(1); bl = b(k)%limbs(2)
                    p = ah * bh
                    e = c_fma(ah, bh, -p)
                    cross = ah * bl + al * bh
                    t = s_hi + p
                    bp = t - s_hi; ap = t - bp
                    aerr = s_hi - ap; berr = p - bp
                    s_lo = s_lo + (e + cross + aerr + berr)
                    s_hi = t
                end do
                t = s_hi + s_lo; bp = t - s_hi
                s_hi = t; s_lo = s_lo - bp
            end do
        end if
        t = s_hi + s_lo
        bp = t - s_hi
        res%limbs(1) = t
        res%limbs(2) = s_lo - bp
    end function

    ! Complex dot_product: sum(conj(a_k) * b_k).
    ! Expand real/imag components so each scalar reduction routes through
    ! the compensated dd_dot_product (same Neumaier-style accumulator used
    ! by the real path) rather than a naive left fold. Uses 4 real dots at
    ! the cost of 4 small temp arrays.
    !
    ! Future: a single fused kernel that keeps four compensated DD
    ! accumulators (re_hi/lo, im_hi/lo) in registers across one pass over
    ! the inputs would cut memory traffic roughly in half and avoid the
    ! temp-array copies. Worth revisiting if profiling shows cdd reductions
    ! as a bottleneck — current form prioritizes code reuse + correctness.
    pure function cdd_dot_product(a, b) result(res)
        type(complex64x2), intent(in) :: a(:), b(:)
        type(complex64x2) :: res
        type(float64x2) :: a_re(size(a)), a_im(size(a))
        type(float64x2) :: b_re(size(b)), b_im(size(b))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        ! conj(a)·b = (a_re·b_re + a_im·b_im) + i (a_re·b_im - a_im·b_re)
        res%re = dd_dot_product(a_re, b_re) + dd_dot_product(a_im, b_im)
        res%im = dd_dot_product(a_re, b_im) - dd_dot_product(a_im, b_re)
    end function

    ! ----------------------------------------------------------------
    ! norm2 (pure) — rank 1-7, NO mask per standard
    ! ----------------------------------------------------------------

#:for rank in range(1, MAX_RANK+1)
    pure function dd_norm2_${rank}$d(array) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2) :: res
        type(float64x2) :: s
        integer :: ${IVARS(rank)}$
        s = dd_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            s = s + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
        res = dd_sqrt(s)
    end function

#:if rank > 1
    pure function dd_norm2_${rank}$d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                cur = dd_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    cur = cur + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = dd_sqrt(cur)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ----------------------------------------------------------------
    ! findloc (pure) — rank 1-7 (dd + cdd)
    ! ----------------------------------------------------------------

#:for rank in range(1, MAX_RANK+1)
    ! dd findloc rank ${rank}$
    pure function dd_findloc_${rank}$d(array, value, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function dd_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = dd_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = dd_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = dd_findloc_1d(array, value, back=back)
        else
            r1 = dd_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function dd_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

    ! cdd findloc rank ${rank}$
    pure function cdd_findloc_${rank}$d(array, value, mask, back) result(res)
        type(complex64x2), intent(in) :: array(${COLONS(rank)}$)
        type(complex64x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function cdd_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(complex64x2), intent(in) :: array(:)
        type(complex64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = cdd_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = cdd_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = cdd_findloc_1d(array, value, back=back)
        else
            r1 = cdd_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function cdd_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(complex64x2), intent(in) :: array(${COLONS(rank)}$)
        type(complex64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ----------------------------------------------------------------
    ! matmul (pure) — dd + cdd
    ! ----------------------------------------------------------------

    ! dd matmul: 2D × 2D → 2D (delegates to C kernel matmuldd_mm)
    pure function dd_matmul_mm(a, b) result(res)
        type(float64x2), intent(in), target, contiguous :: a(:,:), b(:,:)
        type(float64x2), target :: res(size(a,1), size(b,2))
        call c_dd_matmul_mm(c_loc(a), c_loc(b), c_loc(res), &
            int(size(a,1), c_int64_t), int(size(a,2), c_int64_t), &
            int(size(b,2), c_int64_t), &
            int(DD_FMA_RENORM_INTERVAL, c_int64_t))
    end function

    ! dd matmul: 2D × 1D → 1D (delegates to C kernel matmuldd_mv)
    pure function dd_matmul_mv(a, b) result(res)
        type(float64x2), intent(in), target, contiguous :: a(:,:), b(:)
        type(float64x2), target :: res(size(a,1))
        call c_dd_matmul_mv(c_loc(a), c_loc(b), c_loc(res), &
            int(size(a,1), c_int64_t), int(size(a,2), c_int64_t), &
            int(DD_FMA_RENORM_INTERVAL, c_int64_t))
    end function

    ! dd matmul: 1D × 2D → 1D (delegates to C kernel matmuldd_vm)
    pure function dd_matmul_vm(a, b) result(res)
        type(float64x2), intent(in), target, contiguous :: a(:), b(:,:)
        type(float64x2), target :: res(size(b,2))
        call c_dd_matmul_vm(c_loc(a), c_loc(b), c_loc(res), &
            int(size(a), c_int64_t), int(size(b,2), c_int64_t), &
            int(DD_FMA_RENORM_INTERVAL, c_int64_t))
    end function

    ! Complex matmul via 4 real DD matmuls on the split (re, im) parts.
    ! (a + i b) · (c + i d) = (a·c - b·d) + i (a·d + b·c), so one complex
    ! matmul of shape (M, K) × (K, N) becomes four real matmuls of the
    ! same shape, each going through the compensated dd_matmul_mm kernel.
    ! Cost: 2 extra m·k + 2 extra k·n temp DD arrays (plus 2 m·n
    ! intermediates) per call.
    !
    ! Future: a fused complex kernel that streams each input once and
    ! accumulates the four real-part / imag-part contributions into a
    ! single set of compensated DD accumulators (4 doubles per output)
    ! would roughly halve the memory traffic and remove the temp arrays.
    ! The real dd_matmul is compute-bound on most targets, so the payoff
    ! is modest — revisit if cdd matmul becomes a profile hotspot. The
    ! analogous note on cdd_dot_product above applies here too.
    pure function cdd_matmul_mm(a, b) result(res)
        type(complex64x2), intent(in) :: a(:,:), b(:,:)
        type(complex64x2) :: res(size(a,1), size(b,2))
        type(float64x2) :: a_re(size(a,1), size(a,2)), a_im(size(a,1), size(a,2))
        type(float64x2) :: b_re(size(b,1), size(b,2)), b_im(size(b,1), size(b,2))
        type(float64x2) :: p_re(size(a,1), size(b,2)), p_im(size(a,1), size(b,2))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        p_re = dd_matmul_mm(a_re, b_re) - dd_matmul_mm(a_im, b_im)
        p_im = dd_matmul_mm(a_re, b_im) + dd_matmul_mm(a_im, b_re)
        res%re = p_re
        res%im = p_im
    end function

    pure function cdd_matmul_mv(a, b) result(res)
        type(complex64x2), intent(in) :: a(:,:), b(:)
        type(complex64x2) :: res(size(a,1))
        type(float64x2) :: a_re(size(a,1), size(a,2)), a_im(size(a,1), size(a,2))
        type(float64x2) :: b_re(size(b)), b_im(size(b))
        type(float64x2) :: p_re(size(a,1)), p_im(size(a,1))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        p_re = dd_matmul_mv(a_re, b_re) - dd_matmul_mv(a_im, b_im)
        p_im = dd_matmul_mv(a_re, b_im) + dd_matmul_mv(a_im, b_re)
        res%re = p_re
        res%im = p_im
    end function

    pure function cdd_matmul_vm(a, b) result(res)
        type(complex64x2), intent(in) :: a(:), b(:,:)
        type(complex64x2) :: res(size(b,2))
        type(float64x2) :: a_re(size(a)), a_im(size(a))
        type(float64x2) :: b_re(size(b,1), size(b,2)), b_im(size(b,1), size(b,2))
        type(float64x2) :: p_re(size(b,2)), p_im(size(b,2))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        p_re = dd_matmul_vm(a_re, b_re) - dd_matmul_vm(a_im, b_im)
        p_im = dd_matmul_vm(a_re, b_im) + dd_matmul_vm(a_im, b_re)
        res%re = p_re
        res%im = p_im
    end function

    ! ----------------------------------------------------------------
    ! Fused sincos / sinhcosh — one range-reduction, two outputs
    ! ----------------------------------------------------------------

    pure elemental subroutine dd_sincos(x, s, c)
        type(float64x2), intent(in) :: x
        type(float64x2), intent(out) :: s, c
        type(float64x2_t) :: ss, cc
        call c_dd_sincos(float64x2_t(x%limbs(1), x%limbs(2)), ss, cc)
        s%limbs = [ss%hi, ss%lo]
        c%limbs = [cc%hi, cc%lo]
    end subroutine

    pure elemental subroutine dd_sinhcosh(x, s, c)
        type(float64x2), intent(in) :: x
        type(float64x2), intent(out) :: s, c
        type(float64x2_t) :: ss, cc
        call c_dd_sinhcosh(float64x2_t(x%limbs(1), x%limbs(2)), ss, cc)
        s%limbs = [ss%hi, ss%lo]
        c%limbs = [cc%hi, cc%lo]
    end subroutine

    ! ----------------------------------------------------------------
    ! Configuration
    ! ----------------------------------------------------------------

    subroutine dd_set_fma_renorm_interval(n)
        integer, intent(in) :: n
        DD_FMA_RENORM_INTERVAL = n
    end subroutine

    ! ----------------------------------------------------------------
    ! random_number (impure subroutine)
    ! ----------------------------------------------------------------

    subroutine dd_random_number_0d(harvest)
        type(float64x2), intent(out) :: harvest
        real(dp) :: hi, lo, s, b
        call random_number(hi)
        call random_number(lo)
        ! Pack two independent dp randoms into a DD: hi gets ~53 bits in [0,1),
        ! lo contributes ~53 more bits below hi's ulp.
        lo = lo * 2.0_dp**(-53)
        s = hi + lo
        b = s - hi
        harvest%limbs(1) = s
        harvest%limbs(2) = lo - b
    end subroutine

#:for rank in range(1, MAX_RANK+1)
    subroutine dd_random_number_${rank}$d(harvest)
        type(float64x2), intent(out) :: harvest(${COLONS(rank)}$)
        real(dp) :: hi(${SIZES(rank, 'harvest')}$), lo(${SIZES(rank, 'harvest')}$)
        real(dp) :: s, b
        integer :: ${IVARS(rank)}$
        call random_number(hi)
        call random_number(lo)
        lo = lo * 2.0_dp**(-53)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(harvest, ${d}$)
#:endfor
            s = hi(${IDXS(rank)}$) + lo(${IDXS(rank)}$)
            b = s - hi(${IDXS(rank)}$)
            harvest(${IDXS(rank)}$)%limbs(1) = s
            harvest(${IDXS(rank)}$)%limbs(2) = lo(${IDXS(rank)}$) - b
#:for d in range(rank)
        end do
#:endfor
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! Binary arithmetic (+, -, *, /) — elemental
    ! ----------------------------------------------------------------


#! Complex result: lift any non-complex operand to a complex64x2 via
#! assignment overloads, then delegate to the C kernel c${opname}$dd so
#! the arithmetic lives in C++ (see src/complex64x2_abi.inc).
#:def cdd_arith_body(opname)
        block
            type(complex64x2) :: ca, cb
            type(complex64x2_t) :: ka, kb, kr
            ca = a
            cb = b
            ka%re = float64x2_t(ca%re%limbs(1), ca%re%limbs(2))
            ka%im = float64x2_t(ca%im%limbs(1), ca%im%limbs(2))
            kb%re = float64x2_t(cb%re%limbs(1), cb%re%limbs(2))
            kb%im = float64x2_t(cb%im%limbs(1), cb%im%limbs(2))
            kr = c_dd_cdd2_${opname}$(ka, kb)
            res%re%limbs = [kr%re%hi, kr%re%lo]
            res%im%limbs = [kr%im%hi, kr%im%lo]
        end block
#:enddef

#:for opsym, opname in ARITH_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('dd', 'cdd') or n2 in ('dd', 'cdd')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex64x2)' if rc else 'type(float64x2)'}$ :: res
#:if not rc
        ! Native inline mirroring float64x2::operator ${opsym}$ in
        ! include/multifloats.h (two_sum / fast_two_sum / two_prod EFTs).
        ! Bit-exact with the C++ kernel on finite inputs.
        type(float64x2) :: x, y
        real(dp) :: xh, xl, yh, yl
        real(dp) :: s, a_, b_, c_, d_, aa, cc
#:if opname == 'mul'
        real(dp) :: p00, e00, p01, p10
#:endif
#:if opname == 'div'
        real(dp) :: q1, q2, p00, e00, p01, qhi, qlo, r0, r0e, r1, rh, rl
#:endif
        x = ${DDCONV[n1].format('a')}$
        y = ${DDCONV[n2].format('b')}$
        xh = x%limbs(1); xl = x%limbs(2)
        yh = y%limbs(1); yl = y%limbs(2)
#:if opname == 'add' or opname == 'sub'
#:if opname == 'sub'
        yh = -yh
        yl = -yl
#:endif
        s = xh + yh
        if (.not. ieee_is_finite(s)) then
            res%limbs = [s, 0.0_dp]
        else if (xh == 0.0_dp .and. yh == 0.0_dp) then
            ! two_sum loses the -0 sign when both hi limbs are zero;
            ! short-circuit so the IEEE sign of s is preserved.
            res%limbs = [s, xl + yl]
        else
            call two_sum(xh, yh, a_, b_)
            call two_sum(xl, yl, c_, d_)
            call fast_two_sum(a_, c_, aa, cc)
            b_ = b_ + d_ + cc
            call fast_two_sum(aa, b_, res%limbs(1), res%limbs(2))
        end if
#:elif opname == 'mul'
        call two_prod(xh, yh, p00, e00)
        if (.not. ieee_is_finite(p00)) then
            ! two_prod's fma residual goes NaN whenever p00 overflows or
            ! either input is ±Inf/NaN (e.g. inf*2 → e00=fma(inf,2,-inf)
            ! =NaN). Short-circuit so the EFT residual doesn't contaminate
            ! the lo limb — matches operator* in include/multifloats.h.
            res%limbs = [p00, 0.0_dp]
        else
            p01 = xh * yl
            p10 = xl * yh
            p01 = p01 + p10
            e00 = e00 + p01
            call fast_two_sum(p00, e00, res%limbs(1), res%limbs(2))
        end if
#:else
        ! div: Dekker-style single Newton refinement (match operator/).
        q1 = xh / yh
        if (.not. ieee_is_finite(q1)) then
            ! Mirror q1 into the lo limb so non-finite DD propagates
            ! through both limbs — same as C++ operator/.
            res%limbs = [q1, q1]
        else if (.not. ieee_is_finite(yh)) then
            ! Finite / ±Inf: q1 is ±0; the refinement would compute
            ! 0 * inf = NaN, so short-circuit.
            res%limbs = [q1, 0.0_dp]
        else
            call two_prod(q1, yh, p00, e00)
            p01 = q1 * yl
            qhi = p00
            qlo = e00 + p01
            call two_sum(xh, -qhi, r0, r0e)
            r1 = (xl - qlo) + r0e
            call fast_two_sum(r0, r1, rh, rl)
            q2 = rh / yh
            call fast_two_sum(q1, q2, res%limbs(1), res%limbs(2))
        end if
#:endif
#:else
$:cdd_arith_body(opname)
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Power operator (**) — elemental
    ! ----------------------------------------------------------------

#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('dd', 'cdd') or n2 in ('dd', 'cdd')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    elemental function ${n1}$_pow_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex64x2)' if rc else 'type(float64x2)'}$ :: res
#:if n2 == 'int'
#:if rc
        ! Integer-power on a complex base via repeated multiplication.
        block
            type(complex64x2) :: base
            integer :: k, n
            base = a
            res%re = DD_ONE
            res%im%limbs = [0.0_dp, 0.0_dp]
            n = abs(b)
            do k = 1, n
                res = res * base
            end do
            if (b < 0) then
                res = complex64x2(DD_ONE, dd_from_dp(0.0_dp)) / res
            end if
        end block
#:else
        ! Integer-power on a real base: delegate to multifloats::powi
        ! (exponentiation-by-squaring in C++). Keeping this delegated
        ! rather than reinlined because the C++ inline-constexpr body
        ! pipelines the inner DD mults ~2x tighter than the gfortran
        ! rendering of the same loop — a real codegen gap on a
        ! non-hot path that still exceeds Fortran's reach.
        block
            type(float64x2) :: base
            type(float64x2_t) :: r
            base = a
            r = c_dd_powi(float64x2_t(base%limbs(1), base%limbs(2)), &
                          int(b, c_int))
            res%limbs = [r%hi, r%lo]
        end block
#:endif
#:elif rc
        ! General complex power: a^b = exp(b * log(a))
        block
            type(complex64x2) :: ca, cb
            ca = a
            cb = b
            res = cdd_exp(cb * cdd_log(ca))
        end block
#:else
        ! General real power: delegate to multifloats::pow, which
        ! handles IEEE edge cases (pow(1, x)=1, pow(x, 0)=1, signed
        ! zero, ±Inf exponents) that naive exp(y*log(x)) gets wrong.
        block
            type(float64x2) :: x, y
            x = a
            y = b
            res = dd_pow_full(x, y)
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Equality comparison (==, /=) — elemental
    ! ----------------------------------------------------------------

#:for opsym, opname in EQ_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('dd', 'cdd') or n2 in ('dd', 'cdd')
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
#:if not ISCPLX[n1] and not ISCPLX[n2]
        ! Match C++ float64x2::operator== / != : both limbs must agree.
        type(float64x2) :: x, y
        x = ${DDCONV[n1].format('a')}$
        y = ${DDCONV[n2].format('b')}$
#:if opname == 'eq'
        res = x%limbs(1) == y%limbs(1) .and. x%limbs(2) == y%limbs(2)
#:else
        res = x%limbs(1) /= y%limbs(1) .or.  x%limbs(2) /= y%limbs(2)
#:endif
#:else
        ! Complex (in)equality: compare real and imaginary parts in native DD.
        block
            type(complex64x2) :: ca, cb
            ca = a
            cb = b
#:if opname == 'eq'
            res = (ca%re == cb%re) .and. (ca%im == cb%im)
#:else
            res = (ca%re /= cb%re) .or. (ca%im /= cb%im)
#:endif
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Ordered comparison (<, >, <=, >=) — elemental
    ! ----------------------------------------------------------------

#:for opsym, opname in ORD_OPS
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'dd' or n2 == 'dd'
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
        ! Lexicographic on (hi, lo), mirroring the C++
        ! float64x2::operator< body in include/multifloats.h:
        !   if (hi < r.hi) return true;
        !   if (r.hi < hi) return false;
        !   return lo < r.lo;
        ! The other ordered ops compose from < exactly as in C++
        ! (operator> uses r < lhs; <=/>= negate the strict form).
        type(float64x2) :: x, y
        x = ${DDCONV[n1].format('a')}$
        y = ${DDCONV[n2].format('b')}$
#:if opname == 'lt'
        if (x%limbs(1) < y%limbs(1)) then
            res = .true.
        else if (y%limbs(1) < x%limbs(1)) then
            res = .false.
        else
            res = x%limbs(2) < y%limbs(2)
        end if
#:elif opname == 'gt'
        if (y%limbs(1) < x%limbs(1)) then
            res = .true.
        else if (x%limbs(1) < y%limbs(1)) then
            res = .false.
        else
            res = y%limbs(2) < x%limbs(2)
        end if
#:elif opname == 'le'
        if (x%limbs(1) < y%limbs(1)) then
            res = .true.
        else if (y%limbs(1) < x%limbs(1)) then
            res = .false.
        else
            res = x%limbs(2) <= y%limbs(2)
        end if
#:else
        if (y%limbs(1) < x%limbs(1)) then
            res = .true.
        else if (x%limbs(1) < y%limbs(1)) then
            res = .false.
        else
            res = y%limbs(2) <= x%limbs(2)
        end if
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Defined I/O
    ! ----------------------------------------------------------------

    subroutine write_dd_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(float64x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        real(qp) :: val_qp
        val_qp = to_qp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        else
            write(unit, '(ES23.16,1X,ES23.16)', iostat=iostat, iomsg=iomsg) &
                dtv%limbs(1), dtv%limbs(2)
        end if
#:endif
    end subroutine

    subroutine write_cdd_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(complex64x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        complex(qp) :: val_cqp
        val_cqp = to_cqp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        else
            write(unit, '(4(ES23.16,1X))', iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        end if
#:endif
    end subroutine

    subroutine read_dd_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(float64x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        real(qp) :: val_qp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
        if (iostat == 0) then
            dtv%limbs(1) = real(val_qp, dp)
            dtv%limbs(2) = real(val_qp - real(dtv%limbs(1), qp), dp)
        end if
#:else
        ! Without quad, read both limbs as doubles.
        read(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
#:endif
    end subroutine

    subroutine read_cdd_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(complex64x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        complex(qp) :: val_cqp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
        if (iostat == 0) then
            dtv%re%limbs(1) = real(real(val_cqp, qp), dp)
            dtv%re%limbs(2) = real(real(val_cqp, qp) - real(dtv%re%limbs(1), qp), dp)
            dtv%im%limbs(1) = real(aimag(val_cqp), dp)
            dtv%im%limbs(2) = real(aimag(val_cqp) - real(dtv%im%limbs(1), qp), dp)
        end if
#:else
        read(unit, *, iostat=iostat, iomsg=iomsg) &
            dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
#:endif
    end subroutine

end module multifloats
