#! multifloats.fypp — Float64x2 multifloats module (generated with fypp)
#!
#! The public generic interface is inherited from the mock scaffold, but the
#! core Float64x2 arithmetic uses explicit 2-limb double-double kernels
#! adapted from external/MultiFloats.jl. Broader transformational and
#! transcendental coverage still routes through REAL(16)/COMPLEX(16) helpers.
#!
#! The interface for float64x2 mirrors REAL(KIND=16) as closely as possible:
#! all mixed-type arithmetic, comparisons, and assignments with real(dp),
#! real(sp), integer, complex(dp), and complex(sp) are supported.
#!
#! =====================================================================
#! Performance note: Fortran ABI overhead (2025-04)
#! =====================================================================
#!
#! The DD kernels (add, mul, div, sqrt, ...) use `elemental` functions
#! on a `sequence` derived type. This design is intentional — it gives
#! automatic whole-array operations and EQUIVALENCE compatibility (needed
#! by some LAPACK routines) — but it carries an inherent ABI cost:
#!
#!   - gfortran passes/returns derived types via hidden pointers (not in
#!     FP registers), adding ~3-7× call overhead vs the C ABI.
#!   - With LTO (OBJECT library + -flto), gfortran inlines the kernels
#!     and eliminates most of this overhead, but its SROA pass does not
#!     fully promote the hidden result pointer to registers, leaving a
#!     ~1.5× residual gap vs C++ on the cheapest ops (add, mul).
#!
#! Benchmarking confirmed that switching to `bind(c)` + `value` args on
#! a `bind(c)` type closes the gap entirely (fc/cw ≈ 1.0× for add, mul,
#! div, sqrt), proving the gap is purely ABI, not codegen. However,
#! `bind(c)` is incompatible with `elemental` and `sequence`, so we keep
#! the current design and accept the ~1.5× overhead on basic arithmetic
#! (which is already 2-10× faster than libquadmath quad precision).
#!
#! To get the fastest possible DD arithmetic from Fortran without LTO,
#! call the C-ABI wrappers in src/multifloats_c.h directly via
#! iso_c_binding interfaces (see test/bench_abi.f90 for an example).
#! =====================================================================

#! =====================================================================
#! Type system metadata
#! =====================================================================
#:set RTYPES = [('mf', 'type(float64x2)'), ('dp', 'real(dp)'), ('sp', 'real(sp)'), ('int', 'integer')]
#:set CTYPES = [('cx', 'type(complex128x2)'), ('cdp', 'complex(dp)'), ('csp', 'complex(sp)')]
#:set ATYPES = RTYPES + CTYPES

#:set CONV = {'mf': 'to_qp({})', 'cx': 'to_cqp({})', 'dp': 'real({}, qp)', 'sp': 'real({}, qp)', 'int': 'real({}, qp)', 'cdp': 'cmplx({}, kind=qp)', 'csp': 'cmplx({}, kind=qp)'}
#:set ISCPLX = {'mf': False, 'cx': True, 'dp': False, 'sp': False, 'int': False, 'cdp': True, 'csp': True}
#:set MFCONV = {'mf': '{}', 'dp': 'mf_from_dp({})', 'sp': 'mf_from_sp({})', 'int': 'mf_from_int({})'}

#! Operator tables
#:set ARITH_OPS = [('+', 'add'), ('-', 'sub'), ('*', 'mul'), ('/', 'div')]
#:set EQ_OPS = [('==', 'eq'), ('/=', 'ne')]
#:set ORD_OPS = [('<', 'lt'), ('>', 'gt'), ('<=', 'le'), ('>=', 'ge')]

#! Unary math function tables
#:set UNARY_MF_MF = ['abs', 'sqrt', 'sin', 'cos', 'tan', 'sinpi', 'cospi', 'exp', 'log', 'log10', 'atan', 'asin', 'acos', 'aint', 'anint', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh', 'erf', 'erfc', 'erfc_scaled', 'gamma', 'log_gamma', 'bessel_j0', 'bessel_j1', 'bessel_y0', 'bessel_y1', 'fraction', 'rrspacing', 'spacing', 'epsilon', 'huge', 'tiny']
#:set UNARY_CX_CX = ['sqrt', 'sin', 'cos', 'tan', 'exp', 'log', 'atan', 'asin', 'acos', 'conjg', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh']
#:set UNARY_CX_MF = ['abs', 'aimag']
#:set ALL_UNARY = sorted(set(UNARY_MF_MF + UNARY_CX_CX + UNARY_CX_MF))

#! Binary real function tables
#:set BINARY_REAL = ['sign', 'mod', 'atan2', 'dim', 'modulo', 'hypot', 'nearest']
#:set BINARY_MINMAX = ['min', 'max']

#! Array reduction function tables
#:set ARRAY_REDUCE_VAL = ['maxval', 'minval']
#:set ARRAY_REDUCE_LOC = ['maxloc', 'minloc']
#:set ARRAY_REDUCE_SUM = ['sum', 'product']

#! Bessel functions with integer order
#:set BESSEL_N = ['bessel_jn', 'bessel_yn']

#! Functions: (mf, integer) → mf
#:set MF_INT_TO_MF = ['scale', 'set_exponent']

#! Inquiry functions
#:set INQUIRY_MF_INT = ['digits', 'maxexponent', 'minexponent', 'radix']
#:set INQUIRY_BOTH_INT = ['precision', 'range']

#! =====================================================================
#! Rank-generic helpers
#! =====================================================================
#:set MAX_RANK = 7
#:set COLONS = lambda r: ', '.join([':'] * r)
#:set SIZES = lambda r, v='array': (', &\n' + ' '*12).join(['size(%s,%d)' % (v, i) for i in range(1, r+1)]) if r > 4 else ', '.join(['size(%s,%d)' % (v, i) for i in range(1, r+1)])
#:set IDXS = lambda r: ', '.join(['i%d' % i for i in range(1, r+1)])
#:set IVARS = lambda r: ', '.join(['i%d' % i for i in range(1, r+1)])
#:set OUT_IDXS = lambda r, d: ', '.join(['i%d' % i for i in range(1, r+1) if i != d])
#:set SURVIVOR_DIMS = lambda r, d: [i for i in range(1, r+1) if i != d]
#:set DIM_REDUCED_SIZES = lambda r: (', &\n' + ' '*12).join(['merge(size(array,%d),size(array,%d),dim<=%d)' % (j+1,j,j) for j in range(1, r)])

#! Convert a Julia / C99 hex floating-point literal to a Fortran double
#! literal body via Python's float.fromhex + repr (round-trip exact).
#:set hex_dp = lambda h: repr(float.fromhex(h))
#:set hex_array = lambda lst: (', &\n        ').join([hex_dp(h) + '_dp' for h in lst])
#:set hex_array_padded = lambda lst, n: hex_array(lst + ['0x0p+0'] * (n - len(lst)))

#! Inline function: generate nested conversion loops
#:set conv_loops = lambda r, src, dst, func: '\n'.join(['        do i%d = 1, size(%s, %d)' % (d, src, d) for d in range(r, 0, -1)] + ['            %s(%s) = %s(%s(%s))' % (dst, IDXS(r), func, src, IDXS(r))] + ['        end do'] * r)

module multifloats
    use, intrinsic :: ieee_arithmetic, only: ieee_is_finite, ieee_is_nan, &
                                              ieee_fma, ieee_value, &
                                              ieee_quiet_nan
    use, intrinsic :: iso_fortran_env, only: int8, int16, int32, int64
    implicit none
    private

    integer, parameter :: qp = 16  ! Quad precision
    integer, parameter :: dp = 8   ! Double precision
    integer, parameter :: sp = 4   ! Single precision

    ! SEQUENCE is required so derived-type variables of these types may
    ! appear in EQUIVALENCE statements (used by some LAPACK routines
    ! such as DLALN2/wlaln2 to overlay 2x2 work arrays with linearized
    ! vectors).
    type, public :: float64x2
        sequence
        real(dp) :: limbs(2)
    end type float64x2

    type, public :: complex128x2
        sequence
        type(float64x2) :: re, im
    end type complex128x2

    ! ================================================================
    ! Constructors
    ! ================================================================

    interface float64x2
        module procedure mf_from_mf
        module procedure mf_from_dp
        module procedure mf_from_sp
        module procedure mf_from_int
        module procedure mf_from_i8
        module procedure mf_from_i16
        module procedure mf_from_i64
        module procedure mf_from_char
        module procedure mf_from_cx
        module procedure mf_from_cdp
        module procedure mf_from_csp
    end interface float64x2

    interface complex128x2
        module procedure cx_from_cx
        ! Two-argument (re, im) constructors — matching kinds.
        module procedure cx_from_mf_2
        module procedure cx_from_dp_2
        module procedure cx_from_sp_2
        module procedure cx_from_int_2
        module procedure cx_from_i8_2
        module procedure cx_from_i16_2
        module procedure cx_from_i64_2
        ! Two-argument (re, im) constructors — common mixed kinds.
        module procedure cx_from_mf_dp_2
        module procedure cx_from_dp_mf_2
        ! Single-argument constructors (imag = 0).
        module procedure cx_from_mf_1
        module procedure cx_from_dp_1
        module procedure cx_from_sp_1
        module procedure cx_from_int_1
        module procedure cx_from_i8_1
        module procedure cx_from_i16_1
        module procedure cx_from_i64_1
        module procedure cx_from_cdp_1
        module procedure cx_from_csp_1
    end interface complex128x2

    ! ================================================================
    ! Arithmetic operators (+, -, *, /)
    ! ================================================================

#:for opsym, opname in ARITH_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
#:if opsym == '-'
        module procedure mf_neg
        module procedure cx_neg
#:endif
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ================================================================
    ! Power operator (**)
    ! ================================================================

    interface operator(**)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_pow_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(**)

    ! ================================================================
    ! Equality comparison (==, /=) — all type pairs
    ! ================================================================

#:for opsym, opname in EQ_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ================================================================
    ! Ordered comparison (<, >, <=, >=) — real types only
    ! ================================================================

#:for opsym, opname in ORD_OPS
    interface operator(${opsym}$)
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ================================================================
    ! Unary math generics
    ! ================================================================

#:for func in ALL_UNARY
    interface ${func}$
#:if func in UNARY_MF_MF
        module procedure mf_${func}$
#:endif
#:if func in UNARY_CX_CX or func in UNARY_CX_MF
        module procedure cx_${func}$
#:endif
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Binary real functions (sign, mod, atan2, dim, modulo, hypot, nearest)
    ! ================================================================

#:for func in BINARY_REAL
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: ${func}$

#:endfor
#:set MINMAX_NARG = [3, 4, 5, 6, 7, 8]
#:for func in BINARY_MINMAX
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
#:for n in MINMAX_NARG
        module procedure mf_${func}$${n}$
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Array reductions: value (maxval, minval)
    ! ================================================================

#:for func in ARRAY_REDUCE_VAL
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_${func}$_${rank}$d
        module procedure mf_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Array reductions: location (maxloc, minloc)
    ! ================================================================

#:for func in ARRAY_REDUCE_LOC
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_${func}$_${rank}$d
        module procedure mf_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Array reductions: sum, product (mf + cx)
    ! ================================================================

#:for func in ARRAY_REDUCE_SUM
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_${func}$_${rank}$d
        module procedure mf_${func}$_${rank}$d_dim
        module procedure cx_${func}$_${rank}$d
        module procedure cx_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! dot_product, norm2, findloc, matmul
    ! ================================================================

    interface dot_product
        module procedure mf_dot_product
        module procedure cx_dot_product
    end interface
    public :: dot_product

    interface norm2
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_norm2_${rank}$d
#:if rank > 1
        module procedure mf_norm2_${rank}$d_dim
#:endif
#:endfor
    end interface
    public :: norm2

    interface findloc
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_findloc_${rank}$d
        module procedure mf_findloc_${rank}$d_dim
        module procedure cx_findloc_${rank}$d
        module procedure cx_findloc_${rank}$d_dim
#:endfor
    end interface
    public :: findloc

    interface matmul
        module procedure mf_matmul_mm
        module procedure mf_matmul_mv
        module procedure mf_matmul_vm
        module procedure cx_matmul_mm
        module procedure cx_matmul_mv
        module procedure cx_matmul_vm
    end interface
    public :: matmul

    ! ================================================================
    ! Bessel functions with integer order
    ! ================================================================

#:for func in BESSEL_N
    interface ${func}$
        module procedure mf_${func}$_elem
        module procedure mf_${func}$_range
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Conversions and numeric functions
    ! ================================================================

    interface ceiling
        module procedure mf_ceiling
    end interface
    public :: ceiling

    interface floor
        module procedure mf_floor
    end interface
    public :: floor

    interface exponent
        module procedure mf_exponent
    end interface
    public :: exponent

#:for func in MF_INT_TO_MF
    interface ${func}$
        module procedure mf_${func}$
    end interface
    public :: ${func}$

#:endfor
    ! ================================================================
    ! Numeric inquiry functions
    ! ================================================================

#:for func in INQUIRY_MF_INT
    interface ${func}$
        module procedure mf_${func}$
    end interface
    public :: ${func}$

#:endfor
#:for func in INQUIRY_BOTH_INT
    interface ${func}$
        module procedure mf_${func}$
        module procedure cx_${func}$
    end interface
    public :: ${func}$

#:endfor
    interface storage_size
        module procedure mf_storage_size
        module procedure cx_storage_size
    end interface
    public :: storage_size

    ! ================================================================
    ! Complex-specific: cmplx, real, mf_real
    ! ================================================================

    interface cmplx
        module procedure mf_cmplx_2
        module procedure mf_cmplx_1
    end interface
    public :: cmplx

    interface real
        module procedure cx_real
        module procedure mf_real_mf
    end interface
    public :: real

    interface mf_real
        module procedure mf_real_mf
        module procedure cx_real_mf
    end interface
    public :: mf_real

    ! ================================================================
    ! Conversions: dble, int, nint, mf_to_double
    ! ================================================================

    interface dble
        module procedure mf_dble
    end interface
    public :: dble

    interface int
        module procedure mf_int
    end interface
    public :: int

    interface nint
        module procedure mf_nint
    end interface
    public :: nint

    public :: mf_to_double

    ! ================================================================
    ! random_number (impure subroutine)
    ! ================================================================

    interface random_number
        module procedure mf_random_number_0d
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_random_number_${rank}$d
#:endfor
    end interface
    public :: random_number
    public :: mf_set_fma_renorm_interval

    ! ================================================================
    ! Assignment (=)
    ! ================================================================

    interface assignment(=)
        ! lhs = mf / cx (forward direction: build a multifloat type)
#:for n, _ in ATYPES
#:if n != 'mf'
        module procedure mf_assign_${n}$
#:endif
#:endfor
#:for n, _ in ATYPES
#:if n != 'cx'
        module procedure cx_assign_${n}$
#:endif
#:endfor
        ! Non-default integer kinds → mf / cx
        module procedure mf_assign_i8
        module procedure mf_assign_i16
        module procedure mf_assign_i64
        module procedure cx_assign_i8
        module procedure cx_assign_i16
        module procedure cx_assign_i64
        ! mf → built-in numeric types
        module procedure dp_assign_mf
        module procedure sp_assign_mf
        module procedure int_assign_mf
        module procedure i8_assign_mf
        module procedure i16_assign_mf
        module procedure i64_assign_mf
        module procedure cdp_assign_mf
        module procedure csp_assign_mf
        ! cx → built-in numeric types
        module procedure dp_assign_cx
        module procedure sp_assign_cx
        module procedure int_assign_cx
        module procedure i8_assign_cx
        module procedure i16_assign_cx
        module procedure i64_assign_cx
        module procedure cdp_assign_cx
        module procedure csp_assign_cx
    end interface
    public :: assignment(=)

    ! ================================================================
    ! Defined I/O
    ! ================================================================

    interface write(formatted)
        module procedure write_mf_formatted
        module procedure write_cx_formatted
    end interface
    public :: write(formatted)

    interface read(formatted)
        module procedure read_mf_formatted
        module procedure read_cx_formatted
    end interface
    public :: read(formatted)

    ! ================================================================
    ! Named constants
    ! ================================================================

    type(float64x2), parameter, public :: MF_ZERO  = float64x2([0.0_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_ONE   = float64x2([1.0_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_TWO   = float64x2([2.0_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_HALF  = float64x2([0.5_dp, 0.0_dp])
    type(float64x2), parameter, public :: MF_EIGHT = float64x2([8.0_dp, 0.0_dp])

    type(float64x2), parameter, public :: MF_SAFMIN = float64x2([tiny(0.0_dp),  0.0_dp])
    type(float64x2), parameter, public :: MF_SAFMAX = float64x2([huge(0.0_dp),  0.0_dp])
    type(float64x2), parameter, public :: MF_TSML   = float64x2([1.0e-100_dp,   0.0_dp])
    type(float64x2), parameter, public :: MF_TBIG   = float64x2([1.0e+100_dp,   0.0_dp])
    type(float64x2), parameter, public :: MF_SSML   = float64x2([1.0e-50_dp,    0.0_dp])
    type(float64x2), parameter, public :: MF_SBIG   = float64x2([1.0e+50_dp,    0.0_dp])
    type(float64x2), parameter, public :: MF_RTMIN  = float64x2([1.0e-150_dp,   0.0_dp])
    type(float64x2), parameter, public :: MF_RTMAX  = float64x2([1.0e+150_dp,   0.0_dp])

    ! Renormalization interval for fused multiply-accumulate reductions
    ! (dot_product, matmul). The accumulator s_lo drifts by ~1 ulp per
    ! iteration; renormalizing every MF_FMA_RENORM_INTERVAL steps keeps
    ! worst-case error within ~1e-31 (full DD). Set to 0 to disable
    ! periodic renormalization (single renorm at the end only).
    ! The default of 8 gives near-optimal precision with negligible
    ! overhead (~3 extra FP ops per 8 iterations = ~3% cost).
    integer, public, protected :: MF_FMA_RENORM_INTERVAL = 8

    ! ================================================================
    ! Tables for full-DD exp / log (ported from MultiFloats.jl)
    ! ================================================================

    ! Polynomial coefficients for exp2 (Float64, N=2). 14 entries; the
    ! lo limb is zero for entries 10..14.
    real(dp), parameter :: exp2_coefs_hi(14) = [ &
        ${hex_array(['+0x1.0000000000000p+0000', '+0x1.62E42FEFA39EFp-0001', '+0x1.EBFBDFF82C58Fp-0003', '+0x1.C6B08D704A0C0p-0005', '+0x1.3B2AB6FBA4E77p-0007', '+0x1.5D87FE78A6731p-0010', '+0x1.430912F86C787p-0013', '+0x1.FFCBFC588B0C7p-0017', '+0x1.62C0223A5C863p-0020', '+0x1.B5253D395E80Fp-0024', '+0x1.E4CF5152FBB30p-0028', '+0x1.E8CAC72F6E9E5p-0032', '+0x1.C3C1919538484p-0036', '+0x1.816519F74C4AFp-0040'])}$ ]
    real(dp), parameter :: exp2_coefs_lo(14) = [ &
        ${hex_array_padded(['+0x1.314BACF0323FFp-0113', '+0x1.ABC9E3B39803Fp-0056', '-0x1.5E43A53E454F1p-0057', '-0x1.D3316275139AEp-0059', '+0x1.4E65DFEF67D34p-0062', '+0x1.0717F88815ADFp-0066', '+0x1.BC7CDBCDC0339p-0067', '-0x1.E645E286FE571p-0071', '-0x1.99EF542AA8E1Ep-0074'], 14)}$ ]

    ! exp2 input clamps. Below min: result = 0. Above max: result = inf.
    real(dp), parameter :: exp2_min = ${hex_dp('-0x1.FF00000000000p+0009')}$_dp
    real(dp), parameter :: exp2_max = ${hex_dp('+0x1.FFFFFFFFFFFFFp+0009')}$_dp

    ! High-precision constants needed by exp / log conversions.
    real(dp), parameter :: log2_e_hi = ${hex_dp('+0x1.71547652B82FEp+0000')}$_dp
    real(dp), parameter :: log2_e_lo = ${hex_dp('+0x1.777D0FFDA0D24p-0056')}$_dp
    real(dp), parameter :: ln_2_hi   = ${hex_dp('+0x1.62E42FEFA39EFp-0001')}$_dp
    real(dp), parameter :: ln_2_lo   = ${hex_dp('+0x1.ABC9E3B39803Fp-0056')}$_dp
    real(dp), parameter :: log10_2_hi = ${hex_dp('+0x1.34413509F79FFp-0002')}$_dp
    real(dp), parameter :: log10_2_lo = ${hex_dp('-0x1.9DC1DA994FD21p-0059')}$_dp

    ! log2 polynomial — narrow kernel (used with table lookup).
    ! 7 coefficients; lo limb zero for entries 5..7.
    real(dp), parameter :: log2_narrow_hi(7) = [ &
        ${hex_array(['+0x1.71547652B82FEp+0001', '+0x1.EC709DC3A03FDp-0001', '+0x1.2776C50EF9BFEp-0001', '+0x1.A61762A7ADED9p-0002', '+0x1.484B13D7C0C4Dp-0002', '+0x1.0C9A845FCF968p-0002', '+0x1.C6A48D52BA6C7p-0003'])}$ ]
    real(dp), parameter :: log2_narrow_lo(7) = [ &
        ${hex_array_padded(['+0x1.777D0FFDA0D24p-0055', '+0x1.D27F055486A5Ap-0055', '+0x1.E4B2AE3DCBD87p-0055', '+0x1.90D60ECEBE07Fp-0057'], 7)}$ ]

    ! log2 polynomial — wide kernel (direct path for x near 1).
    ! 9 coefficients; lo limb zero for entries 7..9.
    real(dp), parameter :: log2_wide_hi(9) = [ &
