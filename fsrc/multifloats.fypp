         2.6712179058256416e-18_dp, 2.2368792763711565e-17_dp, &
        -4.246405680857825e-17_dp,  3.494516357745965e-18_dp, &
        -2.4103897311490816e-17_dp, 4.468163526988311e-17_dp, &
        -1.4783628552133162e-17_dp, -3.0880950164975563e-17_dp, &
        -1.670020420476703e-17_dp,  4.3007535189465375e-18_dp, &
         2.7943000056050083e-17_dp, -6.972291600506703e-18_dp, &
        -2.0610765990304212e-17_dp, -1.7498130336849765e-17_dp, &
