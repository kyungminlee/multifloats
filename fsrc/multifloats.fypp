#! multifloats.fypp — Float64x2 multifloats module (generated with fypp)
#!
#! The public generic interface is inherited from the mock scaffold, but the
#! core Float64x2 arithmetic uses explicit 2-limb double-double kernels
#! adapted from external/MultiFloats.jl. Broader transformational and
#! transcendental coverage still routes through REAL(16)/COMPLEX(16) helpers.
#!
#! The interface for float64x2 mirrors REAL(KIND=16) as closely as possible:
#! all mixed-type arithmetic, comparisons, and assignments with real(dp),
#! real(sp), integer, complex(dp), and complex(sp) are supported.
#!
#! =====================================================================
#! Performance note: Fortran ABI overhead (2025-04)
#! =====================================================================
#!
#! The DD kernels (add, mul, div, sqrt, ...) use `elemental` functions
#! on a `sequence` derived type. This design is intentional — it gives
#! automatic whole-array operations and EQUIVALENCE compatibility (needed
#! by some LAPACK routines) — but it carries an inherent ABI cost:
#!
#!   - gfortran passes/returns derived types via hidden pointers (not in
#!     FP registers), adding ~3-7× call overhead vs the C ABI.
#!   - With LTO (OBJECT library + -flto), gfortran inlines the kernels
#!     and eliminates most of this overhead, but its SROA pass does not
#!     fully promote the hidden result pointer to registers, leaving a
#!     ~1.5× residual gap vs C++ on the cheapest ops (add, mul).
#!
#! Benchmarking confirmed that switching to `bind(c)` + `value` args on
#! a `bind(c)` type closes the gap entirely (fc/cw ≈ 1.0× for add, mul,
#! div, sqrt), proving the gap is purely ABI, not codegen. However,
#! `bind(c)` is incompatible with `elemental` and `sequence`, so we keep
#! the current design and accept the ~1.5× overhead on basic arithmetic
#! (which is already 2-10× faster than libquadmath quad precision).
#!
#! To get the fastest possible DD arithmetic from Fortran without LTO,
#! call the C-ABI wrappers in src/multifloats_c.h directly via
#! iso_c_binding interfaces (see test/bench_abi.f90 for an example).
#! =====================================================================

#! =====================================================================
#! Type system metadata
#! =====================================================================
#:set RTYPES = [('mf', 'type(float64x2)'), ('dp', 'real(dp)'), ('sp', 'real(sp)'), ('int', 'integer')]
#:set CTYPES = [('cx', 'type(complex128x2)'), ('cdp', 'complex(dp)'), ('csp', 'complex(sp)')]
#:set ATYPES = RTYPES + CTYPES

#:set CONV = {'mf': 'to_qp({})', 'cx': 'to_cqp({})', 'dp': 'real({}, qp)', 'sp': 'real({}, qp)', 'int': 'real({}, qp)', 'cdp': 'cmplx({}, kind=qp)', 'csp': 'cmplx({}, kind=qp)'}
#:set ISCPLX = {'mf': False, 'cx': True, 'dp': False, 'sp': False, 'int': False, 'cdp': True, 'csp': True}
#:set MFCONV = {'mf': '{}', 'dp': 'mf_from_dp({})', 'sp': 'mf_from_sp({})', 'int': 'mf_from_int({})'}

#! Operator tables
#:set ARITH_OPS = [('+', 'add'), ('-', 'sub'), ('*', 'mul'), ('/', 'div')]
#:set EQ_OPS = [('==', 'eq'), ('/=', 'ne')]
#:set ORD_OPS = [('<', 'lt'), ('>', 'gt'), ('<=', 'le'), ('>=', 'ge')]

#! Unary math function tables
#:set UNARY_MF_MF = ['abs', 'sqrt', 'sin', 'cos', 'tan', 'sinpi', 'cospi', 'tanpi', 'exp', 'log', 'log10', 'atan', 'asin', 'acos', 'atanpi', 'asinpi', 'acospi', 'aint', 'anint', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh', 'erf', 'erfc', 'erfc_scaled', 'gamma', 'log_gamma', 'bessel_j0', 'bessel_j1', 'bessel_y0', 'bessel_y1', 'fraction', 'rrspacing', 'spacing', 'epsilon', 'huge', 'tiny']
#:set UNARY_CX_CX = ['sqrt', 'sin', 'cos', 'tan', 'exp', 'log', 'atan', 'asin', 'acos', 'conjg', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh']
#:set UNARY_CX_MF = ['abs', 'aimag']
#:set ALL_UNARY = sorted(set(UNARY_MF_MF + UNARY_CX_CX + UNARY_CX_MF))

#! Binary real function tables
#:set BINARY_REAL = ['sign', 'mod', 'atan2', 'atan2pi', 'dim', 'modulo', 'hypot', 'nearest']
#:set BINARY_MINMAX = ['min', 'max']

#! Array reduction function tables
#:set ARRAY_REDUCE_VAL = ['maxval', 'minval']
#:set ARRAY_REDUCE_LOC = ['maxloc', 'minloc']
#:set ARRAY_REDUCE_SUM = ['sum', 'product']

#! Bessel functions with integer order
#:set BESSEL_N = ['bessel_jn', 'bessel_yn']

#! Functions: (mf, integer) → mf
#:set MF_INT_TO_MF = ['scale', 'set_exponent']

#! Inquiry functions
#:set INQUIRY_MF_INT = ['digits', 'maxexponent', 'minexponent', 'radix']
#:set INQUIRY_BOTH_INT = ['precision', 'range']

#! =====================================================================
#! Rank-generic helpers
#! =====================================================================
#:set MAX_RANK = 7
#:set COLONS = lambda r: ', '.join([':'] * r)
#:set SIZES = lambda r, v='array': (', &\n' + ' '*12).join(['size(%s,%d)' % (v, i) for i in range(1, r+1)]) if r > 4 else ', '.join(['size(%s,%d)' % (v, i) for i in range(1, r+1)])
#:set IDXS = lambda r: ', '.join(['i%d' % i for i in range(1, r+1)])
#:set IVARS = lambda r: ', '.join(['i%d' % i for i in range(1, r+1)])
#:set OUT_IDXS = lambda r, d: ', '.join(['i%d' % i for i in range(1, r+1) if i != d])
#:set SURVIVOR_DIMS = lambda r, d: [i for i in range(1, r+1) if i != d]
#:set DIM_REDUCED_SIZES = lambda r: (', &\n' + ' '*12).join(['merge(size(array,%d),size(array,%d),dim<=%d)' % (j+1,j,j) for j in range(1, r)])

#! Convert a Julia / C99 hex floating-point literal to a Fortran double
#! literal body via Python's float.fromhex + repr (round-trip exact).
#:set hex_dp = lambda h: repr(float.fromhex(h))
#:set hex_array = lambda lst: (', &\n        ').join([hex_dp(h) + '_dp' for h in lst])
#:set hex_array_padded = lambda lst, n: hex_array(lst + ['0x0p+0'] * (n - len(lst)))

#! Inline function: generate nested conversion loops
#:set conv_loops = lambda r, src, dst, func: '\n'.join(['        do i%d = 1, size(%s, %d)' % (d, src, d) for d in range(r, 0, -1)] + ['            %s(%s) = %s(%s(%s))' % (dst, IDXS(r), func, src, IDXS(r))] + ['        end do'] * r)

module multifloats
    use, intrinsic :: ieee_arithmetic, only: ieee_is_finite, ieee_is_nan, &
                                              ieee_value, ieee_quiet_nan,  &
                                              ieee_positive_inf, ieee_negative_inf
    use, intrinsic :: iso_fortran_env, only: int8, int16, int32, int64
    use, intrinsic :: iso_c_binding, only: c_double, c_int64_t, c_ptr, c_loc
    implicit none
    private

    ! Wrap C's fma() as a pure elemental function. ieee_fma from
    ! ieee_arithmetic is impure in gfortran <= 12, so we bypass it.
    interface
        pure function c_fma(x, y, z) bind(c, name="fma")
            import :: c_double
            real(c_double), value, intent(in) :: x, y, z
            real(c_double) :: c_fma
        end function
    end interface

    ! C-ABI matmul kernels (defined in multifloats_math.cc). The Fortran
    ! float64x2 type has SEQUENCE layout [hi, lo] which is bit-compatible
    ! with the C dd_t struct, so we pass arrays by c_loc. The final
    ! renorm_interval arg mirrors MF_FMA_RENORM_INTERVAL (0 = off).
    interface
        pure subroutine c_dd_matmul_mm(a, b, c, m, k, n, ri) &
                bind(c, name="dd_matmul_mm")
            import :: c_ptr, c_int64_t
            type(c_ptr), value, intent(in) :: a, b, c
            integer(c_int64_t), value, intent(in) :: m, k, n, ri
        end subroutine
        pure subroutine c_dd_matmul_mv(a, x, y, m, k, ri) &
                bind(c, name="dd_matmul_mv")
            import :: c_ptr, c_int64_t
            type(c_ptr), value, intent(in) :: a, x, y
            integer(c_int64_t), value, intent(in) :: m, k, ri
        end subroutine
        pure subroutine c_dd_matmul_vm(x, b, y, k, n, ri) &
                bind(c, name="dd_matmul_vm")
            import :: c_ptr, c_int64_t
            type(c_ptr), value, intent(in) :: x, b, y
            integer(c_int64_t), value, intent(in) :: k, n, ri
        end subroutine
    end interface

#:if defined('MULTIFLOATS_NO_QUAD')
#:set HAS_QUAD = False
#:else
#:set HAS_QUAD = True
#:endif
    integer, parameter :: dp = 8   ! Double precision
    integer, parameter :: sp = 4   ! Single precision
#:if HAS_QUAD
    integer, parameter :: qp = 16  ! Quad precision (not available on all compilers)
#:endif

    ! SEQUENCE is required so derived-type variables of these types may
    ! appear in EQUIVALENCE statements (used by some LAPACK routines
    ! such as DLALN2/wlaln2 to overlay 2x2 work arrays with linearized
    ! vectors).
    type, public :: float64x2
        sequence
        real(dp) :: limbs(2)
    end type float64x2

    type, public :: complex128x2
        sequence
        type(float64x2) :: re, im
    end type complex128x2

    ! ================================================================
    ! PUBLIC INTERFACE
    ! ================================================================

    ! ----------------------------------------------------------------
    ! Constructors
    ! ----------------------------------------------------------------

    interface float64x2
        module procedure mf_from_mf
        module procedure mf_from_dp
        module procedure mf_from_sp
        module procedure mf_from_int
        module procedure mf_from_i8
        module procedure mf_from_i16
        module procedure mf_from_i64
        module procedure mf_from_char
        module procedure mf_from_cx
        module procedure mf_from_cdp
        module procedure mf_from_csp
    end interface float64x2

    interface complex128x2
        module procedure cx_from_cx
        ! Two-argument (re, im) constructors — matching kinds.
        module procedure cx_from_mf_2
        module procedure cx_from_dp_2
        module procedure cx_from_sp_2
        module procedure cx_from_int_2
        module procedure cx_from_i8_2
        module procedure cx_from_i16_2
        module procedure cx_from_i64_2
        ! Two-argument (re, im) constructors — common mixed kinds.
        module procedure cx_from_mf_dp_2
        module procedure cx_from_dp_mf_2
        ! Single-argument constructors (imag = 0).
        module procedure cx_from_mf_1
        module procedure cx_from_dp_1
        module procedure cx_from_sp_1
        module procedure cx_from_int_1
        module procedure cx_from_i8_1
        module procedure cx_from_i16_1
        module procedure cx_from_i64_1
        module procedure cx_from_cdp_1
        module procedure cx_from_csp_1
    end interface complex128x2

    ! ----------------------------------------------------------------
    ! Arithmetic operators (+, -, *, /)
    ! ----------------------------------------------------------------

#:for opsym, opname in ARITH_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
#:if opsym == '-'
        module procedure mf_neg
        module procedure cx_neg
#:endif
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ----------------------------------------------------------------
    ! Power operator (**)
    ! ----------------------------------------------------------------

    interface operator(**)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_pow_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(**)

    ! ----------------------------------------------------------------
    ! Equality comparison (==, /=) — all type pairs
    ! ----------------------------------------------------------------

#:for opsym, opname in EQ_OPS
    interface operator(${opsym}$)
#:for n1, _ in ATYPES
#:for n2, _ in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ----------------------------------------------------------------
    ! Ordered comparison (<, >, <=, >=) — real types only
    ! ----------------------------------------------------------------

#:for opsym, opname in ORD_OPS
    interface operator(${opsym}$)
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${opname}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: operator(${opsym}$)

#:endfor
    ! ----------------------------------------------------------------
    ! Unary math generics
    ! ----------------------------------------------------------------

#:for func in ALL_UNARY
    interface ${func}$
#:if func in UNARY_MF_MF
        module procedure mf_${func}$
#:endif
#:if func in UNARY_CX_CX or func in UNARY_CX_MF
        module procedure cx_${func}$
#:endif
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Binary real functions (sign, mod, atan2, dim, modulo, hypot, nearest)
    ! ----------------------------------------------------------------

#:for func in BINARY_REAL
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
    end interface
    public :: ${func}$

#:endfor
#:set MINMAX_NARG = [3, 4, 5, 6, 7, 8]
#:for func in BINARY_MINMAX
    interface ${func}$
#:for n1, _ in RTYPES
#:for n2, _ in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
        module procedure ${n1}$_${func}$_${n2}$
#:endif
#:endfor
#:endfor
#:for n in MINMAX_NARG
        module procedure mf_${func}$${n}$
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: value (maxval, minval)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_VAL
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_${func}$_${rank}$d
        module procedure mf_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: location (maxloc, minloc)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_LOC
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_${func}$_${rank}$d
        module procedure mf_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: sum, product (mf + cx)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_SUM
    interface ${func}$
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_${func}$_${rank}$d
        module procedure mf_${func}$_${rank}$d_dim
        module procedure cx_${func}$_${rank}$d
        module procedure cx_${func}$_${rank}$d_dim
#:endfor
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! dot_product, norm2, findloc, matmul
    ! ----------------------------------------------------------------

    interface dot_product
        module procedure mf_dot_product
        module procedure cx_dot_product
    end interface
    public :: dot_product

    interface norm2
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_norm2_${rank}$d
#:if rank > 1
        module procedure mf_norm2_${rank}$d_dim
#:endif
#:endfor
    end interface
    public :: norm2

    interface findloc
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_findloc_${rank}$d
        module procedure mf_findloc_${rank}$d_dim
        module procedure cx_findloc_${rank}$d
        module procedure cx_findloc_${rank}$d_dim
#:endfor
    end interface
    public :: findloc

    interface matmul
        module procedure mf_matmul_mm
        module procedure mf_matmul_mv
        module procedure mf_matmul_vm
        module procedure cx_matmul_mm
        module procedure cx_matmul_mv
        module procedure cx_matmul_vm
    end interface
    public :: matmul

    ! ----------------------------------------------------------------
    ! Bessel functions with integer order
    ! ----------------------------------------------------------------

#:for func in BESSEL_N
    interface ${func}$
        module procedure mf_${func}$_elem
        module procedure mf_${func}$_range
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Conversions and numeric functions
    ! ----------------------------------------------------------------

    interface ceiling
        module procedure mf_ceiling
    end interface
    public :: ceiling

    interface floor
        module procedure mf_floor
    end interface
    public :: floor

    interface exponent
        module procedure mf_exponent
    end interface
    public :: exponent

#:for func in MF_INT_TO_MF
    interface ${func}$
        module procedure mf_${func}$
    end interface
    public :: ${func}$

#:endfor
    ! ----------------------------------------------------------------
    ! Numeric inquiry functions
    ! ----------------------------------------------------------------

#:for func in INQUIRY_MF_INT
    interface ${func}$
        module procedure mf_${func}$
    end interface
    public :: ${func}$

#:endfor
#:for func in INQUIRY_BOTH_INT
    interface ${func}$
        module procedure mf_${func}$
        module procedure cx_${func}$
    end interface
    public :: ${func}$

#:endfor
    interface storage_size
        module procedure mf_storage_size
        module procedure cx_storage_size
    end interface
    public :: storage_size

    ! ----------------------------------------------------------------
    ! Complex-specific: cmplx, real, mf_real
    ! ----------------------------------------------------------------

    interface cmplx
        module procedure mf_cmplx_2
        module procedure mf_cmplx_1
    end interface
    public :: cmplx

    interface real
        module procedure cx_real
        module procedure mf_real_mf
    end interface
    public :: real

    interface mf_real
        module procedure mf_real_mf
        module procedure cx_real_mf
    end interface
    public :: mf_real

    ! ----------------------------------------------------------------
    ! Conversions: dble, int, nint, mf_to_double
    ! ----------------------------------------------------------------

    interface dble
        module procedure mf_dble
    end interface
    public :: dble

    interface int
        module procedure mf_int
    end interface
    public :: int

    interface nint
        module procedure mf_nint
    end interface
    public :: nint

    public :: mf_to_double

    ! ----------------------------------------------------------------
    ! random_number (impure subroutine)
    ! ----------------------------------------------------------------

    interface random_number
        module procedure mf_random_number_0d
#:for rank in range(1, MAX_RANK+1)
        module procedure mf_random_number_${rank}$d
#:endfor
    end interface
    public :: random_number
    public :: mf_set_fma_renorm_interval

    ! ----------------------------------------------------------------
    ! Assignment (=)
    ! ----------------------------------------------------------------

    interface assignment(=)
        ! lhs = mf / cx (forward direction: build a multifloat type)
#:for n, _ in ATYPES
#:if n != 'mf'
        module procedure mf_assign_${n}$
#:endif
#:endfor
#:for n, _ in ATYPES
#:if n != 'cx'
        module procedure cx_assign_${n}$
#:endif
#:endfor
        ! Non-default integer kinds → mf / cx
        module procedure mf_assign_i8
        module procedure mf_assign_i16
        module procedure mf_assign_i64
        module procedure cx_assign_i8
        module procedure cx_assign_i16
        module procedure cx_assign_i64
        ! mf → built-in numeric types
        module procedure dp_assign_mf
        module procedure sp_assign_mf
        module procedure int_assign_mf
        module procedure i8_assign_mf
        module procedure i16_assign_mf
        module procedure i64_assign_mf
        module procedure cdp_assign_mf
        module procedure csp_assign_mf
        ! cx → built-in numeric types
        module procedure dp_assign_cx
        module procedure sp_assign_cx
        module procedure int_assign_cx
        module procedure i8_assign_cx
        module procedure i16_assign_cx
        module procedure i64_assign_cx
        module procedure cdp_assign_cx
        module procedure csp_assign_cx
    end interface
    public :: assignment(=)

    ! ----------------------------------------------------------------
    ! Defined I/O
    ! ----------------------------------------------------------------

    interface write(formatted)
        module procedure write_mf_formatted
        module procedure write_cx_formatted
    end interface
    public :: write(formatted)

    interface read(formatted)
        module procedure read_mf_formatted
        module procedure read_cx_formatted
    end interface
    public :: read(formatted)

    ! ----------------------------------------------------------------
    ! Named constants
    ! ----------------------------------------------------------------

    ! Named constants — using component initialization for portability
    ! (flang does not support sequence-type structure constructors in
    ! constant expressions).
#:def MF_CONST(name, val)
    type(float64x2), parameter, public :: ${name}$ = &
        float64x2(limbs=[${val}$, 0.0_dp])
#:enddef
    $:MF_CONST('MF_ZERO',   '0.0_dp')
    $:MF_CONST('MF_ONE',    '1.0_dp')
    $:MF_CONST('MF_TWO',    '2.0_dp')
    $:MF_CONST('MF_HALF',   '0.5_dp')
    $:MF_CONST('MF_EIGHT',  '8.0_dp')
    $:MF_CONST('MF_SAFMIN', '2.2250738585072014e-308_dp')
    $:MF_CONST('MF_SAFMAX', '1.7976931348623157e+308_dp')
    $:MF_CONST('MF_TSML',   '1.0e-100_dp')
    $:MF_CONST('MF_TBIG',   '1.0e+100_dp')
    $:MF_CONST('MF_SSML',   '1.0e-50_dp')
    $:MF_CONST('MF_SBIG',   '1.0e+50_dp')
    $:MF_CONST('MF_RTMIN',  '1.0e-150_dp')
    $:MF_CONST('MF_RTMAX',  '1.0e+150_dp')

    ! Renormalization interval for fused multiply-accumulate reductions
    ! (dot_product, matmul). The accumulator s_lo drifts by ~1 ulp per
    ! iteration; renormalizing every MF_FMA_RENORM_INTERVAL steps keeps
    ! worst-case error within ~1e-31 (full DD). Set to 0 to disable
    ! periodic renormalization (single renorm at the end only).
    ! The default of 8 gives near-optimal precision with negligible
    ! overhead (~3 extra FP ops per 8 iterations = ~3% cost).
    integer, public, protected :: MF_FMA_RENORM_INTERVAL = 8

    ! ================================================================
    ! MODULE DATA, CONSTANTS & C-ABI INTERFACES
    ! ================================================================

    ! ----------------------------------------------------------------
    ! Polynomial and conversion constants
    ! (generated by scripts/gen_constants.py)
    ! ----------------------------------------------------------------
    include 'dd_constants.f90.inc'

    ! ----------------------------------------------------------------
    ! C-ABI interfaces for DD math kernels (defined in src/multifloats_math.cc).
    ! The Fortran wrappers below each delegate to one of these, keeping the
    ! algorithmic implementation single-sourced in C++.
    ! ----------------------------------------------------------------
    type, bind(c) :: dd_t
        real(c_double) :: hi, lo
    end type dd_t

    type, bind(c) :: cdd_t
        type(dd_t) :: re, im
    end type cdd_t

#! Complex DD transcendentals delegated to C dd_cx_* kernels. Function names
#! are uniform (dd_cx_<func>) so no map is needed — the Fortran-side name is
#! always `cx_<func>`, the C symbol is always `dd_cx_<func>`.
#:set C_DELEGATE_CX_UNARY_FUNCS = ['sqrt', 'exp', 'log', 'sin', 'cos', 'tan', &
    'asin', 'acos', 'atan', 'sinh', 'cosh', 'tanh', 'asinh', 'acosh', 'atanh']

#! (fortran_full_name, c_symbol) pairs for DD math kernels implemented in
#! src/multifloats_math.cc. The Fortran side exposes these as elemental
#! wrappers generated by C_DELEGATE_UNARY / C_DELEGATE_BINARY below, so the
#! algorithm lives in C++ only.
#:set C_DELEGATE_UNARY_MAP = [ &
    ('dd_sqrt_full',      'dd_sqrt'),   &
    ('dd_trunc_full',     'dd_trunc'),  &
    ('dd_round_full',     'dd_round'),  &
    ('dd_exp2_full',      'dd_exp2'),   &
    ('dd_exp_full',       'dd_exp'),    &
    ('dd_log2_full',      'dd_log2'),   &
    ('dd_log_full',       'dd_log'),    &
    ('dd_log10_full',     'dd_log10'),  &
    ('dd_sin_full',       'dd_sin'),    &
    ('dd_cos_full',       'dd_cos'),    &
    ('dd_tan_full',       'dd_tan'),    &
    ('dd_asin_full',      'dd_asin'),   &
    ('dd_acos_full',      'dd_acos'),   &
    ('dd_atan_full',      'dd_atan'),   &
    ('dd_sinpi_full',     'dd_sinpi'),  &
    ('dd_cospi_full',     'dd_cospi'),  &
    ('dd_tanpi_full',     'dd_tanpi'),  &
    ('dd_asinpi_full',    'dd_asinpi'), &
    ('dd_acospi_full',    'dd_acospi'), &
    ('dd_atanpi_full',    'dd_atanpi'), &
    ('dd_sinh_full',      'dd_sinh'),   &
    ('dd_cosh_full',      'dd_cosh'),   &
    ('dd_tanh_full',      'dd_tanh'),   &
    ('dd_asinh_full',     'dd_asinh'),  &
    ('dd_acosh_full',     'dd_acosh'),  &
    ('dd_atanh_full',     'dd_atanh'),  &
    ('dd_erf_full',         'dd_erf'),    &
    ('dd_erfc_full',        'dd_erfc'),   &
    ('dd_erfc_scaled_full', 'dd_erfcx'),  &
    ('dd_gamma_full',     'dd_tgamma'), &
    ('dd_log_gamma_full', 'dd_lgamma'), &
    ('dd_bessel_j0_full', 'dd_j0'),     &
    ('dd_bessel_j1_full', 'dd_j1'),     &
    ('dd_bessel_y0_full', 'dd_y0'),     &
    ('dd_bessel_y1_full', 'dd_y1') ]
#:set C_DELEGATE_BINARY_MAP = [ &
    ('dd_atan2_full',   'dd_atan2'),   &
    ('dd_atan2pi_full', 'dd_atan2pi'), &
    ('dd_hypot_full',   'dd_hypot'),   &
    ('dd_fmod_full',    'dd_fmod') ]

    interface
#:for _ffull, csym in C_DELEGATE_UNARY_MAP
        pure type(dd_t) function c_${csym}$(a) bind(c, name='${csym}$')
            import :: dd_t; type(dd_t), value, intent(in) :: a
        end function
#:endfor
#:for _ffull, csym in C_DELEGATE_BINARY_MAP
        pure type(dd_t) function c_${csym}$(a, b) bind(c, name='${csym}$')
            import :: dd_t; type(dd_t), value, intent(in) :: a, b
        end function
#:endfor
#:for func in C_DELEGATE_CX_UNARY_FUNCS
        pure type(cdd_t) function c_dd_cx_${func}$(a) bind(c, name='dd_cx_${func}$')
            import :: cdd_t; type(cdd_t), value, intent(in) :: a
        end function
#:endfor
    end interface

#! Elemental wrapper: Fortran `ffull(x)` → C `csym(dd_t)`.
#:def C_DELEGATE_UNARY(ffull, csym)
    elemental function ${ffull}$(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        type(dd_t) :: r
        r = c_${csym}$(dd_t(x%limbs(1), x%limbs(2)))
        res%limbs = [r%hi, r%lo]
    end function
#:enddef

#! Elemental wrapper: Fortran `ffull(a, b)` → C `csym(dd_t, dd_t)`.
#:def C_DELEGATE_BINARY(ffull, csym)
    elemental function ${ffull}$(a, b) result(res)
        type(float64x2), intent(in) :: a, b
        type(float64x2) :: res
        type(dd_t) :: r
        r = c_${csym}$(dd_t(a%limbs(1), a%limbs(2)), dd_t(b%limbs(1), b%limbs(2)))
        res%limbs = [r%hi, r%lo]
    end function
#:enddef

contains

    ! ================================================================
    ! PROCEDURE IMPLEMENTATIONS
    ! ================================================================

    ! ----------------------------------------------------------------
    ! Internal conversion helpers (elemental)
    ! ----------------------------------------------------------------

#:if HAS_QUAD
    elemental function to_qp(mf) result(res)
        type(float64x2), intent(in) :: mf
        real(qp) :: res
        res = real(mf%limbs(1), qp) + real(mf%limbs(2), qp)
    end function

    elemental function from_qp(v) result(res)
        real(qp), intent(in) :: v
        type(float64x2) :: res
        real(dp) :: s, bprime
        if (.not. ieee_is_finite(v)) then
            res%limbs = [real(v, dp), 0.0_dp]
        else
            res%limbs(1) = real(v, dp)
            res%limbs(2) = real(v - real(res%limbs(1), qp), dp)
            s = res%limbs(1) + res%limbs(2)
            bprime = s - res%limbs(1)
            res%limbs(2) = res%limbs(2) - bprime
            res%limbs(1) = s
        end if
    end function

    elemental function to_cqp(cx) result(res)
        type(complex128x2), intent(in) :: cx
        complex(qp) :: res
        res = cmplx(to_qp(cx%re), to_qp(cx%im), kind=qp)
    end function

    elemental function from_cqp(v) result(res)
        complex(qp), intent(in) :: v
        type(complex128x2) :: res
        res%re = from_qp(real(v, qp))
        res%im = from_qp(aimag(v))
    end function
#:endif

    ! ----------------------------------------------------------------
    ! Constructors
    ! ----------------------------------------------------------------

    elemental function mf_from_mf(v) result(res)
        type(float64x2), intent(in) :: v
        type(float64x2) :: res
        res = v
    end function

    elemental function mf_from_dp(v) result(res)
        real(dp), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [v, 0.0_dp]
    end function

    elemental function mf_from_sp(v) result(res)
        real(sp), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_int(v) result(res)
        integer, intent(in) :: v
        type(float64x2) :: res
        ! Default integer kind is 32-bit and fits exactly in dp.
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_i8(v) result(res)
        integer(int8), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_i16(v) result(res)
        integer(int16), intent(in) :: v
        type(float64x2) :: res
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    elemental function mf_from_i64(v) result(res)
        integer(int64), intent(in) :: v
        type(float64x2) :: res
        ! int64 → dp may lose the bottom 11 bits when |v| >= 2^53.
        res%limbs = [real(v, dp), 0.0_dp]
    end function

    function mf_from_char(v) result(res)
        character(len=*), intent(in) :: v
        type(float64x2) :: res
#:if HAS_QUAD
        real(qp) :: val_qp
        read(v, *) val_qp
        res = from_qp(val_qp)
#:else
        ! Without quad precision, parse to double (loses low limb).
        read(v, *) res%limbs(1)
        res%limbs(2) = 0.0_dp
#:endif
    end function

    elemental function mf_from_cx(cx) result(res)
        type(complex128x2), intent(in) :: cx
        type(float64x2) :: res
        res = cx%re
    end function

    elemental function mf_from_cdp(x) result(res)
        complex(dp), intent(in) :: x
        type(float64x2) :: res
        res%limbs = [real(x, dp), 0.0_dp]
    end function

    elemental function mf_from_csp(x) result(res)
        complex(sp), intent(in) :: x
        type(float64x2) :: res
        res%limbs = [real(real(x, sp), dp), 0.0_dp]
    end function

    elemental function cx_from_cx(v) result(res)
        type(complex128x2), intent(in) :: v
        type(complex128x2) :: res
        res = v
    end function

    elemental function cx_from_mf_2(r, i) result(res)
        type(float64x2), intent(in) :: r, i
        type(complex128x2) :: res
        res%re = r
        res%im = i
    end function

    elemental function cx_from_dp_2(r, i) result(res)
        real(dp), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im%limbs = [i, 0.0_dp]
    end function

    elemental function cx_from_mf_1(r) result(res)
        type(float64x2), intent(in) :: r
        type(complex128x2) :: res
        res%re = r
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_dp_1(r) result(res)
        real(dp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    ! Two-argument matching-kind constructors for the remaining real /
    ! integer kinds. Each promotes both operands to dp before storing.

    elemental function cx_from_sp_2(r, i) result(res)
        real(sp), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_int_2(r, i) result(res)
        integer, intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_i8_2(r, i) result(res)
        integer(int8), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_i16_2(r, i) result(res)
        integer(int16), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    elemental function cx_from_i64_2(r, i) result(res)
        integer(int64), intent(in) :: r, i
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [real(i, dp), 0.0_dp]
    end function

    ! Mixed (mf, dp) and (dp, mf) — common when one part has been
    ! computed in DD and the other is still a literal double.

    elemental function cx_from_mf_dp_2(r, i) result(res)
        type(float64x2), intent(in) :: r
        real(dp), intent(in) :: i
        type(complex128x2) :: res
        res%re = r
        res%im%limbs = [i, 0.0_dp]
    end function

    elemental function cx_from_dp_mf_2(r, i) result(res)
        real(dp), intent(in) :: r
        type(float64x2), intent(in) :: i
        type(complex128x2) :: res
        res%re%limbs = [r, 0.0_dp]
        res%im = i
    end function

    ! Single-argument constructors for the remaining numeric kinds
    ! (imag set to 0).

    elemental function cx_from_sp_1(r) result(res)
        real(sp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_int_1(r) result(res)
        integer, intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_i8_1(r) result(res)
        integer(int8), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_i16_1(r) result(res)
        integer(int16), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_i64_1(r) result(res)
        integer(int64), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_from_cdp_1(r) result(res)
        complex(dp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(r, dp), 0.0_dp]
        res%im%limbs = [aimag(r), 0.0_dp]
    end function

    elemental function cx_from_csp_1(r) result(res)
        complex(sp), intent(in) :: r
        type(complex128x2) :: res
        res%re%limbs = [real(real(r, sp), dp), 0.0_dp]
        res%im%limbs = [real(aimag(r), dp), 0.0_dp]
    end function

    ! ----------------------------------------------------------------
    ! Assignment (elemental)
    ! ----------------------------------------------------------------

#:for n, d in ATYPES
#:if n != 'mf'
    elemental subroutine mf_assign_${n}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if n == 'dp'
        lhs%limbs = [rhs, 0.0_dp]
#:elif n == 'sp'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'int'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'cx'
        lhs = rhs%re
#:elif n == 'cdp'
        lhs%limbs = [real(rhs, dp), 0.0_dp]
#:elif n == 'csp'
        lhs%limbs = [real(real(rhs, sp), dp), 0.0_dp]
#:endif
    end subroutine

#:endif
#:endfor
#:for n, d in ATYPES
#:if n != 'cx'
    elemental subroutine cx_assign_${n}$(lhs, rhs)
        type(complex128x2), intent(out) :: lhs
        ${d}$, intent(in) :: rhs
#:if n == 'mf'
        lhs%re = rhs
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'dp'
        lhs%re%limbs = [rhs, 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'sp'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'int'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
#:elif n == 'cdp'
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [aimag(rhs), 0.0_dp]
#:elif n == 'csp'
        lhs%re%limbs = [real(real(rhs, sp), dp), 0.0_dp]
        lhs%im%limbs = [real(aimag(rhs), dp), 0.0_dp]
#:endif
    end subroutine

#:endif
#:endfor
    ! ----------------------------------------------------------------
    ! Non-default integer kinds → mf / cx
    ! ----------------------------------------------------------------

#:for ksuf, ktype in [('i8', 'integer(int8)'), ('i16', 'integer(int16)'), ('i64', 'integer(int64)')]
    elemental subroutine mf_assign_${ksuf}$(lhs, rhs)
        type(float64x2), intent(out) :: lhs
        ${ktype}$, intent(in) :: rhs
        lhs%limbs = [real(rhs, dp), 0.0_dp]
    end subroutine

    elemental subroutine cx_assign_${ksuf}$(lhs, rhs)
        type(complex128x2), intent(out) :: lhs
        ${ktype}$, intent(in) :: rhs
        lhs%re%limbs = [real(rhs, dp), 0.0_dp]
        lhs%im%limbs = [0.0_dp, 0.0_dp]
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! mf → built-in numeric types (truncation for integer kinds, mirrors
    ! the same semantics as `int_var = real_dp_var` in plain Fortran).
    ! ----------------------------------------------------------------

    elemental subroutine dp_assign_mf(lhs, rhs)
        real(dp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = rhs%limbs(1)
    end subroutine

    elemental subroutine sp_assign_mf(lhs, rhs)
        real(sp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = real(rhs%limbs(1), sp)
    end subroutine

    elemental subroutine cdp_assign_mf(lhs, rhs)
        complex(dp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = cmplx(rhs%limbs(1), 0.0_dp, dp)
    end subroutine

    elemental subroutine csp_assign_mf(lhs, rhs)
        complex(sp), intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        lhs = cmplx(real(rhs%limbs(1), sp), 0.0_sp, sp)
    end subroutine

#:for ksuf, ktype, klit in [('int', 'integer', 'int32'), ('i8', 'integer(int8)', 'int8'), ('i16', 'integer(int16)', 'int16'), ('i64', 'integer(int64)', 'int64')]
    elemental subroutine ${ksuf}$_assign_mf(lhs, rhs)
        ${ktype}$, intent(out) :: lhs
        type(float64x2), intent(in) :: rhs
        real(dp) :: hi
        hi = rhs%limbs(1)
        lhs = int(hi, kind(lhs))
        ! Adjust toward zero when the leading limb is exactly an integer
        ! and the lo limb pushes the true value across the boundary.
        if (hi == real(lhs, dp)) then
            if (lhs > 0 .and. rhs%limbs(2) < 0.0_dp) lhs = lhs - 1_${klit}$
            if (lhs < 0 .and. rhs%limbs(2) > 0.0_dp) lhs = lhs + 1_${klit}$
        end if
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! cx → built-in numeric types (real types take the real part;
    ! integer kinds truncate the real part toward zero).
    ! ----------------------------------------------------------------

    elemental subroutine dp_assign_cx(lhs, rhs)
        real(dp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = rhs%re%limbs(1)
    end subroutine

    elemental subroutine sp_assign_cx(lhs, rhs)
        real(sp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = real(rhs%re%limbs(1), sp)
    end subroutine

    elemental subroutine cdp_assign_cx(lhs, rhs)
        complex(dp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = cmplx(rhs%re%limbs(1), rhs%im%limbs(1), dp)
    end subroutine

    elemental subroutine csp_assign_cx(lhs, rhs)
        complex(sp), intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        lhs = cmplx(real(rhs%re%limbs(1), sp), real(rhs%im%limbs(1), sp), sp)
    end subroutine

#:for ksuf, ktype, klit in [('int', 'integer', 'int32'), ('i8', 'integer(int8)', 'int8'), ('i16', 'integer(int16)', 'int16'), ('i64', 'integer(int64)', 'int64')]
    elemental subroutine ${ksuf}$_assign_cx(lhs, rhs)
        ${ktype}$, intent(out) :: lhs
        type(complex128x2), intent(in) :: rhs
        real(dp) :: hi
        hi = rhs%re%limbs(1)
        lhs = int(hi, kind(lhs))
        if (hi == real(lhs, dp)) then
            if (lhs > 0 .and. rhs%re%limbs(2) < 0.0_dp) lhs = lhs - 1_${klit}$
            if (lhs < 0 .and. rhs%re%limbs(2) > 0.0_dp) lhs = lhs + 1_${klit}$
        end if
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! Conversions (elemental)
    ! ----------------------------------------------------------------

    elemental function mf_dble(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        ! For a normalized DD, |lo| <= ulp(hi)/2, so the round-to-nearest
        ! double of hi+lo is exactly hi.
        res = x%limbs(1)
    end function

    elemental function mf_int(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = int(hi)
        if (hi == real(res, dp)) then
            ! hi is exactly an integer; the lo limb determines whether
            ! the true value crosses an integer boundary toward zero.
            if (res > 0 .and. x%limbs(2) < 0.0_dp) res = res - 1
            if (res < 0 .and. x%limbs(2) > 0.0_dp) res = res + 1
        end if
    end function

    elemental function mf_nint(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        ! For all values where the closest integer is unambiguous, the
        ! leading limb suffices: |lo| <= ulp(hi)/2 < 1/2.
        res = nint(x%limbs(1))
    end function

    elemental function mf_to_double(x) result(res)
        type(float64x2), intent(in) :: x
        real(dp) :: res
        res = x%limbs(1)
    end function

    elemental function mf_ceiling(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = ceiling(hi)
        if (hi == real(res, dp) .and. x%limbs(2) > 0.0_dp) res = res + 1
    end function

    elemental function mf_floor(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        real(dp) :: hi
        hi = x%limbs(1)
        res = floor(hi)
        if (hi == real(res, dp) .and. x%limbs(2) < 0.0_dp) res = res - 1
    end function

    elemental function mf_exponent(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = exponent(x%limbs(1))
    end function

    ! ----------------------------------------------------------------
    ! Unary operators (elemental)
    ! ----------------------------------------------------------------

    elemental function mf_neg(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res%limbs = -x%limbs
    end function

    elemental function cx_neg(x) result(res)
        type(complex128x2), intent(in) :: x
        type(complex128x2) :: res
        res%re%limbs = -x%re%limbs
        res%im%limbs = -x%im%limbs
    end function

    ! ----------------------------------------------------------------
    ! Thin wrappers around the DD math kernels in src/multifloats_math.cc.
    ! The algorithmic implementation is single-sourced in C++; Fortran
    ! delegates via the C-ABI declarations at the top of this module.
    ! ----------------------------------------------------------------
#:for ffull, csym in C_DELEGATE_UNARY_MAP
$:C_DELEGATE_UNARY(ffull, csym)
#:endfor
#:for ffull, csym in C_DELEGATE_BINARY_MAP
$:C_DELEGATE_BINARY(ffull, csym)
#:endfor

    ! ----------------------------------------------------------------
    ! Unary math: mf → mf (elemental)
    ! ----------------------------------------------------------------

#:for func in UNARY_MF_MF
    elemental function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
#:if func == 'abs'
        ! IEEE abs: also flips signed-zero -0 to +0. Use sign() rather
        ! than `<` so the -0 case is not silently treated as positive.
        if (sign(1.0_dp, x%limbs(1)) < 0.0_dp .or. &
            (x%limbs(1) == 0.0_dp .and. x%limbs(2) < 0.0_dp)) then
            res%limbs = -x%limbs
        else
            res = x
        end if
#:elif func == 'sqrt'
        res = dd_sqrt_full(x)
#:elif func == 'aint'
        res = dd_trunc_full(x)
#:elif func == 'anint'
        res = dd_round_full(x)
#:elif func == 'fraction'
        block
            integer :: e
            if (x%limbs(1) == 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                e = exponent(x%limbs(1))
                res%limbs(1) = scale(x%limbs(1), -e)
                res%limbs(2) = scale(x%limbs(2), -e)
            end if
        end block
#:elif func == 'tiny' or func == 'huge' or func == 'epsilon'
        ! Inquiry constants: derive from the underlying double, not via
        ! quad precision (which under/overflows when stored back as dp).
#:if func == 'tiny'
        res%limbs = [tiny(0.0_dp), 0.0_dp]
#:elif func == 'huge'
        res%limbs = [huge(0.0_dp), 0.0_dp]
#:else
        ! epsilon for double-double is roughly 2^-105 (one ulp at the lo
        ! limb of 1.0).
        res%limbs = [scale(epsilon(0.0_dp), -53), 0.0_dp]
#:endif
#:elif func == 'spacing'
        ! DD spacing: distance to the next representable double-double.
        ! For a normalized DD whose hi limb is x[0], the next DD differs
        ! in the lo limb by ulp(x[0]) * 2^-53, which is spacing(x[0]) / 2^53.
        res%limbs = [scale(spacing(x%limbs(1)), -53), 0.0_dp]
#:elif func == 'rrspacing'
        ! rrspacing(x) = |x| / spacing(x). Compute against the DD spacing
        ! so the result is consistent with mf_spacing above.
        res%limbs = [abs(x%limbs(1)) / scale(spacing(x%limbs(1)), -53), 0.0_dp]
#:elif func == 'exp'
        res = dd_exp_full(x)
#:elif func == 'log'
        res = dd_log_full(x)
#:elif func == 'log10'
        res = dd_log10_full(x)
#:elif func == 'sin'
        res = dd_sin_full(x)
#:elif func == 'cos'
        res = dd_cos_full(x)
#:elif func == 'sinpi'
        res = dd_sinpi_full(x)
#:elif func == 'cospi'
        res = dd_cospi_full(x)
#:elif func == 'tanpi'
        res = dd_tanpi_full(x)
#:elif func == 'tan'
        res = dd_tan_full(x)
#:elif func == 'sinh'
        res = dd_sinh_full(x)
#:elif func == 'cosh'
        res = dd_cosh_full(x)
#:elif func == 'tanh'
        res = dd_tanh_full(x)
#:elif func == 'asin'
        res = dd_asin_full(x)
#:elif func == 'acos'
        res = dd_acos_full(x)
#:elif func == 'atan'
        res = dd_atan_full(x)
#:elif func == 'asinpi'
        res = dd_asinpi_full(x)
#:elif func == 'acospi'
        res = dd_acospi_full(x)
#:elif func == 'atanpi'
        res = dd_atanpi_full(x)
#:elif func == 'asinh'
        res = dd_asinh_full(x)
#:elif func == 'acosh'
        res = dd_acosh_full(x)
#:elif func == 'atanh'
        res = dd_atanh_full(x)
#:elif func == 'erf'
        res = dd_erf_full(x)
#:elif func == 'erfc'
        res = dd_erfc_full(x)
#:elif func == 'erfc_scaled'
        res = dd_erfc_scaled_full(x)
#:elif func == 'gamma'
        res = dd_gamma_full(x)
#:elif func == 'log_gamma'
        res = dd_log_gamma_full(x)
#:elif func == 'bessel_j0'
        res = dd_bessel_j0_full(x)
#:elif func == 'bessel_j1'
        res = dd_bessel_j1_full(x)
#:elif func == 'bessel_y0'
        res = dd_bessel_y0_full(x)
#:elif func == 'bessel_y1'
        res = dd_bessel_y1_full(x)
#:else
        ! Should be unreachable: every entry of UNARY_MF_MF is handled above.
        res%limbs = [0.0_dp, 0.0_dp]
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Unary math: cx → cx (elemental)
    ! ----------------------------------------------------------------

#:for func in UNARY_CX_CX
    elemental function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        type(complex128x2) :: res
#:if func == 'conjg'
        res%re = x%re
        res%im%limbs = -x%im%limbs
#:else
        ! Delegate to C dd_cx_${func}$ — algorithm single-sourced in
        ! src/multifloats_math.cc (same Kahan sqrt, factored (1-z)(1+z)
        ! branches, overflow-safe log, etc. that used to live here).
        block
            type(cdd_t) :: a, r
            a%re = dd_t(x%re%limbs(1), x%re%limbs(2))
            a%im = dd_t(x%im%limbs(1), x%im%limbs(2))
            r = c_dd_cx_${func}$(a)
            res%re%limbs = [r%re%hi, r%re%lo]
            res%im%limbs = [r%im%hi, r%im%lo]
        end block
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Unary math: cx → mf (elemental)
    ! ----------------------------------------------------------------

#:for func in UNARY_CX_MF
    elemental function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
#:if func == 'abs'
        ! |a + bi| = hypot(a, b)
        res = mf_hypot_mf(x%re, x%im)
#:else
        ! aimag(a + bi) = b
        res = x%im
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Complex-specific: cmplx, real, mf_real (elemental)
    ! ----------------------------------------------------------------

    elemental function mf_cmplx_2(re, im) result(res)
        type(float64x2), intent(in) :: re, im
        type(complex128x2) :: res
        res%re = re
        res%im = im
    end function

    elemental function mf_cmplx_1(re) result(res)
        type(float64x2), intent(in) :: re
        type(complex128x2) :: res
        res%re = re
        res%im%limbs = [0.0_dp, 0.0_dp]
    end function

    elemental function cx_real(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    elemental function mf_real_mf(x) result(res)
        type(float64x2), intent(in) :: x
        type(float64x2) :: res
        res = x
    end function

    elemental function cx_real_mf(x) result(res)
        type(complex128x2), intent(in) :: x
        type(float64x2) :: res
        res = x%re
    end function

    ! ----------------------------------------------------------------
    ! Binary real functions (elemental)
    ! ----------------------------------------------------------------

#:for func in BINARY_REAL + BINARY_MINMAX
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
    elemental function ${n1}$_${func}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        type(float64x2) :: res
        type(float64x2) :: x, y
        x = ${MFCONV[n1].format('a')}$
        y = ${MFCONV[n2].format('b')}$
#:if func == 'min'
        if (x < y) then
            res = x
        else
            res = y
        end if
#:elif func == 'max'
        if (x > y) then
            res = x
        else
            res = y
        end if
#:elif func == 'sign'
        ! Fortran sign(a, b): magnitude of |a|, sign of b.
        block
            logical :: x_neg, y_neg
            x_neg = (x%limbs(1) < 0.0_dp .or. (x%limbs(1) == 0.0_dp .and. x%limbs(2) < 0.0_dp))
            y_neg = (y%limbs(1) < 0.0_dp .or. (y%limbs(1) == 0.0_dp .and. y%limbs(2) < 0.0_dp))
            if (x_neg .neqv. y_neg) then
                res%limbs = -x%limbs
            else
                res = x
            end if
        end block
#:elif func == 'mod'
        res = dd_fmod_full(x, y)
#:elif func == 'modulo'
        ! modulo via mod + sign adjustment
        res = ${n1}$_mod_${n2}$(a, b)
        if (res%limbs(1) /= 0.0_dp) then
            if ((res%limbs(1) > 0.0_dp .and. y%limbs(1) < 0.0_dp) .or. &
                (res%limbs(1) < 0.0_dp .and. y%limbs(1) > 0.0_dp)) then
                res = res + y
            end if
        end if
#:elif func == 'dim'
        if (.not. (ieee_is_finite(x%limbs(1)) .and. ieee_is_finite(y%limbs(1)))) then
            ! Defer to the dp intrinsic so NaN/Inf propagation matches.
            res%limbs = [dim(x%limbs(1), y%limbs(1)), 0.0_dp]
        else if (x > y) then
            res = x - y
        else
            res = MF_ZERO
        end if
#:elif func == 'hypot'
        res = dd_hypot_full(x, y)
#:elif func == 'atan2'
        ! Full-DD atan2 — see dd_atan2_full above. Here the binary
        ! generator passes (a, b) with a = "y" and b = "x" inverted, so
        ! we still call dd_atan2_full(x, y) where x corresponds to the
        ! first argument (y in standard atan2 terms).
        res = dd_atan2_full(x, y)
#:elif func == 'atan2pi'
        ! atan2pi(y, x) = atan2(y, x) / π. Same (a, b) convention.
        res = dd_atan2pi_full(x, y)
#:elif func == 'nearest'
        ! Approximate one DD ulp toward y on the leading limb only.
        block
            real(dp) :: hi, dir
            hi = x%limbs(1)
            if (y%limbs(1) > 0.0_dp) then
                dir = huge(0.0_dp)
            else
                dir = -huge(0.0_dp)
            end if
            res%limbs(1) = nearest(hi, dir)
            res%limbs(2) = 0.0_dp
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! min/max with N arguments (N = 3..8). LAPACK has call sites with
    ! up to 5 arguments; the upper bound is generous so future call
    ! sites do not regress.
#:def mf_minmax_body(func, n)
    elemental function mf_${func}$${n}$(${', '.join(['a%d' % i for i in range(1, n+1)])}$) result(res)
        type(float64x2), intent(in) :: ${', '.join(['a%d' % i for i in range(1, n+1)])}$
        type(float64x2) :: res
#:set cmp = '<' if func == 'min' else '>'
        res = a1
#:for i in range(2, n+1)
        if (a${i}$ ${cmp}$ res) res = a${i}$
#:endfor
    end function
#:enddef
#:for func in BINARY_MINMAX
#:for n in MINMAX_NARG
$:mf_minmax_body(func, n)

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Bessel functions with integer order (elemental + transformational)
    ! ----------------------------------------------------------------

    ! Full DD bessel_jn via forward/backward recurrence from j0/j1
    elemental function mf_bessel_jn_elem(n, x) result(res)
        integer, intent(in) :: n
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, ax, a, b, temp, t, di
        integer :: nn, i, k, m
        real(dp) :: xx
        type(float64x2) :: w, h, q0, q1, z, v, tmp2
        nn = n
        ax = x
        ! J(-n,x) = (-1)^n * J(n,x)
        if (nn < 0) then
            nn = -nn
            ax%limbs = -ax%limbs
        end if
        if (nn == 0) then; res = dd_bessel_j0_full(ax); return; end if
        if (nn == 1) then; res = dd_bessel_j1_full(ax); return; end if
        ! Handle sign: J(n,-x) = (-1)^n * J(n,x)
        if (ax%limbs(1) < 0.0_dp) then
            ax%limbs = -ax%limbs
            if (iand(nn, 1) /= 0) then
                ! odd n: result gets negated
            end if
        end if
        xx = ax%limbs(1)
        if (xx == 0.0_dp) then; res%limbs = [0.0_dp, 0.0_dp]; return; end if
        if (.not. ieee_is_finite(xx)) then; res%limbs = [0.0_dp, 0.0_dp]; return; end if

        if (real(nn, dp) <= xx) then
            ! Forward recurrence: stable when x >= n
            a = dd_bessel_j0_full(ax)
            b = dd_bessel_j1_full(ax)
            do i = 1, nn - 1
                temp = b
                di%limbs = [real(i + i, dp), 0.0_dp]
                b = di / ax * b - a
                a = temp
            end do
            res = b
        else
            ! Backward recurrence via continued fraction
            ! Determine k: number of extra terms needed
            w%limbs = [real(nn + nn, dp) / xx, 0.0_dp]
            h%limbs = [2.0_dp / xx, 0.0_dp]
            q0 = w
            z = w + h
            q1 = w * z - MF_ONE
            k = 1
            do while (q1%limbs(1) < 1.0e17_dp)
                k = k + 1
                z = z + h
                tmp2 = z * q1 - q0
                q0 = q1
                q1 = tmp2
            end do
            m = nn + nn
            t%limbs = [0.0_dp, 0.0_dp]
            do i = 2 * (nn + k), m, -2
                di%limbs = [real(i, dp), 0.0_dp]
                t = MF_ONE / (di / ax - t)
            end do
            a = t
            b = MF_ONE
            ! Backward recurrence
            v%limbs = [2.0_dp / xx, 0.0_dp]
            tmp2%limbs = [real(nn, dp), 0.0_dp]
            tmp2 = tmp2 * dd_log_full(mf_abs(v * tmp2))
            if (tmp2%limbs(1) < 1.1356e4_dp) then
                do i = nn - 1, 1, -1
                    temp = b
                    di%limbs = [real(i + i, dp), 0.0_dp]
                    b = di * b / ax - a
                    a = temp
                end do
            else
                do i = nn - 1, 1, -1
                    temp = b
                    di%limbs = [real(i + i, dp), 0.0_dp]
                    b = di * b / ax - a
                    a = temp
                    if (b%limbs(1) > 1e100_dp) then
                        a = a / b
                        t = t / b
                        b = MF_ONE
                    end if
                end do
            end if
            ! Normalize: pick j0 or j1 whichever is larger
            z = dd_bessel_j0_full(ax)
            w = dd_bessel_j1_full(ax)
            if (abs(z%limbs(1)) >= abs(w%limbs(1))) then
                res = t * z / b
            else
                res = t * w / a
            end if
        end if
        ! Apply sign for negative x with odd n
        if (x%limbs(1) < 0.0_dp .and. iand(nn, 1) /= 0) res%limbs = -res%limbs
    end function

    ! Full DD bessel_yn via forward recurrence from y0/y1
    elemental function mf_bessel_yn_elem(n, x) result(res)
        integer, intent(in) :: n
        type(float64x2), intent(in) :: x
        type(float64x2) :: res, a, b, temp, di
        integer :: nn, i, sgn
        real(dp) :: xx
        nn = n
        sgn = 1
        if (nn < 0) then
            nn = -nn
            sgn = 1 - iand(nn, 1) * 2  ! (-1)^n
        end if
        xx = x%limbs(1)
        if (xx <= 0.0_dp) then
            if (xx == 0.0_dp) then
                res%limbs = [ieee_value(0.0_dp, ieee_negative_inf), 0.0_dp]
            else
                res%limbs = [ieee_value(0.0_dp, ieee_quiet_nan), 0.0_dp]
            end if
            return
        end if
        if (nn == 0) then; res = dd_bessel_y0_full(x); if (sgn < 0) res%limbs = -res%limbs; return; end if
        if (nn == 1) then; res = dd_bessel_y1_full(x); if (sgn < 0) res%limbs = -res%limbs; return; end if
        if (.not. ieee_is_finite(xx)) then; res%limbs = [0.0_dp, 0.0_dp]; return; end if
        ! Forward recurrence (always stable for Yn)
        a = dd_bessel_y0_full(x)
        b = dd_bessel_y1_full(x)
        do i = 1, nn - 1
            temp = b
            di%limbs = [real(i + i, dp), 0.0_dp]
            b = di / x * b - a
            a = temp
            if (.not. ieee_is_finite(b%limbs(1))) exit
        end do
        if (sgn < 0) b%limbs = -b%limbs
        res = b
    end function

    pure function mf_bessel_jn_range(n1, n2, x) result(res)
        integer, intent(in) :: n1, n2
        type(float64x2), intent(in) :: x
        type(float64x2) :: res(max(n2 - n1 + 1, 0))
        integer :: i
        ! Jn forward recurrence is unstable for n > x, so use the
        ! elemental function which handles backward recurrence correctly.
        do i = 1, size(res)
            res(i) = mf_bessel_jn_elem(n1 + i - 1, x)
        end do
    end function

    pure function mf_bessel_yn_range(n1, n2, x) result(res)
        integer, intent(in) :: n1, n2
        type(float64x2), intent(in) :: x
        type(float64x2) :: res(max(n2 - n1 + 1, 0))
        type(float64x2) :: a, b, temp, di
        integer :: n, nsize
        nsize = size(res)
        if (nsize == 0) return
        ! Yn forward recurrence is always stable.
        ! Recur from y0/y1 up to n2, storing from n1 onward.
        a = dd_bessel_y0_full(x)
        b = dd_bessel_y1_full(x)
        if (n1 == 0) res(1) = a
        if (n1 <= 1 .and. 1 <= n2) res(1 - n1 + 1) = b
        do n = 2, n2
            temp = b
            di%limbs = [real(2*(n-1), dp), 0.0_dp]
            b = di / x * b - a
            a = temp
            if (n >= n1) res(n - n1 + 1) = b
            if (.not. ieee_is_finite(b%limbs(1))) then
                ! Fill rest with overflow value
                res(max(n - n1 + 2, 1):nsize) = b
                exit
            end if
        end do
    end function

    ! ----------------------------------------------------------------
    ! Functions: (mf, integer) → mf (elemental)
    ! ----------------------------------------------------------------

#:for func in MF_INT_TO_MF
    elemental function mf_${func}$(x, i) result(res)
        type(float64x2), intent(in) :: x
        integer, intent(in) :: i
        type(float64x2) :: res
#:if func == 'scale'
        ! scale(x, i) = x * 2^i — exact on dp limbs.
        res%limbs(1) = scale(x%limbs(1), i)
        res%limbs(2) = scale(x%limbs(2), i)
#:else
        ! set_exponent(x, i) = fraction(x) * 2^i.
        block
            integer :: e
            if (x%limbs(1) == 0.0_dp) then
                res%limbs = [0.0_dp, 0.0_dp]
            else
                e = exponent(x%limbs(1))
                res%limbs(1) = scale(x%limbs(1), i - e)
                res%limbs(2) = scale(x%limbs(2), i - e)
            end if
        end block
#:endif
    end function

#:endfor
    ! ----------------------------------------------------------------
    ! Numeric inquiry functions (elemental)
    ! ----------------------------------------------------------------

#:for func in INQUIRY_MF_INT
    elemental function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
#:if func == 'digits'
        res = 106
#:elif func == 'maxexponent'
        res = maxexponent(0.0_dp)
#:elif func == 'minexponent'
        res = minexponent(0.0_dp)
#:else
        res = radix(0.0_dp)
#:endif
    end function

#:endfor
#:for func in INQUIRY_BOTH_INT
    elemental function mf_${func}$(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
#:if func == 'precision'
        res = 31
#:else
        res = range(0.0_dp)
#:endif
    end function

    elemental function cx_${func}$(x) result(res)
        type(complex128x2), intent(in) :: x
        integer :: res
#:if func == 'precision'
        res = 31
#:else
        res = range(0.0_dp)
#:endif
    end function

#:endfor
    elemental function mf_storage_size(x) result(res)
        type(float64x2), intent(in) :: x
        integer :: res
        res = 2 * storage_size(0.0_dp)
    end function

    elemental function cx_storage_size(x) result(res)
        type(complex128x2), intent(in) :: x
        integer :: res
        res = 4 * storage_size(0.0_dp)
    end function

    ! ----------------------------------------------------------------
    ! Array reductions: value (maxval, minval) — rank 1-7
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_VAL
#:set CMP_OP = '>' if func == 'maxval' else '<'
#:for rank in range(1, MAX_RANK+1)
    pure function mf_${func}$_${rank}$d(array, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res
        logical :: have
        integer :: ${IVARS(rank)}$
        have = .false.
        ! Provide a deterministic default for empty / fully-masked input.
        res = mf_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (.not. have) then
                res = array(${IDXS(rank)}$)
                have = .true.
            else if (array(${IDXS(rank)}$) ${CMP_OP}$ res) then
                res = array(${IDXS(rank)}$)
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_${func}$_1d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        if (present(mask)) then
            res = mf_${func}$_1d(array, mask=mask)
        else
            res = mf_${func}$_1d(array)
        end if
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        logical :: have
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                have = .false.
                cur = mf_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (.not. have) then
                        cur = array(${IDXS(rank)}$)
                        have = .true.
                    else if (array(${IDXS(rank)}$) ${CMP_OP}$ cur) then
                        cur = array(${IDXS(rank)}$)
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: location (maxloc, minloc) — rank 1-7
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_LOC
#:set CMP_OP = '>' if func == 'maxloc' else '<'
#:set CMP_STRICT = '>' if func == 'maxloc' else '<'
#:for rank in range(1, MAX_RANK+1)
    pure function mf_${func}$_${rank}$d(array, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        type(float64x2) :: best
        logical :: have, scan_back
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        have = .false.
        best = mf_from_dp(0.0_dp)
        res = 0
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (.not. have) then
                best = array(${IDXS(rank)}$)
                res = [${IDXS(rank)}$]
                have = .true.
            else if (array(${IDXS(rank)}$) ${CMP_STRICT}$ best) then
                best = array(${IDXS(rank)}$)
                res = [${IDXS(rank)}$]
            else if (scan_back .and. array(${IDXS(rank)}$) == best) then
                res = [${IDXS(rank)}$]
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_${func}$_1d_dim(array, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = mf_${func}$_1d(array, mask=mask, back=back)
        else if (present(mask)) then
            r1 = mf_${func}$_1d(array, mask=mask)
        else if (present(back)) then
            r1 = mf_${func}$_1d(array, back=back)
        else
            r1 = mf_${func}$_1d(array)
        end if
        res = r1(1)
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: best
        logical :: have, scan_back
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                have = .false.
                best = mf_from_dp(0.0_dp)
                idx = 0
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (.not. have) then
                        best = array(${IDXS(rank)}$)
                        idx = i${d}$
                        have = .true.
                    else if (array(${IDXS(rank)}$) ${CMP_STRICT}$ best) then
                        best = array(${IDXS(rank)}$)
                        idx = i${d}$
                    else if (scan_back .and. array(${IDXS(rank)}$) == best) then
                        idx = i${d}$
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Array reductions: sum, product — rank 1-7 (mf + cx)
    ! ----------------------------------------------------------------

#:for func in ARRAY_REDUCE_SUM
#:set INIT_VAL = '0.0_dp' if func == 'sum' else '1.0_dp'
#:set OP_SYM = '+' if func == 'sum' else '*'
#:for rank in range(1, MAX_RANK+1)
    ! mf ${func}$ rank ${rank}$
    pure function mf_${func}$_${rank}$d(array, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res
        integer :: ${IVARS(rank)}$
#:if func == 'sum'
        real(dp) :: s_hi, s_lo, x_hi, x_lo, t, bp, ap, aerr, berr
        s_hi = 0.0_dp; s_lo = 0.0_dp
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            x_hi = array(${IDXS(rank)}$)%limbs(1)
            x_lo = array(${IDXS(rank)}$)%limbs(2)
            t = s_hi + x_hi
            bp = t - s_hi; ap = t - bp
            aerr = s_hi - ap; berr = x_hi - bp
            s_lo = s_lo + (x_lo + aerr + berr)
            s_hi = t
#:for d in range(rank)
        end do
#:endfor
        t = s_hi + s_lo; bp = t - s_hi
        res%limbs(1) = t
        res%limbs(2) = s_lo - bp
#:else
        res = mf_from_dp(${INIT_VAL}$)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            res = res ${OP_SYM}$ array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
#:endif
    end function

#:if rank == 1
    pure function mf_${func}$_1d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(float64x2) :: res
        if (present(mask)) then
            res = mf_${func}$_1d(array, mask=mask)
        else
            res = mf_${func}$_1d(array)
        end if
    end function
#:else
    pure function mf_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
#:if func == 'sum'
        real(dp) :: s_hi, s_lo, x_hi, x_lo, t, bp, ap, aerr, berr
#:else
        type(float64x2) :: cur
#:endif
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
#:if func == 'sum'
                ! Neumaier-compensated scalar accumulator, matching
                ! mf_sum_${rank}$d above.
                s_hi = 0.0_dp; s_lo = 0.0_dp
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    x_hi = array(${IDXS(rank)}$)%limbs(1)
                    x_lo = array(${IDXS(rank)}$)%limbs(2)
                    t = s_hi + x_hi
                    bp = t - s_hi; ap = t - bp
                    aerr = s_hi - ap; berr = x_hi - bp
                    s_lo = s_lo + (x_lo + aerr + berr)
                    s_hi = t
                end do
                t = s_hi + s_lo
                bp = t - s_hi; ap = t - bp
                aerr = s_hi - ap; berr = s_lo - bp
                res(${OUT_IDXS(rank, d)}$)%limbs(1) = t
                res(${OUT_IDXS(rank, d)}$)%limbs(2) = aerr + berr
#:else
                ! Product: each DD*DD is already ~1 DD ulp; Neumaier-style
                ! compensation does not apply to multiplication.
                cur = mf_from_dp(${INIT_VAL}$)
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    cur = cur ${OP_SYM}$ array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:endif
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

    ! cx ${func}$ rank ${rank}$
    pure function cx_${func}$_${rank}$d(array, mask) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex128x2) :: res
#:if func == 'sum'
        real(dp) :: re_hi, re_lo, im_hi, im_lo
        real(dp) :: xh, xl, t, bp, ap, aerr, berr
#:else
        type(float64x2) :: zero, one
#:endif
        integer :: ${IVARS(rank)}$
#:if func == 'sum'
        ! Neumaier-compensated accumulators on both real and imaginary limbs.
        re_hi = 0.0_dp; re_lo = 0.0_dp
        im_hi = 0.0_dp; im_lo = 0.0_dp
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            xh = array(${IDXS(rank)}$)%re%limbs(1)
            xl = array(${IDXS(rank)}$)%re%limbs(2)
            t = re_hi + xh
            bp = t - re_hi; ap = t - bp
            aerr = re_hi - ap; berr = xh - bp
            re_lo = re_lo + (xl + aerr + berr)
            re_hi = t
            xh = array(${IDXS(rank)}$)%im%limbs(1)
            xl = array(${IDXS(rank)}$)%im%limbs(2)
            t = im_hi + xh
            bp = t - im_hi; ap = t - bp
            aerr = im_hi - ap; berr = xh - bp
            im_lo = im_lo + (xl + aerr + berr)
            im_hi = t
#:for d in range(rank)
        end do
#:endfor
        t = re_hi + re_lo
        bp = t - re_hi; ap = t - bp
        aerr = re_hi - ap; berr = re_lo - bp
        res%re%limbs(1) = t
        res%re%limbs(2) = aerr + berr
        t = im_hi + im_lo
        bp = t - im_hi; ap = t - bp
        aerr = im_hi - ap; berr = im_lo - bp
        res%im%limbs(1) = t
        res%im%limbs(2) = aerr + berr
#:else
        zero = mf_from_dp(0.0_dp)
        one = mf_from_dp(1.0_dp)
        res%re = one
        res%im = zero
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            res = res ${OP_SYM}$ array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
#:endif
    end function

#:if rank == 1
    pure function cx_${func}$_1d_dim(array, dim, mask) result(res)
        type(complex128x2), intent(in) :: array(:)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        type(complex128x2) :: res
        if (present(mask)) then
            res = cx_${func}$_1d(array, mask=mask)
        else
            res = cx_${func}$_1d(array)
        end if
    end function
#:else
    pure function cx_${func}$_${rank}$d_dim(array, dim, mask) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        type(complex128x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
#:if func == 'sum'
        real(dp) :: re_hi, re_lo, im_hi, im_lo
        real(dp) :: xh, xl, t, bp, ap, aerr, berr
#:else
        type(complex128x2) :: cur
        type(float64x2) :: zero, one
#:endif
        integer :: ${IVARS(rank)}$
#:if func == 'product'
        zero = mf_from_dp(0.0_dp)
        one = mf_from_dp(1.0_dp)
#:endif
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
#:if func == 'sum'
                ! Neumaier-compensated real + imag accumulators.
                re_hi = 0.0_dp; re_lo = 0.0_dp
                im_hi = 0.0_dp; im_lo = 0.0_dp
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    xh = array(${IDXS(rank)}$)%re%limbs(1)
                    xl = array(${IDXS(rank)}$)%re%limbs(2)
                    t = re_hi + xh
                    bp = t - re_hi; ap = t - bp
                    aerr = re_hi - ap; berr = xh - bp
                    re_lo = re_lo + (xl + aerr + berr)
                    re_hi = t
                    xh = array(${IDXS(rank)}$)%im%limbs(1)
                    xl = array(${IDXS(rank)}$)%im%limbs(2)
                    t = im_hi + xh
                    bp = t - im_hi; ap = t - bp
                    aerr = im_hi - ap; berr = xh - bp
                    im_lo = im_lo + (xl + aerr + berr)
                    im_hi = t
                end do
                t = re_hi + re_lo
                bp = t - re_hi; ap = t - bp
                aerr = re_hi - ap; berr = re_lo - bp
                res(${OUT_IDXS(rank, d)}$)%re%limbs(1) = t
                res(${OUT_IDXS(rank, d)}$)%re%limbs(2) = aerr + berr
                t = im_hi + im_lo
                bp = t - im_hi; ap = t - bp
                aerr = im_hi - ap; berr = im_lo - bp
                res(${OUT_IDXS(rank, d)}$)%im%limbs(1) = t
                res(${OUT_IDXS(rank, d)}$)%im%limbs(2) = aerr + berr
#:else
                cur%re = one
                cur%im = zero
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    cur = cur ${OP_SYM}$ array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = cur
#:endif
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! dot_product (pure)
    ! ----------------------------------------------------------------

    pure function mf_dot_product(a, b) result(res)
        type(float64x2), intent(in) :: a(:), b(:)
        type(float64x2) :: res
        ! Fused multiply-accumulate with periodic renormalization.
        ! Every MF_FMA_RENORM_INTERVAL iterations (default 8) we
        ! fast_two_sum the accumulator to keep s_lo bounded. Set the
        ! interval to 0 to renormalize only at the end.
        ! Hoist the `ri > 0` test out of the inner loop: the `ri <= 0`
        ! path is a single tight FMA pass; the periodic-renorm path is
        ! a nested block loop with the fast_two_sum between blocks. This
        ! eliminates the `mod(k, ri)` check from the hot per-element body.
        real(dp) :: s_hi, s_lo, ah, al, bh, bl
        real(dp) :: p, e, cross, t, bp, ap, aerr, berr
        integer :: k, kk, ke, n, ri
        ri = MF_FMA_RENORM_INTERVAL
        n = size(a)
        s_hi = 0.0_dp
        s_lo = 0.0_dp
        if (ri <= 0) then
            do k = 1, n
                ah = a(k)%limbs(1); al = a(k)%limbs(2)
                bh = b(k)%limbs(1); bl = b(k)%limbs(2)
                p = ah * bh
                e = c_fma(ah, bh, -p)
                cross = ah * bl + al * bh
                t = s_hi + p
                bp = t - s_hi; ap = t - bp
                aerr = s_hi - ap; berr = p - bp
                s_lo = s_lo + (e + cross + aerr + berr)
                s_hi = t
            end do
        else
            do kk = 1, n, ri
                ke = min(kk + ri - 1, n)
                do k = kk, ke
                    ah = a(k)%limbs(1); al = a(k)%limbs(2)
                    bh = b(k)%limbs(1); bl = b(k)%limbs(2)
                    p = ah * bh
                    e = c_fma(ah, bh, -p)
                    cross = ah * bl + al * bh
                    t = s_hi + p
                    bp = t - s_hi; ap = t - bp
                    aerr = s_hi - ap; berr = p - bp
                    s_lo = s_lo + (e + cross + aerr + berr)
                    s_hi = t
                end do
                t = s_hi + s_lo; bp = t - s_hi
                s_hi = t; s_lo = s_lo - bp
            end do
        end if
        t = s_hi + s_lo
        bp = t - s_hi
        res%limbs(1) = t
        res%limbs(2) = s_lo - bp
    end function

    ! Complex dot_product: sum(conj(a_k) * b_k).
    ! Expand real/imag components so each scalar reduction routes through
    ! the compensated mf_dot_product (same Neumaier-style accumulator used
    ! by the real path) rather than a naive left fold. Uses 4 real dots at
    ! the cost of 4 small temp arrays.
    !
    ! Future: a single fused kernel that keeps four compensated DD
    ! accumulators (re_hi/lo, im_hi/lo) in registers across one pass over
    ! the inputs would cut memory traffic roughly in half and avoid the
    ! temp-array copies. Worth revisiting if profiling shows cx reductions
    ! as a bottleneck — current form prioritizes code reuse + correctness.
    pure function cx_dot_product(a, b) result(res)
        type(complex128x2), intent(in) :: a(:), b(:)
        type(complex128x2) :: res
        type(float64x2) :: a_re(size(a)), a_im(size(a))
        type(float64x2) :: b_re(size(b)), b_im(size(b))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        ! conj(a)·b = (a_re·b_re + a_im·b_im) + i (a_re·b_im - a_im·b_re)
        res%re = mf_dot_product(a_re, b_re) + mf_dot_product(a_im, b_im)
        res%im = mf_dot_product(a_re, b_im) - mf_dot_product(a_im, b_re)
    end function

    ! ----------------------------------------------------------------
    ! norm2 (pure) — rank 1-7, NO mask per standard
    ! ----------------------------------------------------------------

#:for rank in range(1, MAX_RANK+1)
    pure function mf_norm2_${rank}$d(array) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2) :: res
        type(float64x2) :: s
        integer :: ${IVARS(rank)}$
        s = mf_from_dp(0.0_dp)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            s = s + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
#:for d in range(rank)
        end do
#:endfor
        res = mf_sqrt(s)
    end function

#:if rank > 1
    pure function mf_norm2_${rank}$d_dim(array, dim) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        integer, intent(in) :: dim
        type(float64x2) :: res(${DIM_REDUCED_SIZES(rank)}$)
        type(float64x2) :: cur
        integer :: ${IVARS(rank)}$
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                cur = mf_from_dp(0.0_dp)
                do i${d}$ = 1, size(array, ${d}$)
                    cur = cur + array(${IDXS(rank)}$) * array(${IDXS(rank)}$)
                end do
                res(${OUT_IDXS(rank, d)}$) = mf_sqrt(cur)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ----------------------------------------------------------------
    ! findloc (pure) — rank 1-7 (mf + cx)
    ! ----------------------------------------------------------------

#:for rank in range(1, MAX_RANK+1)
    ! mf findloc rank ${rank}$
    pure function mf_findloc_${rank}$d(array, value, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function mf_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(:)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = mf_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = mf_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = mf_findloc_1d(array, value, back=back)
        else
            r1 = mf_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function mf_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(float64x2), intent(in) :: array(${COLONS(rank)}$)
        type(float64x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

    ! cx findloc rank ${rank}$
    pure function cx_findloc_${rank}$d(array, value, mask, back) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        type(complex128x2), intent(in) :: value
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${rank}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$
        scan_back = .false.
        if (present(back)) scan_back = back
        res = 0
        found = .false.
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(array, ${d}$)
#:endfor
            if (present(mask)) then
                if (.not. mask(${IDXS(rank)}$)) cycle
            end if
            if (array(${IDXS(rank)}$) == value) then
                res = [${IDXS(rank)}$]
                found = .true.
                if (.not. scan_back) return
            end if
#:for d in range(rank)
        end do
#:endfor
    end function

#:if rank == 1
    pure function cx_findloc_1d_dim(array, value, dim, mask, back) result(res)
        type(complex128x2), intent(in) :: array(:)
        type(complex128x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(:)
        logical, intent(in), optional :: back
        integer :: res
        integer :: r1(1)
        if (present(mask) .and. present(back)) then
            r1 = cx_findloc_1d(array, value, mask=mask, back=back)
        else if (present(mask)) then
            r1 = cx_findloc_1d(array, value, mask=mask)
        else if (present(back)) then
            r1 = cx_findloc_1d(array, value, back=back)
        else
            r1 = cx_findloc_1d(array, value)
        end if
        res = r1(1)
    end function
#:else
    pure function cx_findloc_${rank}$d_dim(array, value, dim, mask, back) result(res)
        type(complex128x2), intent(in) :: array(${COLONS(rank)}$)
        type(complex128x2), intent(in) :: value
        integer, intent(in) :: dim
        logical, intent(in), optional :: mask(${COLONS(rank)}$)
        logical, intent(in), optional :: back
        integer :: res(${DIM_REDUCED_SIZES(rank)}$)
        logical :: scan_back, found
        integer :: ${IVARS(rank)}$, idx
        scan_back = .false.
        if (present(back)) scan_back = back
        select case (dim)
#:for d in range(1, rank+1)
        case (${d}$)
#:for i in [j for j in range(rank, 0, -1) if j != d]
            do i${i}$ = 1, size(array, ${i}$)
#:endfor
                idx = 0
                found = .false.
                do i${d}$ = 1, size(array, ${d}$)
                    if (present(mask)) then
                        if (.not. mask(${IDXS(rank)}$)) cycle
                    end if
                    if (array(${IDXS(rank)}$) == value) then
                        idx = i${d}$
                        found = .true.
                        if (.not. scan_back) exit
                    end if
                end do
                res(${OUT_IDXS(rank, d)}$) = idx
#:for i in [j for j in range(rank, 0, -1) if j != d]
            end do
#:endfor
#:endfor
        end select
    end function
#:endif

#:endfor
    ! ----------------------------------------------------------------
    ! matmul (pure) — mf + cx
    ! ----------------------------------------------------------------

    ! mf matmul: 2D × 2D → 2D (delegates to C kernel dd_matmul_mm)
    pure function mf_matmul_mm(a, b) result(res)
        type(float64x2), intent(in), target, contiguous :: a(:,:), b(:,:)
        type(float64x2), target :: res(size(a,1), size(b,2))
        call c_dd_matmul_mm(c_loc(a), c_loc(b), c_loc(res), &
            int(size(a,1), c_int64_t), int(size(a,2), c_int64_t), &
            int(size(b,2), c_int64_t), &
            int(MF_FMA_RENORM_INTERVAL, c_int64_t))
    end function

    ! mf matmul: 2D × 1D → 1D (delegates to C kernel dd_matmul_mv)
    pure function mf_matmul_mv(a, b) result(res)
        type(float64x2), intent(in), target, contiguous :: a(:,:), b(:)
        type(float64x2), target :: res(size(a,1))
        call c_dd_matmul_mv(c_loc(a), c_loc(b), c_loc(res), &
            int(size(a,1), c_int64_t), int(size(a,2), c_int64_t), &
            int(MF_FMA_RENORM_INTERVAL, c_int64_t))
    end function

    ! mf matmul: 1D × 2D → 1D (delegates to C kernel dd_matmul_vm)
    pure function mf_matmul_vm(a, b) result(res)
        type(float64x2), intent(in), target, contiguous :: a(:), b(:,:)
        type(float64x2), target :: res(size(b,2))
        call c_dd_matmul_vm(c_loc(a), c_loc(b), c_loc(res), &
            int(size(a), c_int64_t), int(size(b,2), c_int64_t), &
            int(MF_FMA_RENORM_INTERVAL, c_int64_t))
    end function

    ! Complex matmul via 4 real DD matmuls on the split (re, im) parts.
    ! (a + i b) · (c + i d) = (a·c - b·d) + i (a·d + b·c), so one complex
    ! matmul of shape (M, K) × (K, N) becomes four real matmuls of the
    ! same shape, each going through the compensated mf_matmul_mm kernel.
    ! Cost: 2 extra m·k + 2 extra k·n temp DD arrays (plus 2 m·n
    ! intermediates) per call.
    !
    ! Future: a fused complex kernel that streams each input once and
    ! accumulates the four real-part / imag-part contributions into a
    ! single set of compensated DD accumulators (4 doubles per output)
    ! would roughly halve the memory traffic and remove the temp arrays.
    ! The real mf_matmul is compute-bound on most targets, so the payoff
    ! is modest — revisit if cx matmul becomes a profile hotspot. The
    ! analogous note on cx_dot_product above applies here too.
    pure function cx_matmul_mm(a, b) result(res)
        type(complex128x2), intent(in) :: a(:,:), b(:,:)
        type(complex128x2) :: res(size(a,1), size(b,2))
        type(float64x2) :: a_re(size(a,1), size(a,2)), a_im(size(a,1), size(a,2))
        type(float64x2) :: b_re(size(b,1), size(b,2)), b_im(size(b,1), size(b,2))
        type(float64x2) :: p_re(size(a,1), size(b,2)), p_im(size(a,1), size(b,2))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        p_re = mf_matmul_mm(a_re, b_re) - mf_matmul_mm(a_im, b_im)
        p_im = mf_matmul_mm(a_re, b_im) + mf_matmul_mm(a_im, b_re)
        res%re = p_re
        res%im = p_im
    end function

    pure function cx_matmul_mv(a, b) result(res)
        type(complex128x2), intent(in) :: a(:,:), b(:)
        type(complex128x2) :: res(size(a,1))
        type(float64x2) :: a_re(size(a,1), size(a,2)), a_im(size(a,1), size(a,2))
        type(float64x2) :: b_re(size(b)), b_im(size(b))
        type(float64x2) :: p_re(size(a,1)), p_im(size(a,1))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        p_re = mf_matmul_mv(a_re, b_re) - mf_matmul_mv(a_im, b_im)
        p_im = mf_matmul_mv(a_re, b_im) + mf_matmul_mv(a_im, b_re)
        res%re = p_re
        res%im = p_im
    end function

    pure function cx_matmul_vm(a, b) result(res)
        type(complex128x2), intent(in) :: a(:), b(:,:)
        type(complex128x2) :: res(size(b,2))
        type(float64x2) :: a_re(size(a)), a_im(size(a))
        type(float64x2) :: b_re(size(b,1), size(b,2)), b_im(size(b,1), size(b,2))
        type(float64x2) :: p_re(size(b,2)), p_im(size(b,2))
        a_re = a%re; a_im = a%im
        b_re = b%re; b_im = b%im
        p_re = mf_matmul_vm(a_re, b_re) - mf_matmul_vm(a_im, b_im)
        p_im = mf_matmul_vm(a_re, b_im) + mf_matmul_vm(a_im, b_re)
        res%re = p_re
        res%im = p_im
    end function

    ! ----------------------------------------------------------------
    ! Configuration
    ! ----------------------------------------------------------------

    subroutine mf_set_fma_renorm_interval(n)
        integer, intent(in) :: n
        MF_FMA_RENORM_INTERVAL = n
    end subroutine

    ! ----------------------------------------------------------------
    ! random_number (impure subroutine)
    ! ----------------------------------------------------------------

    subroutine mf_random_number_0d(harvest)
        type(float64x2), intent(out) :: harvest
        real(dp) :: hi, lo, s, b
        call random_number(hi)
        call random_number(lo)
        ! Pack two independent dp randoms into a DD: hi gets ~53 bits in [0,1),
        ! lo contributes ~53 more bits below hi's ulp.
        lo = lo * 2.0_dp**(-53)
        s = hi + lo
        b = s - hi
        harvest%limbs(1) = s
        harvest%limbs(2) = lo - b
    end subroutine

#:for rank in range(1, MAX_RANK+1)
    subroutine mf_random_number_${rank}$d(harvest)
        type(float64x2), intent(out) :: harvest(${COLONS(rank)}$)
        real(dp) :: hi(${SIZES(rank, 'harvest')}$), lo(${SIZES(rank, 'harvest')}$)
        real(dp) :: s, b
        integer :: ${IVARS(rank)}$
        call random_number(hi)
        call random_number(lo)
        lo = lo * 2.0_dp**(-53)
#:for d in range(rank, 0, -1)
        do i${d}$ = 1, size(harvest, ${d}$)
#:endfor
            s = hi(${IDXS(rank)}$) + lo(${IDXS(rank)}$)
            b = s - hi(${IDXS(rank)}$)
            harvest(${IDXS(rank)}$)%limbs(1) = s
            harvest(${IDXS(rank)}$)%limbs(2) = lo(${IDXS(rank)}$) - b
#:for d in range(rank)
        end do
#:endfor
    end subroutine

#:endfor
    ! ----------------------------------------------------------------
    ! Binary arithmetic (+, -, *, /) — elemental
    ! ----------------------------------------------------------------

#! Unpack operand `name` (a or b) into scalar dp locals (hi, lo). For non-DD
#! operands lo is 0. Used by the real-DD arithmetic bodies below.
#:def unpack_operand(name, n, hi, lo)
#:if n == 'mf'
        ${hi}$ = ${name}$%limbs(1)
        ${lo}$ = ${name}$%limbs(2)
#:elif n == 'sp' or n == 'int'
        ${hi}$ = real(${name}$, dp)
        ${lo}$ = 0.0_dp
#:else
        ${hi}$ = ${name}$
        ${lo}$ = 0.0_dp
#:endif
#:enddef

#! Real-DD add/sub. For sub, the caller negates y first.
#:def dd_arith_addsub_body()
        s = x0 + y0
        if (.not. ieee_is_finite(s)) then
            ! Any non-finite input or overflow makes s non-finite. The
            ! EFT below would propagate NaN to limbs(2); short-circuit
            ! and let IEEE produce the correct leading limb.
            res%limbs(1) = s
            res%limbs(2) = 0.0_dp
            return
        end if
        ! When both hi limbs are zero, the two_sum EFT produces a
        ! spurious +0 from mixed-sign zero arithmetic (IEEE 754:
        ! -0 + +0 = +0 in round-to-nearest). Short-circuit so the
        ! correct IEEE sign of s is preserved.
        if (x0 == 0.0_dp .and. y0 == 0.0_dp) then
            res%limbs(1) = s
            res%limbs(2) = x1 + y1
            return
        end if
        aprime = s - y0
        bprime = s - aprime
        aerr = x0 - aprime
        berr = y0 - bprime
        e = aerr + berr
        c = x1 + y1
        aprime = c - y1
        bprime = c - aprime
        aerr = x1 - aprime
        berr = y1 - bprime
        d = aerr + berr
        t = s + c
        bprime = t - s
        c = c - bprime
        e = e + d + c
        res%limbs(1) = t + e
        bprime = res%limbs(1) - t
        res%limbs(2) = e - bprime
#:enddef

#! Real-DD multiply via FMA-based two_prod plus cross terms.
#:def dd_arith_mul_body()
        p00 = x0 * y0
        if (.not. ieee_is_finite(p00)) then
            ! Any non-finite input, 0*inf, or overflow lands here in one
            ! test (no separate ieee_is_finite on x0/y0).
            res%limbs(1) = p00
            res%limbs(2) = 0.0_dp
            return
        end if
        e00 = c_fma(x0, y0, -p00)
        p01 = x0 * y1
        p10 = x1 * y0
        e00 = e00 + (p01 + p10)
        res%limbs(1) = p00 + e00
        bprime = res%limbs(1) - p00
        res%limbs(2) = e00 - bprime
#:enddef

#! Newton-refined DD divide. The first guard tests the leading quotient s;
#! if non-finite, every IEEE edge case (y=0, 0/0, inf/finite, NaN) collapses
#! to the same path. The second guard catches finite/inf (s=0 but refinement
#! would hit 0*inf=NaN).
#:def dd_arith_div_body()
        s = x0 / y0
        if (.not. ieee_is_finite(s)) then
            res%limbs(1) = s
            res%limbs(2) = 0.0_dp
            return
        end if
        if (.not. ieee_is_finite(y0)) then
            ! y is ±inf: quotient is ±0 (already in s). The Newton
            ! refinement would compute 0*inf = NaN; short-circuit.
            res%limbs(1) = s
            res%limbs(2) = 0.0_dp
            return
        end if
        ux = 1.0_dp / y0
        p00 = x0 * ux
        e00 = c_fma(x0, ux, -p00) + x1 * ux
        q0 = p00 + e00
        bprime = q0 - p00
        q1_lo = e00 - bprime
        p00 = q0 * y0
        e00 = c_fma(q0, y0, -p00) + q0 * y1 + q1_lo * y0
        q_y0 = p00 + e00
        bprime = q_y0 - p00
        q_y1 = e00 - bprime
        ! residual = q*y - x; final step is q - residual * (1/y0).
        ! Inline the (q*y - x) DD subtract since we already have x0/x1.
        s = q_y0 + (-x0)
        aprime = s - (-x0)
        bprime = s - aprime
        aerr = q_y0 - aprime
        berr = (-x0) - bprime
        e = aerr + berr
        c = q_y1 + (-x1)
        t = s + c
        bprime = t - s
        c = c - bprime
        e = e + c
        r0 = t + e
        bprime = r0 - t
        r1 = e - bprime
        ! correction = residual * u  (u ≈ 1/y0, single dp value)
        p00 = r0 * ux
        e00 = c_fma(r0, ux, -p00) + r1 * ux
        ! res = q - correction
        s = q0 + (-p00)
        aprime = s - (-p00)
        bprime = s - aprime
        aerr = q0 - aprime
        berr = (-p00) - bprime
        e = aerr + berr
        c = q1_lo + (-e00)
        t = s + c
        bprime = t - s
        c = c - bprime
        e = e + c
        res%limbs(1) = t + e
        bprime = res%limbs(1) - t
        res%limbs(2) = e - bprime
#:enddef

#! Complex result: lift any non-complex operand to a complex128x2 via
#! assignment overloads, then do the op in (re, im) form.
#:def cx_arith_body(opname)
        block
            type(complex128x2) :: ca, cb
            type(float64x2) :: denom
            ca = a
            cb = b
#:if opname == 'add'
            res%re = ca%re + cb%re
            res%im = ca%im + cb%im
#:elif opname == 'sub'
            res%re = ca%re - cb%re
            res%im = ca%im - cb%im
#:elif opname == 'mul'
            res%re = ca%re * cb%re - ca%im * cb%im
            res%im = ca%re * cb%im + ca%im * cb%re
#:else
            denom = cb%re * cb%re + cb%im * cb%im
            res%re = (ca%re * cb%re + ca%im * cb%im) / denom
            res%im = (ca%im * cb%re - ca%re * cb%im) / denom
#:endif
        end block
#:enddef

#:for opsym, opname in ARITH_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex128x2)' if rc else 'type(float64x2)'}$ :: res
#:if not rc
        ! Hot fast path uses scalar dp locals (no float64x2 copies, no
        ! generic mf_from_dp call). The single non-finite guard runs
        ! after the leading-limb op so a single test catches every IEEE
        ! special case.
        real(dp) :: x0, x1, y0, y1
        real(dp) :: s, e, t, aprime, bprime, aerr, berr
        real(dp) :: p00, e00, p01, p10, c, d
        real(dp) :: ux, uy, q0, q1_lo, r0, r1, q_y0, q_y1
$:unpack_operand('a', n1, 'x0', 'x1')
$:unpack_operand('b', n2, 'y0', 'y1')
#:if opname == 'sub'
        y0 = -y0
        y1 = -y1
#:endif
#:if opname == 'add' or opname == 'sub'
$:dd_arith_addsub_body()
#:elif opname == 'mul'
$:dd_arith_mul_body()
#:else
$:dd_arith_div_body()
#:endif
#:else
$:cx_arith_body(opname)
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Power operator (**) — elemental
    ! ----------------------------------------------------------------

#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
#:set rc = ISCPLX[n1] or ISCPLX[n2]
    elemental function ${n1}$_pow_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        ${'type(complex128x2)' if rc else 'type(float64x2)'}$ :: res
#:if n2 == 'int'
#:if rc
        ! Integer-power on a complex base via repeated multiplication.
        block
            type(complex128x2) :: base
            integer :: k, n
            base = a
            res%re = MF_ONE
            res%im%limbs = [0.0_dp, 0.0_dp]
            n = abs(b)
            do k = 1, n
                res = res * base
            end do
            if (b < 0) then
                res = complex128x2(MF_ONE, mf_from_dp(0.0_dp)) / res
            end if
        end block
#:else
        ! Integer-power on a real base via repeated multiplication.
        block
            type(float64x2) :: base
            integer :: k, n
            base = a
            res = MF_ONE
            n = abs(b)
            do k = 1, n
                res = res * base
            end do
            if (b < 0) res = MF_ONE / res
        end block
#:endif
#:elif rc
        ! General complex power: a^b = exp(b * log(a))
        block
            type(complex128x2) :: ca, cb
            ca = a
            cb = b
            res = cx_exp(cb * cx_log(ca))
        end block
#:else
        ! General real power: a^b = exp(b * log(a))
        block
            type(float64x2) :: x, y
            x = a
            y = b
            res = mf_exp(y * mf_log(x))
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Equality comparison (==, /=) — elemental
    ! ----------------------------------------------------------------

#:for opsym, opname in EQ_OPS
#:for n1, d1 in ATYPES
#:for n2, d2 in ATYPES
#:if n1 in ('mf', 'cx') or n2 in ('mf', 'cx')
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
#:if not ISCPLX[n1] and not ISCPLX[n2]
        type(float64x2) :: x, y
        x = ${MFCONV[n1].format('a')}$
        y = ${MFCONV[n2].format('b')}$
#:if opname == 'eq'
        res = x%limbs(1) == y%limbs(1) .and. x%limbs(2) == y%limbs(2)
#:else
        res = x%limbs(1) /= y%limbs(1) .or. x%limbs(2) /= y%limbs(2)
#:endif
#:else
        ! Complex (in)equality: compare real and imaginary parts in native DD.
        block
            type(complex128x2) :: ca, cb
            ca = a
            cb = b
#:if opname == 'eq'
            res = (ca%re == cb%re) .and. (ca%im == cb%im)
#:else
            res = (ca%re /= cb%re) .or. (ca%im /= cb%im)
#:endif
        end block
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Ordered comparison (<, >, <=, >=) — elemental
    ! ----------------------------------------------------------------

#:for opsym, opname in ORD_OPS
#:for n1, d1 in RTYPES
#:for n2, d2 in RTYPES
#:if n1 == 'mf' or n2 == 'mf'
    elemental function ${n1}$_${opname}$_${n2}$(a, b) result(res)
        ${d1}$, intent(in) :: a
        ${d2}$, intent(in) :: b
        logical :: res
        type(float64x2) :: x, y
        x = ${MFCONV[n1].format('a')}$
        y = ${MFCONV[n2].format('b')}$
#:if opname == 'lt'
        res = x%limbs(1) < y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) < y%limbs(2))
#:elif opname == 'gt'
        res = x%limbs(1) > y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) > y%limbs(2))
#:elif opname == 'le'
        res = x%limbs(1) < y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) <= y%limbs(2))
#:else
        res = x%limbs(1) > y%limbs(1) .or. (x%limbs(1) == y%limbs(1) .and. x%limbs(2) >= y%limbs(2))
#:endif
    end function

#:endif
#:endfor
#:endfor
#:endfor
    ! ----------------------------------------------------------------
    ! Defined I/O
    ! ----------------------------------------------------------------

    subroutine write_mf_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(float64x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        real(qp) :: val_qp
        val_qp = to_qp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        else
            write(unit, '(ES23.16,1X,ES23.16)', iostat=iostat, iomsg=iomsg) &
                dtv%limbs(1), dtv%limbs(2)
        end if
#:endif
    end subroutine

    subroutine write_cx_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(complex128x2), intent(in) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        complex(qp) :: val_cqp
        val_cqp = to_cqp(dtv)
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            write(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            write(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            write(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        else
            write(unit, '(4(ES23.16,1X))', iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        end if
#:endif
    end subroutine

    subroutine read_mf_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(float64x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        real(qp) :: val_qp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_qp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_qp
        end if
        if (iostat == 0) then
            dtv%limbs(1) = real(val_qp, dp)
            dtv%limbs(2) = real(val_qp - real(dtv%limbs(1), qp), dp)
        end if
#:else
        ! Without quad, read both limbs as doubles.
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) dtv%limbs(1), dtv%limbs(2)
        end if
#:endif
    end subroutine

    subroutine read_cx_formatted(dtv, unit, iotype, v_list, iostat, iomsg)
        type(complex128x2), intent(inout) :: dtv
        integer, intent(in) :: unit
        character(*), intent(in) :: iotype
        integer, intent(in) :: v_list(:)
        integer, intent(out) :: iostat
        character(*), intent(inout) :: iomsg
#:if HAS_QUAD
        complex(qp) :: val_cqp
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        else if (iotype(1:2) == 'DT' .and. len(iotype) > 2) then
            read(unit, fmt='(' // iotype(3:) // ')', iostat=iostat, iomsg=iomsg) val_cqp
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) val_cqp
        end if
        if (iostat == 0) then
            dtv%re%limbs(1) = real(real(val_cqp, qp), dp)
            dtv%re%limbs(2) = real(real(val_cqp, qp) - real(dtv%re%limbs(1), qp), dp)
            dtv%im%limbs(1) = real(aimag(val_cqp), dp)
            dtv%im%limbs(2) = real(aimag(val_cqp) - real(dtv%im%limbs(1), qp), dp)
        end if
#:else
        if (iotype == 'LISTDIRECTED') then
            read(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        else
            read(unit, *, iostat=iostat, iomsg=iomsg) &
                dtv%re%limbs(1), dtv%re%limbs(2), dtv%im%limbs(1), dtv%im%limbs(2)
        end if
#:endif
    end subroutine

end module multifloats
